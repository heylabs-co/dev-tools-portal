---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompanyCard from '../components/CompanyCard.astro';
import { getCollection } from 'astro:content';
import pairsData from '../../data/comparisons/top-pairs.json';
import sectionsData from '../../data/meta/sections.json';

type Section = {
  slug: string;
  name: string;
  icon: string;
  description: string;
  order: number;
  categories: string[];
};

const allCategories = await getCollection('categories');
const catBySlug = new Map(allCategories.map((c) => [c.data.slug, c.data]));
const sections = (sectionsData as Section[]).slice().sort((a, b) => a.order - b.order);

const sectionsView = sections.map((s) => {
  const cats = s.categories
    .map((slug) => catBySlug.get(slug))
    .filter((c): c is NonNullable<typeof c> => c !== undefined)
    .sort((a, b) => (b.company_count ?? 0) - (a.company_count ?? 0));
  const total = cats.reduce((sum, c) => sum + (c.company_count ?? 0), 0);
  return { ...s, cats: cats.slice(0, 6), totalCats: cats.length, total };
});

const allCompanies = await getCollection('companies');
const toolCount = allCompanies.length;
const catCount = allCategories.length;
const compareCount = (pairsData as any[]).length;
const recentCompanies = allCompanies
  .filter((c) => c.data.updated_at)
  .sort((a, b) => (b.data.updated_at! > a.data.updated_at! ? 1 : -1))
  .slice(0, 12);
---

<BaseLayout
  title={`Compare ${toolCount}+ Developer Tools`}
  description={`Compare ${toolCount}+ developer tools side-by-side — pricing models, lock-in risk scores, migration guides, and free tier availability. Find the perfect tool for your stack.`}
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'WebSite',
        name: 'tool.news',
        url: 'https://tool.news',
        description: `Compare ${toolCount}+ developer tools — pricing, lock-in scores, migration guides`,
        potentialAction: {
          '@type': 'SearchAction',
          target: 'https://tool.news/search/?q={search_term_string}',
          'query-input': 'required name=search_term_string',
        },
      },
      {
        '@type': 'Organization',
        name: 'HeyLabs',
        url: 'https://github.com/heylabs-co',
        logo: 'https://tool.news/favicon.svg',
      },
    ],
  }}
>
  <!-- Hero -->
  <section class="relative overflow-hidden py-28 sm:py-36">
    <!-- Background: radial gradient + dot grid -->
    <div class="absolute inset-0 bg-[#FAFBFC] dark:bg-[#0A0A0F]"></div>
    <div
      class="absolute inset-0 opacity-[0.4] dark:opacity-[0.15]"
      style="background-image: radial-gradient(circle at 1px 1px, #5E6AD2 1px, transparent 0); background-size: 32px 32px;"
    ></div>
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full opacity-20 dark:opacity-10 blur-3xl"
      style="background: radial-gradient(ellipse, #818CF8 0%, #5E6AD2 40%, transparent 70%);"
    ></div>

    <div class="relative mx-auto max-w-3xl px-6 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-[#0F172A] dark:text-[#EDEDEF] leading-[1.1]">
        The Developer Tool<br />Intelligence Platform
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-[#64748B] dark:text-[#8A8F98] max-w-2xl mx-auto leading-relaxed">
        {toolCount}+ tools compared — pricing, lock-in scores, migration guides.
        Make informed decisions, faster.
      </p>

      <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
        <a
          href="/recommend/"
          class="inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-[#5E6AD2] to-[#818CF8] px-6 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-90 transition-opacity"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l2.4 7.4L22 12l-7.6 2.6L12 22l-2.4-7.4L2 12l7.6-2.6L12 2z" />
          </svg>
          Get AI Recommendation
        </a>
        <a
          href="/tools/"
          class="inline-flex items-center rounded-lg border border-[#5E6AD2]/30 dark:border-[#818CF8]/30 px-6 py-3 text-sm font-semibold text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/5 dark:hover:bg-[#818CF8]/5 transition-colors"
        >
          Browse Tools
        </a>
        <a
          href="/compare/"
          class="inline-flex items-center rounded-lg border border-[#5E6AD2]/30 dark:border-[#818CF8]/30 px-6 py-3 text-sm font-semibold text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/5 dark:hover:bg-[#818CF8]/5 transition-colors"
        >
          Compare Tools
        </a>
      </div>

      <!-- Stats row -->
      <div class="mt-16 flex items-center justify-center gap-8 sm:gap-16">
        <div class="text-center">
          <span class="block text-2xl sm:text-3xl font-bold text-[#0F172A] dark:text-[#EDEDEF]" style="font-family: 'JetBrains Mono', monospace;">{toolCount}+</span>
          <span class="block mt-1 text-sm text-[#64748B] dark:text-[#8A8F98]">Tools</span>
        </div>
        <div class="h-8 w-px bg-gray-200 dark:bg-gray-800"></div>
        <div class="text-center">
          <span class="block text-2xl sm:text-3xl font-bold text-[#0F172A] dark:text-[#EDEDEF]" style="font-family: 'JetBrains Mono', monospace;">{catCount}</span>
          <span class="block mt-1 text-sm text-[#64748B] dark:text-[#8A8F98]">Categories</span>
        </div>
        <div class="h-8 w-px bg-gray-200 dark:bg-gray-800"></div>
        <div class="text-center">
          <span class="block text-2xl sm:text-3xl font-bold text-[#0F172A] dark:text-[#EDEDEF]" style="font-family: 'JetBrains Mono', monospace;">{compareCount}+</span>
          <span class="block mt-1 text-sm text-[#64748B] dark:text-[#8A8F98]">Comparisons</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Browse by Section -->
  <section class="mx-auto max-w-7xl px-6 py-24">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-bold text-[#0F172A] dark:text-[#EDEDEF]">Browse by Section</h2>
      <p class="mt-2 text-[#64748B] dark:text-[#8A8F98]">
        {catCount} categories across {sections.length} sections — payments, AI, mobile, infrastructure, and more.
      </p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2">
      {sectionsView.map((sec) => (
        <article
          class="group rounded-2xl border p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md"
          style="border-color: var(--color-border); background-color: var(--color-surface);"
        >
          <a
            href={`/sections/${sec.slug}/`}
            class="flex items-baseline justify-between gap-3"
          >
            <div class="flex items-baseline gap-3 min-w-0">
              <span class="text-3xl leading-none">{sec.icon}</span>
              <h3 class="text-lg font-bold transition-colors duration-150 group-hover:text-[#5E6AD2] dark:group-hover:text-[#818CF8]" style="color: var(--color-text);">
                {sec.name}
              </h3>
            </div>
            <span class="text-xs shrink-0" style="color: var(--color-muted);">
              {sec.totalCats} cats · {sec.total.toLocaleString()} tools
            </span>
          </a>
          <p class="mt-2 text-sm" style="color: var(--color-muted);">{sec.description}</p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            {sec.cats.map((cat) => (
              <a
                href={`/categories/${cat.slug}/`}
                class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium transition-colors hover:border-[#5E6AD2] dark:hover:border-[#818CF8]"
                style="border-color: var(--color-border); color: var(--color-text-secondary); background-color: var(--color-elevated);"
              >
                {cat.name} <span class="ml-1 opacity-60">{cat.company_count}</span>
              </a>
            ))}
            {sec.totalCats > 6 && (
              <a
                href={`/sections/${sec.slug}/`}
                class="inline-flex items-center rounded-full border border-dashed px-2.5 py-0.5 text-xs font-medium"
                style="border-color: var(--color-border); color: var(--color-accent);"
              >
                +{sec.totalCats - 6} more
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href="/categories/"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-[#5E6AD2] dark:text-[#818CF8] hover:opacity-80 transition-opacity"
      >
        See all {catCount} categories
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Recently Updated -->
  <section class="mx-auto max-w-7xl px-6 py-24">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-bold text-[#0F172A] dark:text-[#EDEDEF]">Recently Updated</h2>
      <p class="mt-2 text-[#64748B] dark:text-[#8A8F98]">The latest tools added or refreshed on the platform.</p>
    </div>
    <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {recentCompanies.map((company) => (
        <CompanyCard
          slug={company.data.slug}
          name={company.data.name}
          description={company.data.description}
          logo={company.data.logo ?? ''}
          category={company.data.categories.primary.name}
          lockInLevel={company.data.scores?.lock_in?.level}
          pricingModel={company.data.pricing?.model}
          hasFree={company.data.pricing?.has_free_tier}
        />
      ))}
    </div>
    <div class="mt-10 text-center">
      <a
        href="/tools/"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-[#5E6AD2] dark:text-[#818CF8] hover:opacity-80 transition-opacity"
      >
        View all tools
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
