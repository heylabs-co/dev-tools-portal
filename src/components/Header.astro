---
const mobileLinks = [
  { label: 'Tools', href: '/tools/' },
  { label: 'MCP Servers', href: '/mcp-servers/' },
  { label: 'AI Skills', href: '/skills/' },
  { label: 'VS Code Extensions', href: '/extensions/' },
  { label: 'JetBrains Plugins', href: '/plugins/' },
  { label: 'Compare', href: '/compare/' },
  { label: 'Trending', href: '/trending/' },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 transition-all duration-200"
  style="background-color: transparent;"
>
  <div
    class="backdrop-blur-xl"
    style="background-color: color-mix(in srgb, var(--color-surface) 80%, transparent); border-bottom: 1px solid var(--color-border);"
  >
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 lg:px-6">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <span
          class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-sm font-black text-white transition-transform duration-200 group-hover:scale-105"
          style="background-color: var(--color-accent);"
        >TN</span>
        <span
          class="hidden text-[15px] font-semibold tracking-tight sm:inline"
          style="color: var(--color-text);"
        >tool.news</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden items-center gap-1 md:flex">

        <!-- Tools (direct link) -->
        <li>
          <a
            href="/tools/"
            class="nav-link relative px-3 py-2 text-sm font-medium transition-colors duration-150"
            style="color: var(--color-muted);"
          >
            Tools
            <span class="nav-underline absolute bottom-0.5 left-3 right-3 h-px origin-left scale-x-0 transition-transform duration-200 ease-out" style="background-color: var(--color-accent);"></span>
          </a>
        </li>

        <!-- AI Ecosystem dropdown -->
        <li class="dropdown-parent relative">
          <button
            class="nav-link dropdown-trigger relative flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors duration-150 cursor-default select-none"
            style="color: var(--color-muted);"
            tabindex="0"
            aria-haspopup="true"
          >
            AI Ecosystem
            <svg class="chevron h-3.5 w-3.5 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
            <span class="nav-underline absolute bottom-0.5 left-3 right-3 h-px origin-left scale-x-0 transition-transform duration-200 ease-out" style="background-color: var(--color-accent);"></span>
          </button>
          <div class="dropdown-menu absolute left-0 top-full pt-1 hidden">
            <ul
              class="min-w-[180px] rounded-xl shadow-lg py-1.5"
              style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
            >
              <li>
                <a href="/mcp-servers/" class="dropdown-item flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors duration-150" style="color: var(--color-text-secondary);">
                  MCP Servers
                </a>
              </li>
              <li>
                <a href="/skills/" class="dropdown-item flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors duration-150" style="color: var(--color-text-secondary);">
                  AI Skills
                </a>
              </li>
            </ul>
          </div>
        </li>

        <!-- IDE dropdown -->
        <li class="dropdown-parent relative">
          <button
            class="nav-link dropdown-trigger relative flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors duration-150 cursor-default select-none"
            style="color: var(--color-muted);"
            tabindex="0"
            aria-haspopup="true"
          >
            IDE
            <svg class="chevron h-3.5 w-3.5 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
            <span class="nav-underline absolute bottom-0.5 left-3 right-3 h-px origin-left scale-x-0 transition-transform duration-200 ease-out" style="background-color: var(--color-accent);"></span>
          </button>
          <div class="dropdown-menu absolute left-0 top-full pt-1 hidden">
            <ul
              class="min-w-[200px] rounded-xl shadow-lg py-1.5"
              style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
            >
              <li>
                <a href="/extensions/" class="dropdown-item flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors duration-150" style="color: var(--color-text-secondary);">
                  VS Code Extensions
                </a>
              </li>
              <li>
                <a href="/plugins/" class="dropdown-item flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors duration-150" style="color: var(--color-text-secondary);">
                  JetBrains Plugins
                </a>
              </li>
            </ul>
          </div>
        </li>

        <!-- Compare (direct link) -->
        <li>
          <a
            href="/compare/"
            class="nav-link relative px-3 py-2 text-sm font-medium transition-colors duration-150"
            style="color: var(--color-muted);"
          >
            Compare
            <span class="nav-underline absolute bottom-0.5 left-3 right-3 h-px origin-left scale-x-0 transition-transform duration-200 ease-out" style="background-color: var(--color-accent);"></span>
          </a>
        </li>

        <!-- Trending (direct link) -->
        <li>
          <a
            href="/trending/"
            class="nav-link relative px-3 py-2 text-sm font-medium transition-colors duration-150"
            style="color: var(--color-muted);"
          >
            Trending
            <span class="nav-underline absolute bottom-0.5 left-3 right-3 h-px origin-left scale-x-0 transition-transform duration-200 ease-out" style="background-color: var(--color-accent);"></span>
          </a>
        </li>

        <!-- Add Tool button -->
        <li class="ml-3">
          <a
            href="https://github.com/heylabs-co/dev-tools-portal/issues/new?template=add-tool.yml"
            target="_blank"
            rel="noopener noreferrer"
            class="add-tool-btn inline-flex items-center gap-1.5 rounded-lg px-3.5 py-1.5 text-sm font-medium transition-all duration-200"
            style="border: 1px solid var(--color-accent); color: var(--color-accent);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add Tool
          </a>
        </li>
      </ul>

      <!-- Search + mobile toggle -->
      <div class="flex items-center gap-2">
        <a
          href="/search/"
          aria-label="Search"
          class="inline-flex h-8 w-8 items-center justify-center rounded-lg transition-colors duration-150"
          style="color: var(--color-muted);"
          onmouseenter="this.style.color='var(--color-text)';this.style.backgroundColor='var(--color-elevated)'"
          onmouseleave="this.style.color='var(--color-muted)';this.style.backgroundColor='transparent'"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
          </svg>
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="inline-flex h-8 w-8 items-center justify-center rounded-lg transition-colors duration-150 md:hidden"
          style="color: var(--color-muted);"
          aria-label="Toggle menu"
        >
          <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile slide-in menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-[57px] z-40 translate-x-full transition-transform duration-300 ease-out md:hidden"
  >
    <!-- Backdrop -->
    <div class="absolute inset-0 backdrop-blur-sm" style="background-color: rgba(0,0,0,0.3);" id="mobile-backdrop"></div>

    <!-- Panel -->
    <div
      class="absolute right-0 top-0 bottom-0 w-72 overflow-y-auto p-5"
      style="background-color: color-mix(in srgb, var(--color-surface) 95%, transparent); backdrop-filter: blur(20px); border-left: 1px solid var(--color-border);"
    >
      <ul class="flex flex-col gap-1">
        {mobileLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block rounded-lg px-3 py-2.5 text-sm font-medium transition-colors duration-150"
              style={`color: var(--color-text-secondary);`}
              onmouseenter="this.style.backgroundColor='var(--color-elevated)';this.style.color='var(--color-text)'"
              onmouseleave="this.style.backgroundColor='transparent';this.style.color='var(--color-text-secondary)'"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="mt-3 pt-3" style="border-top: 1px solid var(--color-border);">
          <a
            href="https://github.com/heylabs-co/dev-tools-portal/issues/new?template=add-tool.yml"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors duration-150"
            style={`color: var(--color-accent);`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add Tool
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<style>
  /* Direct nav links */
  .nav-link:hover {
    color: var(--color-text) !important;
  }
  .nav-link:hover .nav-underline {
    transform: scaleX(1);
  }

  /* Dropdown trigger: show underline and chevron rotation on parent hover */
  .dropdown-parent:hover .dropdown-trigger {
    color: var(--color-text) !important;
  }
  .dropdown-parent:hover .dropdown-trigger .nav-underline {
    transform: scaleX(1);
  }
  .dropdown-parent:hover .chevron {
    transform: rotate(180deg);
  }

  /* Show dropdown on parent hover — CSS only, no JS */
  .dropdown-parent:hover .dropdown-menu,
  .dropdown-parent:focus-within .dropdown-menu {
    display: block !important;
  }

  /* Dropdown item hover */
  .dropdown-item:hover {
    background-color: var(--color-elevated) !important;
    color: var(--color-text) !important;
  }

  /* Add Tool button */
  .add-tool-btn:hover {
    background-color: var(--color-accent) !important;
    color: #fff !important;
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-backdrop');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  function toggleMenu() {
    const isOpen = !menu?.classList.contains('translate-x-full');
    menu?.classList.toggle('translate-x-full', isOpen);
    menu?.classList.toggle('translate-x-0', !isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  }

  btn?.addEventListener('click', toggleMenu);
  backdrop?.addEventListener('click', toggleMenu);
</script>
