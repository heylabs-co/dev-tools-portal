---
interface Props {
  health: {
    bus_factor?: number;
    last_commit_days_ago?: number;
    release_frequency_days?: number;
    open_issues?: number;
    issue_close_days?: number;
    license?: string;
    stars?: number;
    forks?: number;
    health_score?: string;
    updated_at?: string;
  };
}

const { health } = Astro.props;

const grade = health.health_score ?? 'N/A';

const gradeColors: Record<string, { bg: string; text: string; border: string }> = {
  A: { bg: 'bg-emerald-50 dark:bg-emerald-950/30', text: 'text-emerald-600 dark:text-emerald-400', border: 'border-emerald-200 dark:border-emerald-800/60' },
  B: { bg: 'bg-blue-50 dark:bg-blue-950/30', text: 'text-blue-600 dark:text-blue-400', border: 'border-blue-200 dark:border-blue-800/60' },
  C: { bg: 'bg-yellow-50 dark:bg-yellow-950/30', text: 'text-yellow-600 dark:text-yellow-400', border: 'border-yellow-200 dark:border-yellow-800/60' },
  D: { bg: 'bg-orange-50 dark:bg-orange-950/30', text: 'text-orange-600 dark:text-orange-400', border: 'border-orange-200 dark:border-orange-800/60' },
  F: { bg: 'bg-red-50 dark:bg-red-950/30', text: 'text-red-600 dark:text-red-400', border: 'border-red-200 dark:border-red-800/60' },
};

const colors = gradeColors[grade] ?? gradeColors['C'];

const accentColors: Record<string, string> = {
  A: 'bg-emerald-500 dark:bg-emerald-400',
  B: 'bg-blue-500 dark:bg-blue-400',
  C: 'bg-yellow-500 dark:bg-yellow-400',
  D: 'bg-orange-500 dark:bg-orange-400',
  F: 'bg-red-500 dark:bg-red-400',
};

const accent = accentColors[grade] ?? accentColors['C'];

function formatDays(days: number | undefined): string {
  if (days === undefined) return 'N/A';
  if (days === 0) return 'today';
  if (days === 1) return '1 day';
  if (days < 30) return `${days} days`;
  if (days < 365) return `${Math.round(days / 30)} months`;
  return `${(days / 365).toFixed(1)} years`;
}

function formatNumber(n: number | undefined): string {
  if (n === undefined) return 'N/A';
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return n.toString();
}

const metrics = [
  {
    label: 'Bus Factor',
    value: health.bus_factor !== undefined ? health.bus_factor.toString() : 'N/A',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  },
  {
    label: 'Last Commit',
    value: formatDays(health.last_commit_days_ago),
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    label: 'Release Freq',
    value: health.release_frequency_days !== undefined ? `${health.release_frequency_days}d` : 'N/A',
    icon: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z',
  },
  {
    label: 'Open Issues',
    value: formatNumber(health.open_issues),
    icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    label: 'Issue Response',
    value: health.issue_close_days !== undefined ? `${health.issue_close_days}d` : 'N/A',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    label: 'License',
    value: health.license ?? 'None',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
];
---

<section class="mt-14">
  <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF] mb-5">
    <span class={`block w-1 h-6 rounded-full ${accent}`}></span>
    Project Health
  </h2>

  <div class="rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-6">
    <!-- Grade badge + stars/forks row -->
    <div class="flex items-center gap-5 mb-6">
      <div class={`flex items-center justify-center w-16 h-16 rounded-2xl border-2 ${colors.bg} ${colors.border}`}>
        <span class={`text-3xl font-black ${colors.text}`}>{grade}</span>
      </div>
      <div class="flex-1">
        <p class="text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF]">
          Health Score
        </p>
        <div class="mt-1 flex items-center gap-4 text-sm text-[#64748B] dark:text-[#8A8F98]">
          {health.stars !== undefined && (
            <span class="inline-flex items-center gap-1">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
              {formatNumber(health.stars)}
            </span>
          )}
          {health.forks !== undefined && (
            <span class="inline-flex items-center gap-1">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
              </svg>
              {formatNumber(health.forks)}
            </span>
          )}
        </div>
      </div>
    </div>

    <!-- Metrics grid -->
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
      {metrics.map((m) => (
        <div class="rounded-lg border border-gray-100 dark:border-gray-800/60 bg-[#FAFBFC] dark:bg-[#0D0D12] p-3.5">
          <div class="flex items-center gap-2 mb-1.5">
            <svg class="h-4 w-4 text-[#64748B] dark:text-[#8A8F98] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={m.icon} />
            </svg>
            <span class="text-xs font-medium text-[#64748B] dark:text-[#8A8F98] uppercase tracking-wider">{m.label}</span>
          </div>
          <p class="text-base font-semibold text-[#0F172A] dark:text-[#EDEDEF]" style="font-family: 'JetBrains Mono', monospace;">
            {m.value}
          </p>
        </div>
      ))}
    </div>

    {health.updated_at && (
      <p class="mt-4 text-xs text-[#94A3B8] dark:text-[#6B7280]">
        Last checked: {health.updated_at}
      </p>
    )}
  </div>
</section>
