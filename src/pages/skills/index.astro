---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allSkills = await getCollection('skills');
const sorted = allSkills.sort((a, b) => (b.data.stars ?? 0) - (a.data.stars ?? 0));

// Collect unique categories and formats for filters
const categories = [...new Set(sorted.map((s) => s.data.category).filter(Boolean))].sort() as string[];
const formats = [...new Set(sorted.map((s) => s.data.format).filter(Boolean))].sort() as string[];

const categoryLabels: Record<string, string> = {
  frontend: 'Frontend',
  backend: 'Backend',
  mobile: 'Mobile',
  devops: 'DevOps',
  'ai-ml': 'AI / ML',
  database: 'Database',
  testing: 'Testing',
  security: 'Security',
  api: 'API',
  design: 'Design',
  architecture: 'Architecture',
  documentation: 'Documentation',
  accessibility: 'Accessibility',
  performance: 'Performance',
  other: 'Other',
};

const formatLabels: Record<string, string> = {
  cursorrules: 'Cursor Rules',
  'claude-skill': 'Claude Skill',
  copilot: 'GitHub Copilot',
  windsurf: 'Windsurf',
  instructions: 'Instructions',
  prompt: 'Prompt',
  other: 'Other',
};

const formatColors: Record<string, string> = {
  cursorrules: 'bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 border-violet-200 dark:border-violet-800/40',
  'claude-skill': 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 border-orange-200 dark:border-orange-800/40',
  copilot: 'bg-sky-100 dark:bg-sky-900/30 text-sky-700 dark:text-sky-300 border-sky-200 dark:border-sky-800/40',
  windsurf: 'bg-teal-100 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 border-teal-200 dark:border-teal-800/40',
  instructions: 'bg-gray-100 dark:bg-gray-800/30 text-gray-700 dark:text-gray-300 border-gray-200 dark:border-gray-700/40',
  prompt: 'bg-pink-100 dark:bg-pink-900/30 text-pink-700 dark:text-pink-300 border-pink-200 dark:border-pink-800/40',
  other: 'bg-gray-100 dark:bg-gray-800/30 text-gray-600 dark:text-gray-400 border-gray-200 dark:border-gray-700/40',
};
---

<BaseLayout
  title="AI Skills — 524 Skills for Cursor, Claude Code & Copilot"
  description="Browse 524 AI coding skills and rules for Cursor, Claude Code, GitHub Copilot, and Windsurf. Filter by category and format to find the perfect rules for your AI assistant."
>
  <section class="mx-auto max-w-7xl px-4 py-10">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Skills' }]} />

    <!-- Hero -->
    <div class="mt-8 mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight" style="color: var(--color-text);">
        AI Coding Skills Directory
      </h1>
      <p class="mt-3 text-lg" style="color: var(--color-muted);">
        Find the perfect rules for your AI assistant — {sorted.length} skills for Cursor, Claude Code, GitHub Copilot & more
      </p>
    </div>

    <!-- Filters -->
    <div class="mb-8 flex flex-wrap gap-3" id="skill-filters">
      <!-- Category filter -->
      <select
        id="filter-category"
        class="rounded-lg border px-3 py-2 text-sm font-medium transition-colors"
        style="border-color: var(--color-border-strong); background-color: var(--color-surface); color: var(--color-text);"
      >
        <option value="">All Categories</option>
        {categories.map((cat) => (
          <option value={cat}>{categoryLabels[cat] || cat}</option>
        ))}
      </select>

      <!-- Format filter -->
      <select
        id="filter-format"
        class="rounded-lg border px-3 py-2 text-sm font-medium transition-colors"
        style="border-color: var(--color-border-strong); background-color: var(--color-surface); color: var(--color-text);"
      >
        <option value="">All Formats</option>
        {formats.map((fmt) => (
          <option value={fmt}>{formatLabels[fmt] || fmt}</option>
        ))}
      </select>

      <span id="filter-count" class="inline-flex items-center text-sm" style="color: var(--color-muted);">
        Showing {sorted.length} skills
      </span>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" id="skills-grid">
      {sorted.map((entry) => {
        const d = entry.data;
        const cat = d.category || '';
        const fmt = d.format || '';
        const fmtColor = formatColors[fmt] || formatColors.other;

        return (
          <a
            href={`/skills/${d.slug}/`}
            class="skill-card group flex flex-col rounded-xl border p-5 transition-all duration-200 hover:shadow-md"
            style="border-color: var(--color-border); background-color: var(--color-surface);"
            data-category={cat}
            data-format={fmt}
          >
            {/* Name */}
            <h2 class="text-base font-semibold group-hover:underline" style="color: var(--color-text);">
              {d.name}
            </h2>

            {/* Description */}
            {d.description && (
              <p class="mt-1.5 line-clamp-2 text-sm leading-relaxed" style="color: var(--color-muted);">
                {d.description}
              </p>
            )}

            {/* Badges row */}
            <div class="mt-auto pt-4 flex flex-wrap items-center gap-2">
              {/* Category badge */}
              {cat && (
                <span
                  class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium border"
                  style="background-color: color-mix(in srgb, var(--color-accent) 10%, transparent); color: var(--color-accent); border-color: color-mix(in srgb, var(--color-accent) 20%, transparent);"
                >
                  {categoryLabels[cat] || cat}
                </span>
              )}

              {/* Framework pill */}
              {d.framework && (
                <span
                  class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium border"
                  style="border-color: var(--color-border-strong); color: var(--color-text-secondary); background-color: var(--color-elevated);"
                >
                  {d.framework}
                </span>
              )}

              {/* Format badge */}
              {fmt && (
                <span class={`inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium ${fmtColor}`}>
                  {formatLabels[fmt] || fmt}
                </span>
              )}

              {/* Stars */}
              {d.stars != null && d.stars > 0 && (
                <span class="ml-auto inline-flex items-center gap-1 text-xs font-medium" style="color: var(--color-muted);">
                  <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                  {d.stars >= 1000 ? `${(d.stars / 1000).toFixed(1)}k` : d.stars}
                </span>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>

<script>
  const categorySelect = document.getElementById('filter-category') as HTMLSelectElement;
  const formatSelect = document.getElementById('filter-format') as HTMLSelectElement;
  const countSpan = document.getElementById('filter-count');
  const cards = document.querySelectorAll<HTMLElement>('.skill-card');

  function applyFilters() {
    const cat = categorySelect.value;
    const fmt = formatSelect.value;
    let visible = 0;

    cards.forEach((card) => {
      const matchCat = !cat || card.dataset.category === cat;
      const matchFmt = !fmt || card.dataset.format === fmt;
      const show = matchCat && matchFmt;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (countSpan) {
      countSpan.textContent = `Showing ${visible} skills`;
    }
  }

  categorySelect?.addEventListener('change', applyFilters);
  formatSelect?.addEventListener('change', applyFilters);
</script>
