---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const tools = [
  {
    name: 'search_tools',
    description: 'Search by keyword, category, free tier, or lock-in level',
    icon: '🔍',
  },
  {
    name: 'get_tool',
    description: 'Get full details: pricing, lock-in score, migration guide',
    icon: '📋',
  },
  {
    name: 'compare_tools',
    description: 'Side-by-side comparison of any two tools',
    icon: '⚖️',
  },
  {
    name: 'list_categories',
    description: 'Browse all 42 developer tool categories',
    icon: '📂',
  },
  {
    name: 'recommend_stack',
    description: 'Describe your project, get tool recommendations',
    icon: '🧩',
  },
];

const exampleQueries = [
  'Compare Stripe vs Adyen on pricing and lock-in',
  'What auth tools have a free tier and low vendor lock-in?',
  "I'm building a SaaS with payments, auth, and analytics — recommend a stack",
  'Show me the migration guide for leaving Firebase',
];

const claudeConfig = `{
  "mcpServers": {
    "devtools": {
      "command": "node",
      "args": ["<path-to>/mcp-server/build/index.js"]
    }
  }
}`;

const setupSteps = [
  { step: 'Clone the repo', code: 'git clone https://github.com/heylabs-co/dev-tools-portal.git' },
  { step: 'Build the MCP server', code: 'cd mcp-server && npm install && npm run build' },
  { step: 'Add the config above to your AI assistant', code: null },
  { step: 'Ask your first question', code: 'find me an auth solution with free tier and low lock-in' },
];
---

<BaseLayout
  title="MCP Server — Use DevTools Portal in Your AI Assistant"
  description="Connect 630+ developer tools data to Claude Code, Cursor, and any MCP-compatible AI assistant"
>
  <!-- Breadcrumbs -->
  <div class="mx-auto max-w-7xl px-4 pt-6">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'MCP Server' },
    ]} />
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white dark:from-gray-900 dark:to-gray-950 py-20 text-center">
    <div class="mx-auto max-w-3xl px-4">
      <span class="inline-block rounded-full bg-green-100 dark:bg-green-900 px-4 py-1 text-sm font-semibold text-green-800 dark:text-green-200 mb-6">
        Free &amp; Open Source
      </span>
      <h1 class="text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white">
        DevTools Portal MCP Server
      </h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        Search, compare, and get recommendations for 630+ developer tools — directly from your AI assistant
      </p>
    </div>
  </section>

  <!-- What is MCP -->
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">What is MCP?</h2>
    <div class="mt-4 space-y-4 text-gray-700 dark:text-gray-300 leading-relaxed">
      <p>
        <strong>MCP (Model Context Protocol)</strong> is an open standard by Anthropic for connecting
        AI assistants to external data sources. Think of it as a USB port for AI — any assistant that
        supports MCP can plug into any MCP server and access its data.
      </p>
      <p>
        Our MCP server gives your AI assistant direct access to the full DevTools.wiki database:
      </p>
      <ul class="list-disc space-y-2 pl-6">
        <li>Pricing data and free tier availability</li>
        <li>Lock-in scores and vendor dependency ratings</li>
        <li>Migration guides and switching difficulty</li>
        <li>Side-by-side tool comparisons</li>
        <li>Stack recommendations based on your project needs</li>
      </ul>
    </div>
  </section>

  <!-- 5 Available Tools -->
  <section class="bg-gray-50 dark:bg-gray-900 py-16">
    <div class="mx-auto max-w-7xl px-4">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white text-center">5 Available Tools</h2>
      <p class="mt-2 text-gray-600 dark:text-gray-400 text-center">
        Everything your AI assistant can do with the DevTools Portal
      </p>
      <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {tools.map((tool) => (
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-6 transition-shadow hover:shadow-md">
            <div class="text-3xl mb-3">{tool.icon}</div>
            <h3 class="font-mono text-sm font-bold text-indigo-600 dark:text-indigo-400">{tool.name}</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400 text-sm">{tool.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Installation -->
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Installation</h2>

    <div class="mt-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
        Claude Code config
        <span class="text-sm font-normal text-gray-500 dark:text-gray-400 ml-2">~/.claude/settings.json</span>
      </h3>
      <div class="mt-3 rounded-lg bg-gray-900 dark:bg-gray-800 p-4 overflow-x-auto">
        <pre class="text-sm text-gray-100 font-mono leading-relaxed"><code>{claudeConfig}</code></pre>
      </div>
    </div>

    <div class="mt-10">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Setup steps</h3>
      <ol class="mt-4 space-y-4">
        {setupSteps.map((item, i) => (
          <li class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-indigo-100 dark:bg-indigo-900 text-sm font-bold text-indigo-700 dark:text-indigo-300">
              {i + 1}
            </span>
            <div class="flex-1">
              <p class="font-medium text-gray-900 dark:text-white">{item.step}</p>
              {item.code && (
                <div class="mt-2 rounded-md bg-gray-100 dark:bg-gray-800 px-4 py-2">
                  <code class="text-sm text-gray-800 dark:text-gray-200 font-mono">{item.code}</code>
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Example Queries -->
  <section class="bg-gray-50 dark:bg-gray-900 py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Example Queries</h2>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        Try asking your AI assistant any of these
      </p>
      <div class="mt-6 space-y-3">
        {exampleQueries.map((query) => (
          <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-5 py-4">
            <p class="text-gray-800 dark:text-gray-200 font-mono text-sm">
              &ldquo;{query}&rdquo;
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center">
    <div class="mx-auto max-w-2xl px-4">
      <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white">
        Get started in 5 minutes
      </h2>
      <p class="mt-4 text-gray-600 dark:text-gray-400">
        Clone the repo, build the server, and connect it to your AI assistant.
      </p>
      <a
        href="https://github.com/heylabs-co/dev-tools-portal"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-block rounded-lg bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors"
      >
        View on GitHub
      </a>
    </div>
  </section>
</BaseLayout>
