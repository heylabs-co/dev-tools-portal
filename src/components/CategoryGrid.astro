---
interface Category {
  slug: string;
  name: string;
  company_count: number;
  ai_native: boolean;
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
---

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {categories.map((cat) => (
    <a
      href={`/categories/${cat.slug}/`}
      class="group rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 p-5 transition-shadow hover:shadow-lg"
    >
      <div class="flex items-center justify-between">
        <h3 class="text-base font-semibold text-gray-900 group-hover:text-indigo-600">
          {cat.name}
        </h3>
        {cat.ai_native && (
          <span class="inline-flex items-center rounded-full bg-purple-100 px-2 py-0.5 text-xs font-medium text-purple-800">
            AI
          </span>
        )}
      </div>
      <p class="mt-1 text-sm text-gray-500">
        {cat.company_count} {cat.company_count === 1 ? 'tool' : 'tools'}
      </p>
    </a>
  ))}
</div>
