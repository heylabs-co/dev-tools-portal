---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import sectionsData from '../../data/meta/sections.json';

type Section = {
  slug: string;
  name: string;
  icon: string;
  description: string;
  order: number;
  categories: string[];
};

type NewsItem = {
  id: string;
  source: string;
  source_handle: string | null;
  url: string | null;
  text: string | null;
  title: string | null;
  score: number | null;
  news_score: number | null;
  virality_score: number | null;
  approved_variant: string | null;
  drafts_json: string | null;
  like_count: number | null;
  reply_count: number | null;
  created_at: string;
  pushed_at: string | null;
};

const allCategories = await getCollection('categories');
const catBySlug = new Map(allCategories.map((c) => [c.data.slug, c.data]));
const sections = (sectionsData as Section[]).slice().sort((a, b) => a.order - b.order);

const sectionsView = sections.map((s) => {
  const total = s.categories
    .map((slug) => catBySlug.get(slug))
    .filter((c): c is NonNullable<typeof c> => c !== undefined)
    .reduce((sum, c) => sum + (c.company_count ?? 0), 0);
  return { ...s, totalCats: s.categories.length, total };
});

const allCompanies = await getCollection('companies');
const toolCount = allCompanies.length;
const catCount = allCategories.length;

// Fetch fresh news at build time so the homepage has real content for SEO.
// Client-side JS re-fetches on load to keep the feed current between builds.
const FEED_URL = 'https://toolnews-news.sssands.workers.dev/whats-new';
let initialNews: NewsItem[] = [];
try {
  const ctl = new AbortController();
  const t = setTimeout(() => ctl.abort(), 8000);
  const res = await fetch(FEED_URL, { signal: ctl.signal });
  clearTimeout(t);
  if (res.ok) {
    const data = (await res.json()) as { items?: NewsItem[] };
    initialNews = (data.items ?? []).slice(0, 12);
  } else {
    console.warn(`whats-new build fetch: HTTP ${res.status}`);
  }
} catch (e) {
  console.warn('whats-new build fetch failed — rendering empty shell:', e);
}

function pickBody(item: NewsItem): string {
  if (item.drafts_json) {
    try {
      const d = JSON.parse(item.drafts_json) as {
        quick_take?: string;
        drafts?: Record<string, string>;
      };
      const v = item.approved_variant;
      if (v && d.drafts && d.drafts[v]) return d.drafts[v]!;
      if (d.quick_take) return d.quick_take;
    } catch {
      // fall through
    }
  }
  return item.text ?? item.title ?? '';
}

function sourceLabel(src: string): string {
  return (
    {
      twitter: 'X',
      hackernews: 'HN',
      reddit: 'Reddit',
      github: 'GitHub',
      lobsters: 'Lobsters',
      producthunt: 'PH',
    }[src] ?? src
  );
}

function sourceDiscuss(src: string): string {
  return (
    {
      twitter: 'X',
      hackernews: 'Hacker News',
      reddit: 'Reddit',
      github: 'GitHub',
      lobsters: 'Lobsters',
      producthunt: 'Product Hunt',
    }[src] ?? src
  );
}

function discussLabel(item: NewsItem): string {
  const name = sourceDiscuss(item.source);
  const r = Number(item.reply_count);
  if (Number.isFinite(r) && r > 0) return `💬 ${r.toLocaleString()} on ${name} →`;
  return `Discuss on ${name} →`;
}

function relTime(iso: string | null): string {
  if (!iso) return '';
  const s = iso.includes('T') ? iso : iso.replace(' ', 'T') + 'Z';
  const d = new Date(s);
  if (Number.isNaN(d.getTime())) return '';
  const diff = Date.now() - d.getTime();
  const m = Math.round(diff / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.round(m / 60);
  if (h < 24) return `${h}h ago`;
  const days = Math.round(h / 24);
  if (days < 7) return `${days}d ago`;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<BaseLayout
  title={`tool.news — live dev-tool news + compare ${toolCount}+ tools`}
  description={`AI-curated news from Twitter, HN, Reddit, GitHub Trending, Lobsters, and Product Hunt. Plus ${toolCount}+ developer tools compared — pricing, lock-in scores, migration guides.`}
  jsonLd={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'WebSite',
        name: 'tool.news',
        url: 'https://tool.news',
        description: `AI-curated dev-tool news + ${toolCount}+ tools compared`,
        potentialAction: {
          '@type': 'SearchAction',
          target: 'https://tool.news/search/?q={search_term_string}',
          'query-input': 'required name=search_term_string',
        },
      },
      {
        '@type': 'Organization',
        name: 'HeyLabs',
        url: 'https://heylabs.co',
        logo: 'https://tool.news/favicon.svg',
        sameAs: ['https://github.com/heylabs-co', 'https://x.com/toolnewsHQ'],
      },
    ],
  }}
>
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 bg-[#FAFBFC] dark:bg-[#0A0A0F]"></div>
    <div
      class="absolute inset-0 opacity-[0.4] dark:opacity-[0.15]"
      style="background-image: radial-gradient(circle at 1px 1px, #5E6AD2 1px, transparent 0); background-size: 32px 32px;"
    ></div>
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full opacity-20 dark:opacity-10 blur-3xl"
      style="background: radial-gradient(ellipse, #818CF8 0%, #5E6AD2 40%, transparent 70%);"
    ></div>

    <div class="relative mx-auto max-w-3xl px-6 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-[#0F172A] dark:text-[#EDEDEF] leading-[1.1]">
        The Developer Tool<br />Intelligence Platform
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-[#64748B] dark:text-[#8A8F98] max-w-2xl mx-auto leading-relaxed">
        Live news + {toolCount}+ tools compared — pricing, lock-in scores, migration guides.
        Make informed decisions, faster.
      </p>

      <div class="mt-10 flex items-center justify-center gap-3 flex-wrap">
        <a
          href="#news"
          class="inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-[#5E6AD2] to-[#818CF8] px-6 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-90 transition-opacity"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" />
          </svg>
          Read Dev News
        </a>
        <a
          href="/recommend/"
          class="inline-flex items-center rounded-lg border border-[#5E6AD2]/30 dark:border-[#818CF8]/30 px-6 py-3 text-sm font-semibold text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/5 dark:hover:bg-[#818CF8]/5 transition-colors"
        >
          AI Tool Finder
        </a>
        <a
          href="/tools/"
          class="inline-flex items-center rounded-lg border border-[#5E6AD2]/30 dark:border-[#818CF8]/30 px-6 py-3 text-sm font-semibold text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/5 dark:hover:bg-[#818CF8]/5 transition-colors"
        >
          Browse Tools
        </a>
        <a
          href="/compare/"
          class="inline-flex items-center rounded-lg border border-[#5E6AD2]/30 dark:border-[#818CF8]/30 px-6 py-3 text-sm font-semibold text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/5 dark:hover:bg-[#818CF8]/5 transition-colors"
        >
          Compare
        </a>
      </div>

    </div>
  </section>

  <!-- ── NEWS ─────────────────────────────────────────────────────────── -->
  <section id="news" class="mx-auto max-w-5xl px-6 py-16 scroll-mt-16">
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div class="max-w-2xl">
        <div class="flex items-center gap-2">
          <span class="inline-flex h-2 w-2 animate-pulse rounded-full bg-green-500"></span>
          <span class="text-xs font-semibold uppercase tracking-wider text-[#64748B] dark:text-[#8A8F98]">Live</span>
        </div>
        <h2 class="mt-2 text-3xl font-bold text-[#0F172A] dark:text-[#EDEDEF]">Dev News</h2>
        <p class="mt-2 text-[#64748B] dark:text-[#8A8F98]">
          AI-curated from Twitter, HN, Reddit, GitHub Trending, Lobsters, and Product Hunt.
          Scored on newsworthiness + virality, human-reviewed before it lands here.
        </p>
      </div>

      <div class="flex flex-wrap gap-2 text-xs">
        <a
          href="https://t.me/toolnewshq"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 rounded-full bg-[#2AABEE]/10 px-3 py-1.5 font-medium text-[#2AABEE] hover:bg-[#2AABEE]/20"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/></svg>
          Subscribe on TG
        </a>
        <a
          href="https://x.com/toolnewsHQ"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 rounded-full bg-black/90 px-3 py-1.5 font-medium text-white hover:bg-black dark:bg-white/10 dark:text-white dark:hover:bg-white/20"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          @toolnewsHQ
        </a>
        <a
          href="/news/"
          class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-3 py-1.5 font-medium text-gray-700 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          See all Dev News →
        </a>
      </div>
    </div>

    <!-- News list — hydrated at build, refreshed client-side -->
    <ol id="home-news" class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2">
      {initialNews.length === 0 && (
        <li class="col-span-full rounded-lg border border-dashed border-gray-200 bg-white p-8 text-center text-sm text-gray-500 dark:border-gray-800 dark:bg-gray-900 dark:text-gray-400">
          Feed warming up. Check back in a few minutes — or
          <a href="https://t.me/toolnewshq" target="_blank" rel="noopener" class="underline underline-offset-2">subscribe on Telegram</a>.
        </li>
      )}
      {initialNews.map((item) => {
        const body = pickBody(item);
        const handle = item.source_handle ? `@${item.source_handle}` : '';
        const time = relTime(item.pushed_at ?? item.created_at);
        const href = item.url ?? '/news/';
        const hasUrl = item.url && /^https?:\/\//i.test(item.url);
        return (
          <li class="rounded-lg border border-gray-200 bg-white p-4 transition hover:border-[#5E6AD2]/50 hover:shadow-md dark:border-gray-800 dark:bg-gray-900 dark:hover:border-[#818CF8]/50">
            <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
              <span class="inline-flex items-center rounded bg-gray-900 px-1.5 py-0.5 text-[10px] font-bold text-white dark:bg-gray-100 dark:text-gray-900">{sourceLabel(item.source)}</span>
              {handle && <span class="truncate text-gray-700 dark:text-gray-300">{handle}</span>}
              <span class="ml-auto">{time}</span>
            </div>
            <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-[#0F172A] dark:text-[#EDEDEF]">{body}</p>
            {hasUrl && (
              <a
                href={href}
                target="_blank"
                rel="noopener"
                class="mt-2 inline-block text-xs font-medium text-[#5E6AD2] hover:underline dark:text-[#818CF8]"
              >{discussLabel(item)}</a>
            )}
          </li>
        );
      })}
    </ol>
  </section>

  <!-- ── CATALOG (compact) ────────────────────────────────────────────── -->
  <section class="mx-auto max-w-5xl px-6 py-16 border-t border-gray-100 dark:border-gray-900">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-bold text-[#0F172A] dark:text-[#EDEDEF]">Or browse the catalog</h2>
      <p class="mt-2 text-[#64748B] dark:text-[#8A8F98]">
        {toolCount}+ tools across {catCount} categories. Pricing, lock-in scores, migration guides.
      </p>
    </div>

    <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
      {sectionsView.map((sec) => (
        <a
          href={`/sections/${sec.slug}/`}
          class="group flex items-start gap-3 rounded-lg border border-gray-200 p-3 transition hover:-translate-y-0.5 hover:border-[#5E6AD2]/50 hover:shadow-sm dark:border-gray-800 dark:hover:border-[#818CF8]/50"
        >
          <span class="text-2xl leading-none">{sec.icon}</span>
          <div class="min-w-0 flex-1">
            <div class="truncate text-sm font-semibold text-[#0F172A] dark:text-[#EDEDEF] group-hover:text-[#5E6AD2] dark:group-hover:text-[#818CF8]">
              {sec.name}
            </div>
            <div class="text-[11px] text-gray-500 dark:text-gray-400">
              {sec.total.toLocaleString()} tools
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-6 flex items-center gap-3 text-sm">
      <a
        href="/categories/"
        class="font-medium text-[#5E6AD2] dark:text-[#818CF8] hover:opacity-80"
      >
        All {catCount} categories →
      </a>
      <span class="text-gray-300 dark:text-gray-700">·</span>
      <a
        href="/compare/"
        class="font-medium text-[#5E6AD2] dark:text-[#818CF8] hover:opacity-80"
      >
        Popular comparisons →
      </a>
      <span class="text-gray-300 dark:text-gray-700">·</span>
      <a
        href="/recommend/"
        class="font-medium text-[#5E6AD2] dark:text-[#818CF8] hover:opacity-80"
      >
        AI tool finder →
      </a>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ FEED_URL }}>
  (function () {
    const listEl = document.getElementById('home-news');
    if (!listEl) return;

    function esc(s) {
      return String(s ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function relTime(iso) {
      if (!iso) return '';
      const s = iso.includes('T') ? iso : iso.replace(' ', 'T') + 'Z';
      const d = new Date(s);
      if (Number.isNaN(d.getTime())) return '';
      const diff = Date.now() - d.getTime();
      const m = Math.round(diff / 60000);
      if (m < 1) return 'just now';
      if (m < 60) return m + 'm ago';
      const h = Math.round(m / 60);
      if (h < 24) return h + 'h ago';
      const days = Math.round(h / 24);
      if (days < 7) return days + 'd ago';
      return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    function sourceLabel(src) {
      return (
        { twitter: 'X', hackernews: 'HN', reddit: 'Reddit', github: 'GitHub', lobsters: 'Lobsters', producthunt: 'PH' }[src] ||
        src ||
        '?'
      );
    }

    function sourceDiscuss(src) {
      return (
        { twitter: 'X', hackernews: 'Hacker News', reddit: 'Reddit', github: 'GitHub', lobsters: 'Lobsters', producthunt: 'Product Hunt' }[src] ||
        src ||
        'source'
      );
    }

    function discussLabel(item) {
      const name = sourceDiscuss(item.source);
      const r = Number(item.reply_count);
      if (Number.isFinite(r) && r > 0) return '💬 ' + r.toLocaleString() + ' on ' + name + ' →';
      return 'Discuss on ' + name + ' →';
    }

    function pickBody(item) {
      if (item.drafts_json) {
        try {
          const d = JSON.parse(item.drafts_json);
          const v = item.approved_variant;
          if (v && d.drafts && d.drafts[v]) return d.drafts[v];
          if (d.quick_take) return d.quick_take;
        } catch (_) {}
      }
      return item.text || item.title || '';
    }

    function render(items) {
      if (!items.length) return;
      listEl.innerHTML = items
        .slice(0, 12)
        .map(function (item) {
          const body = pickBody(item);
          const handle = item.source_handle ? '@' + item.source_handle : '';
          const time = relTime(item.pushed_at || item.created_at);
          const url = item.url || '';
          const hasUrl = url && /^https?:\/\//i.test(url);
          return (
            '<li class="rounded-lg border border-gray-200 bg-white p-4 transition hover:border-[#5E6AD2]/50 hover:shadow-md dark:border-gray-800 dark:bg-gray-900 dark:hover:border-[#818CF8]/50">' +
            '<div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">' +
            '<span class="inline-flex items-center rounded bg-gray-900 px-1.5 py-0.5 text-[10px] font-bold text-white dark:bg-gray-100 dark:text-gray-900">' + esc(sourceLabel(item.source)) + '</span>' +
            (handle ? '<span class="truncate text-gray-700 dark:text-gray-300">' + esc(handle) + '</span>' : '') +
            '<span class="ml-auto">' + esc(time) + '</span>' +
            '</div>' +
            '<p class="mt-2 line-clamp-3 text-sm leading-relaxed text-[#0F172A] dark:text-[#EDEDEF]">' + esc(body) + '</p>' +
            (hasUrl ?
              '<a href="' + esc(url) + '" target="_blank" rel="noopener" class="mt-2 inline-block text-xs font-medium text-[#5E6AD2] hover:underline dark:text-[#818CF8]">' + esc(discussLabel(item)) + '</a>' :
              '') +
            '</li>'
          );
        })
        .join('');
    }

    fetch(FEED_URL, { cache: 'no-store' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) { if (data && Array.isArray(data.items)) render(data.items); })
      .catch(function (e) { console.warn('home whats-new refresh failed:', e); });
  })();
</script>
