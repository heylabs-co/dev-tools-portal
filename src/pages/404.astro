---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';

const [companies, mcpServers, skills, extensions, plugins] = await Promise.all([
  getCollection('companies'),
  getCollection('mcpServers'),
  getCollection('skills'),
  getCollection('extensions'),
  getCollection('jetbrainsPlugins'),
]);
const totalEntries =
  companies.length + mcpServers.length + skills.length + extensions.length + plugins.length;
const totalEntriesFormatted = `${totalEntries.toLocaleString()}+`;

const popularCategories = [
  { slug: 'payment-gateway', name: 'Payment Gateways' },
  { slug: 'identity-auth', name: 'Identity & Auth' },
  { slug: 'dbaas', name: 'Databases' },
  { slug: 'ai-api-sdk', name: 'AI API & SDK' },
  { slug: 'observability', name: 'Observability' },
];
---

<BaseLayout
  title="Page not found"
  description={`The page you were looking for doesn't exist on tool.news. Search our catalog of ${totalEntriesFormatted} developer tools or explore popular categories.`}
  noindex={true}
>
  <section class="relative overflow-hidden">
    <!-- Background: subtle radial gradient + dot grid, matching homepage -->
    <div class="absolute inset-0 bg-[#FAFBFC] dark:bg-[#0A0A0F]"></div>
    <div
      class="absolute inset-0 opacity-[0.35] dark:opacity-[0.12]"
      style="background-image: radial-gradient(circle at 1px 1px, #5E6AD2 1px, transparent 0); background-size: 32px 32px;"
    ></div>

    <div class="relative mx-auto max-w-3xl px-6 py-20 sm:py-28">
      <div class="text-center">
        <p
          class="text-sm font-semibold uppercase tracking-[0.2em] text-[#5E6AD2] dark:text-[#818CF8]"
          style="font-family: 'JetBrains Mono', monospace;"
        >
          Error 404
        </p>
        <h1
          class="mt-4 text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-[#0F172A] dark:text-[#EDEDEF] leading-[1.05]"
        >
          Page not found
        </h1>
        <p class="mt-6 text-lg text-[#64748B] dark:text-[#8A8F98] max-w-xl mx-auto leading-relaxed">
          The URL you followed doesn't exist on tool.news. The tool may have been renamed,
          or there might be a typo in the link. Try searching for what you need.
        </p>
      </div>

      <!-- Search widget -->
      <div class="mt-12">
        <SearchBar showFilters={false} placeholder={`Search ${totalEntriesFormatted} developer tools…`} />
      </div>

      <!-- Popular category hubs -->
      <div class="mt-14">
        <h2
          class="text-xs font-semibold uppercase tracking-[0.15em] text-[#64748B] dark:text-[#8A8F98] text-center"
        >
          Or browse a popular category
        </h2>
        <div class="mt-5 flex flex-wrap items-center justify-center gap-2.5">
          {popularCategories.map((cat) => (
            <a
              href={`/categories/${cat.slug}/`}
              class="inline-flex items-center rounded-full border border-[#5E6AD2]/30 dark:border-[#818CF8]/30 bg-white/60 dark:bg-white/5 px-4 py-2 text-sm font-medium text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/5 dark:hover:bg-[#818CF8]/10 transition-colors"
            >
              {cat.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Back home -->
      <div class="mt-12 text-center">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-[#5E6AD2] to-[#818CF8] px-6 py-3 text-sm font-semibold text-white shadow-sm hover:opacity-90 transition-opacity"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to homepage
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
