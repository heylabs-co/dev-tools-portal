---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return skills.map((entry) => ({
    params: { slug: entry.id },
    props: { skill: entry },
  }));
}

const { skill } = Astro.props;
const d = skill.data;

const categoryLabels: Record<string, string> = {
  frontend: 'Frontend',
  backend: 'Backend',
  mobile: 'Mobile',
  devops: 'DevOps',
  'ai-ml': 'AI / ML',
  database: 'Database',
  testing: 'Testing',
  security: 'Security',
  api: 'API',
  design: 'Design',
  architecture: 'Architecture',
  documentation: 'Documentation',
  accessibility: 'Accessibility',
  performance: 'Performance',
  other: 'Other',
};

const formatLabels: Record<string, string> = {
  cursorrules: 'Cursor Rules',
  'claude-skill': 'Claude Skill',
  copilot: 'GitHub Copilot',
  windsurf: 'Windsurf',
  instructions: 'Instructions',
  prompt: 'Prompt',
  other: 'Other',
};

const formatColors: Record<string, string> = {
  cursorrules: 'bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 border-violet-200 dark:border-violet-800/40',
  'claude-skill': 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 border-orange-200 dark:border-orange-800/40',
  copilot: 'bg-sky-100 dark:bg-sky-900/30 text-sky-700 dark:text-sky-300 border-sky-200 dark:border-sky-800/40',
  windsurf: 'bg-teal-100 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 border-teal-200 dark:border-teal-800/40',
  instructions: 'bg-gray-100 dark:bg-gray-800/30 text-gray-700 dark:text-gray-300 border-gray-200 dark:border-gray-700/40',
  prompt: 'bg-pink-100 dark:bg-pink-900/30 text-pink-700 dark:text-pink-300 border-pink-200 dark:border-pink-800/40',
  other: 'bg-gray-100 dark:bg-gray-800/30 text-gray-600 dark:text-gray-400 border-gray-200 dark:border-gray-700/40',
};

const fmt = d.format || '';
const cat = d.category || '';
const fmtLabel = formatLabels[fmt] || fmt;
const catLabel = categoryLabels[cat] || cat;
const fmtColor = formatColors[fmt] || formatColors.other;

const pageTitle = `${d.name} — ${fmtLabel || 'AI Skill'} for ${catLabel || 'Development'}`;
const pageDescription = d.description || `${d.name} is a ${fmtLabel || 'coding skill'} for ${catLabel || 'development'}.`;

// Install instructions per format
const installInstructions: Record<string, { title: string; steps: string[] }> = {
  cursorrules: {
    title: 'How to install in Cursor',
    steps: [
      'Download or copy the rules file from the source repository.',
      'Add it to your project root as <code>.cursorrules</code>.',
      'Restart Cursor — the rules will be active for all AI interactions in this project.',
    ],
  },
  'claude-skill': {
    title: 'How to install for Claude Code',
    steps: [
      'Download the skill file from the source repository.',
      'Place it in the <code>~/.claude/skills/</code> directory.',
      'Claude Code will automatically pick up the skill in your next session.',
    ],
  },
  copilot: {
    title: 'How to install for GitHub Copilot',
    steps: [
      'Copy the instructions from the source repository.',
      'Add them to your GitHub Copilot instructions file in your repo or IDE settings.',
      'Copilot will follow these instructions in all suggestions.',
    ],
  },
  windsurf: {
    title: 'How to install in Windsurf',
    steps: [
      'Download the rules file from the source repository.',
      'Add it to your Windsurf project configuration.',
      'The rules will guide Windsurf AI in your project.',
    ],
  },
};

const install = installInstructions[fmt];

// Schema.org
const siteUrl = 'https://tool.news';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: d.name,
  description: pageDescription,
  url: `${siteUrl}/skills/${d.slug}/`,
  codeRepository: d.source_url || undefined,
  author: d.author ? { '@type': 'Person', name: d.author } : undefined,
  programmingLanguage: d.framework || undefined,
  applicationCategory: catLabel || 'Development',
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article class="mx-auto max-w-4xl px-6 py-12">
    <!-- Breadcrumbs -->
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Skills', href: '/skills/' },
        { label: d.name },
      ]}
    />

    <!-- Hero -->
    <header class="mt-10">
      <h1 class="text-3xl font-bold tracking-tight" style="color: var(--color-text);">
        {d.name}
      </h1>
      {d.description && (
        <p class="mt-3 text-base leading-relaxed" style="color: var(--color-muted);">
          {d.description}
        </p>
      )}

      <!-- Badges -->
      <div class="mt-5 flex flex-wrap items-center gap-2">
        {cat && (
          <span
            class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold border"
            style="background-color: color-mix(in srgb, var(--color-accent) 10%, transparent); color: var(--color-accent); border-color: color-mix(in srgb, var(--color-accent) 20%, transparent);"
          >
            {catLabel}
          </span>
        )}
        {d.framework && (
          <span
            class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border"
            style="border-color: var(--color-border-strong); color: var(--color-text-secondary); background-color: var(--color-elevated);"
          >
            {d.framework}
          </span>
        )}
        {fmt && (
          <span class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium ${fmtColor}`}>
            {fmtLabel}
          </span>
        )}
        {d.stars != null && d.stars > 0 && (
          <span class="inline-flex items-center gap-1 text-sm font-medium" style="color: var(--color-muted);">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            {d.stars >= 1000 ? `${(d.stars / 1000).toFixed(1)}k` : d.stars}
          </span>
        )}
      </div>
    </header>

    <!-- Details -->
    <section class="mt-10">
      <h2 class="flex items-center gap-3 text-lg font-semibold" style="color: var(--color-text);">
        <span class="block w-1 h-6 rounded-full" style="background-color: var(--color-accent);"></span>
        Details
      </h2>
      <div class="mt-5 rounded-xl border p-6 space-y-4" style="border-color: var(--color-border); background-color: var(--color-surface);">
        {d.author && (
          <div class="text-sm">
            <span class="font-medium" style="color: var(--color-text);">Author:</span>
            <span class="ml-2" style="color: var(--color-muted);">{d.author}</span>
          </div>
        )}
        {cat && (
          <div class="text-sm">
            <span class="font-medium" style="color: var(--color-text);">Category:</span>
            <span class="ml-2" style="color: var(--color-muted);">{catLabel}</span>
          </div>
        )}
        {d.framework && (
          <div class="text-sm">
            <span class="font-medium" style="color: var(--color-text);">Framework:</span>
            <span class="ml-2" style="color: var(--color-muted);">{d.framework}</span>
          </div>
        )}
        {fmt && (
          <div class="text-sm">
            <span class="font-medium" style="color: var(--color-text);">Format:</span>
            <span class="ml-2" style="color: var(--color-muted);">{fmtLabel}</span>
          </div>
        )}
        {d.source_url && (
          <div class="text-sm">
            <span class="font-medium" style="color: var(--color-text);">Source:</span>
            <a
              href={d.source_url}
              target="_blank"
              rel="noopener noreferrer"
              class="ml-2 inline-flex items-center gap-1 hover:underline"
              style="color: var(--color-accent);"
            >
              View on GitHub
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        )}
      </div>
    </section>

    <!-- How to Install -->
    {install && (
      <section class="mt-10">
        <h2 class="flex items-center gap-3 text-lg font-semibold" style="color: var(--color-text);">
          <span class="block w-1 h-6 rounded-full bg-emerald-500 dark:bg-emerald-400"></span>
          {install.title}
        </h2>
        <div class="mt-5 rounded-xl border p-6" style="border-color: var(--color-border); background-color: var(--color-surface);">
          <ol class="list-decimal list-inside space-y-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            {install.steps.map((step) => (
              <li set:html={step} />
            ))}
          </ol>
          {d.source_url && (
            <a
              href={d.source_url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
              style="background-color: var(--color-accent);"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              Get from source
            </a>
          )}
        </div>
      </section>
    )}

    {/* Fallback install for formats without specific instructions */}
    {!install && d.source_url && (
      <section class="mt-10">
        <h2 class="flex items-center gap-3 text-lg font-semibold" style="color: var(--color-text);">
          <span class="block w-1 h-6 rounded-full bg-emerald-500 dark:bg-emerald-400"></span>
          How to Use
        </h2>
        <div class="mt-5 rounded-xl border p-6" style="border-color: var(--color-border); background-color: var(--color-surface);">
          <p class="text-sm" style="color: var(--color-text-secondary);">
            Visit the source repository for setup instructions specific to this skill format.
          </p>
          <a
            href={d.source_url}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
            style="background-color: var(--color-accent);"
          >
            View source
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </section>
    )}

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </article>
</BaseLayout>
