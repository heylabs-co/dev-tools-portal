---
// Pagefind search integration component.
// Pagefind assets are generated at /pagefind/ after build.
---

<div class="w-full max-w-2xl mx-auto">
  <div
    id="search"
    class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 shadow-sm overflow-hidden"
  >
  </div>
</div>

<script is:inline>
  (function() {
    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = '/pagefind/pagefind-ui.css';
    document.head.appendChild(link);

    var script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.onload = function() {
      new window.PagefindUI({ element: '#search', showSubResults: true });
    };
    document.head.appendChild(script);
  })();
</script>

<style is:global>
  .pagefind-ui__search-input {
    border-radius: 0.375rem;
    border-color: #d1d5db;
    background: white;
    color: #111827;
    font-size: 0.875rem;
  }
  .pagefind-ui__result-link {
    color: #2563eb;
  }
  .pagefind-ui__result-link:hover {
    text-decoration: underline;
  }
  .pagefind-ui__result-excerpt {
    color: #4b5563;
    font-size: 0.875rem;
  }
</style>
