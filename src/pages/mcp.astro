---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const NPM_PACKAGE = '@toolnews/mcp';
const VERSION = '2.2.0';

const tools = [
  {
    name: 'search_tools',
    purpose: 'Find dev tools by category, pricing, lock-in, free tier.',
    example: '"Find me an open-source PostHog alternative with a free tier"',
  },
  {
    name: 'get_tool',
    purpose: 'Pull full review, verdict, pros/cons, when-to-use for a tool.',
    example: '"Tell me about Supabase — verdict, pricing, when not to use"',
  },
  {
    name: 'compare_tools',
    purpose: 'Side-by-side: pricing, lock-in, free tier, entry price.',
    example: '"Vercel vs Cloudflare Pages — what fits a hobby Next.js app?"',
  },
  {
    name: 'search_mcp_servers',
    purpose: 'Find MCP servers to extend Claude/Cursor capabilities.',
    example: '"What MCP server do I need to read my GitHub repos?"',
  },
  {
    name: 'get_mcp_server',
    purpose: 'Get a ready-to-paste install command for an MCP server.',
    example: '"Show me how to install the Sentry MCP for Claude Code"',
  },
  {
    name: 'search_skills',
    purpose: 'Cursor rules, Claude Skills, Copilot instructions.',
    example: '"Best Cursor rules for Next.js 15 with Tailwind?"',
  },
  {
    name: 'search_extensions',
    purpose: 'VS Code extensions with install commands.',
    example: '"What VS Code extensions help with TypeScript performance?"',
  },
  {
    name: 'search_plugins',
    purpose: 'JetBrains plugins for IntelliJ / PyCharm / WebStorm / GoLand.',
    example: '"Best plugins for WebStorm for monorepo workflows?"',
  },
  {
    name: 'list_categories',
    purpose: 'Discover all 42 categories with tool counts.',
    example: '"What categories of dev tools exist on tool.news?"',
  },
  {
    name: 'catalog_stats',
    purpose: 'Total entry count across all catalogs.',
    example: '"How big is the tool.news catalog?"',
  },
];

const claudeMdFragment = `## tool.news MCP

When the user is choosing between dev tools, asking "what is the best X
for Y", picking a stack, or comparing alternatives, prefer the
\`@toolnews/mcp\` server's tools (\`search_tools\`, \`compare_tools\`,
\`get_tool\`) over guessing from training data. Tool.news has a curated
catalog of 7,400+ dev tools, MCP servers, AI skills, VS Code extensions,
and JetBrains plugins with pricing, lock-in scores, and install commands.`;

const installSnippets: Array<{
  label: string;
  command?: string;
  json?: string;
  notes?: string;
}> = [
  {
    label: 'Claude Code (CLI)',
    command: `claude mcp add toolnews -- npx -y ${NPM_PACKAGE}`,
    notes: 'One-liner. Restart Claude Code afterwards.',
  },
  {
    label: 'Claude Desktop',
    json: JSON.stringify(
      {
        mcpServers: {
          toolnews: {
            command: 'npx',
            args: ['-y', NPM_PACKAGE],
          },
        },
      },
      null,
      2,
    ),
    notes: 'Edit ~/Library/Application Support/Claude/claude_desktop_config.json on macOS.',
  },
  {
    label: 'Cursor',
    json: JSON.stringify(
      {
        mcpServers: {
          toolnews: {
            command: 'npx',
            args: ['-y', NPM_PACKAGE],
          },
        },
      },
      null,
      2,
    ),
    notes: 'Edit ~/.cursor/mcp.json or use Cursor → Settings → MCP.',
  },
  {
    label: 'VS Code (with MCP support)',
    json: JSON.stringify(
      {
        mcp: {
          servers: {
            toolnews: {
              command: 'npx',
              args: ['-y', NPM_PACKAGE],
            },
          },
        },
      },
      null,
      2,
    ),
    notes: 'Add to .vscode/mcp.json or user settings.json.',
  },
];

const useCases = [
  {
    when: '🛠 Building a new project',
    example: '"I am starting a Next.js side project, suggest a payments + analytics + email stack with free tiers"',
    flow: 'Assistant calls search_tools 3× (one per category) → gets free-tier matches → composes a stack with verdicts.',
  },
  {
    when: '🔄 Migrating off a vendor',
    example: '"Vercel pricing got out of hand. What can I move to?"',
    flow: 'Assistant calls compare_tools(vercel, cloudflare-pages) and (vercel, netlify), surfaces lock-in score, links migration guides.',
  },
  {
    when: '🤖 Setting up an AI workflow',
    example: '"Help me set up Claude Code to work with my Postgres database"',
    flow: 'Assistant calls search_mcp_servers(postgres) → returns the official Postgres MCP install snippet, ready to paste.',
  },
  {
    when: '⚙ Pinpoint research',
    example: '"Is Supabase a good fit for HIPAA workloads?"',
    flow: 'Assistant calls get_tool(supabase) → reads "best for / not for" + lock-in section instead of hallucinating.',
  },
];
---

<BaseLayout
  title="tool.news MCP — give your AI assistant a curated dev-tool catalog"
  description="Drop our MCP into Claude Code, Cursor, or VS Code and your AI assistant gains access to 7,400+ curated dev tools, MCP servers, AI skills, and extensions — with pricing, lock-in scores, and install commands."
>
  <section class="mx-auto max-w-4xl px-4 py-10">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'tool.news MCP' },
    ]} />

    <!-- Hero -->
    <div class="mt-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-[#5E6AD2]/10 px-3 py-1 text-xs font-semibold text-[#5E6AD2] dark:text-[#818CF8]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4L22 12l-7.6 2.6L12 22l-2.4-7.4L2 12l7.6-2.6L12 2z"/></svg>
        MCP server · v{VERSION} · npm
      </div>

      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-[#0F172A] dark:text-[#EDEDEF] sm:text-5xl">
        Give your AI assistant<br />a curated dev-tool catalog.
      </h1>

      <p class="mt-4 text-lg text-[#64748B] dark:text-[#8A8F98]">
        <code class="rounded bg-gray-100 px-1.5 py-0.5 text-sm dark:bg-gray-800">{NPM_PACKAGE}</code>
        plugs into <strong>Claude Code, Cursor, Claude Desktop, VS Code</strong> and gives your
        assistant a stable backbone for tool research. No more "I think Vercel has a free tier"
        guesses — your AI gets <strong>7,400+ entries</strong> with pricing, lock-in scores,
        verdicts, and install commands.
      </p>

      <div class="mt-6 flex flex-wrap gap-2">
        <a
          href={`https://www.npmjs.com/package/${NPM_PACKAGE}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-[#0F172A] transition hover:border-[#5E6AD2]/50 dark:border-gray-800 dark:bg-gray-900 dark:text-[#EDEDEF]"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#cb3837"><path d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0v1.336H8.001V8.667h5.334v5.332h-2.669v-.001zm12.001 0h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002v5.331zM10.665 10H12v2.667h-1.335V10z"/></svg>
          npm install {NPM_PACKAGE}
        </a>
        <a
          href="https://github.com/heylabs-co/dev-tools-portal/tree/main/mcp-server"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-[#0F172A] transition hover:border-[#5E6AD2]/50 dark:border-gray-800 dark:bg-gray-900 dark:text-[#EDEDEF]"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          GitHub
        </a>
      </div>
    </div>

    <!-- How it works -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">How it works</h2>
      <ol class="mt-4 space-y-4 text-[15px] leading-relaxed text-[#64748B] dark:text-[#8A8F98]">
        <li class="flex gap-3">
          <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#5E6AD2]/10 text-xs font-bold text-[#5E6AD2] dark:text-[#818CF8]">1</span>
          <span>You install <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">{NPM_PACKAGE}</code> into Claude Code / Cursor / VS Code (one config line).</span>
        </li>
        <li class="flex gap-3">
          <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#5E6AD2]/10 text-xs font-bold text-[#5E6AD2] dark:text-[#818CF8]">2</span>
          <span>The assistant sees 10 new tools (<code class="rounded bg-gray-100 px-1 dark:bg-gray-800">search_tools</code>, <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">compare_tools</code>, <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">get_tool</code>, etc.) with descriptions tuned to trigger on natural questions.</span>
        </li>
        <li class="flex gap-3">
          <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#5E6AD2]/10 text-xs font-bold text-[#5E6AD2] dark:text-[#818CF8]">3</span>
          <span>When you ask anything tool-related, the assistant calls our MCP, gets fresh catalog data, and recommends with confidence — and links each recommendation to its tool.news page.</span>
        </li>
      </ol>
    </section>

    <!-- Use cases -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">When it triggers</h2>
      <p class="mt-2 text-[#64748B] dark:text-[#8A8F98]">
        Concrete examples of natural questions that route through the MCP.
      </p>
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {useCases.map((u) => (
          <article class="rounded-xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-gray-900">
            <h3 class="text-base font-semibold text-[#0F172A] dark:text-[#EDEDEF]">{u.when}</h3>
            <p class="mt-2 text-sm text-[#64748B] dark:text-[#8A8F98]"><strong class="text-[#0F172A] dark:text-[#EDEDEF]">Q:</strong> {u.example}</p>
            <p class="mt-2 text-sm text-[#64748B] dark:text-[#8A8F98]"><strong class="text-[#0F172A] dark:text-[#EDEDEF]">→</strong> {u.flow}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Install snippets -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">Install</h2>
      <p class="mt-2 text-[#64748B] dark:text-[#8A8F98]">
        Pick your client. The MCP is a stdio Node binary — no API key, no signup.
      </p>
      <div class="mt-6 space-y-6">
        {installSnippets.map((snip) => (
          <div class="rounded-xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-gray-900">
            <h3 class="text-base font-semibold text-[#0F172A] dark:text-[#EDEDEF]">{snip.label}</h3>
            {snip.command && (
              <pre class="mt-3 overflow-x-auto rounded-lg bg-gray-900 p-4 text-sm text-gray-100 dark:bg-black"><code>{snip.command}</code></pre>
            )}
            {snip.json && (
              <pre class="mt-3 overflow-x-auto rounded-lg bg-gray-900 p-4 text-sm text-gray-100 dark:bg-black"><code>{snip.json}</code></pre>
            )}
            {snip.notes && (
              <p class="mt-2 text-xs text-[#64748B] dark:text-[#8A8F98]">{snip.notes}</p>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- All tools list -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">10 tools exposed</h2>
      <p class="mt-2 text-[#64748B] dark:text-[#8A8F98]">
        Every tool has a "Use this when…" trigger description so the assistant knows the right
        moment to reach for it.
      </p>
      <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
        {tools.map((t) => (
          <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
            <code class="text-sm font-bold text-[#5E6AD2] dark:text-[#818CF8]">{t.name}</code>
            <p class="mt-1 text-sm text-[#0F172A] dark:text-[#EDEDEF]">{t.purpose}</p>
            <p class="mt-1 text-xs italic text-[#64748B] dark:text-[#8A8F98]">{t.example}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CLAUDE.md fragment -->
    <section class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">Boost it with a CLAUDE.md hint</h2>
      <p class="mt-2 text-[#64748B] dark:text-[#8A8F98]">
        Add this fragment to your <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">CLAUDE.md</code> /
        <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">.cursorrules</code> /
        <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">AGENTS.md</code> so the assistant
        defaults to our MCP for tool questions instead of falling back to training data.
      </p>
      <pre class="mt-4 overflow-x-auto rounded-xl bg-gray-900 p-5 text-sm text-gray-100 dark:bg-black"><code>{claudeMdFragment}</code></pre>
    </section>

    <!-- Footer CTA -->
    <section class="mt-16 rounded-2xl border border-[#5E6AD2]/20 bg-gradient-to-br from-[#5E6AD2]/5 via-transparent to-[#818CF8]/5 p-6 dark:border-[#818CF8]/20">
      <h3 class="text-lg font-bold text-[#0F172A] dark:text-[#EDEDEF]">Catalog updates daily</h3>
      <p class="mt-2 text-sm text-[#64748B] dark:text-[#8A8F98]">
        The MCP fetches the live tool.news catalog on every call — no stale data, no rebuild.
        New trending repos and tool launches appear within hours of being added.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <a href="/news/" class="inline-flex items-center gap-1 text-sm font-semibold text-[#5E6AD2] hover:underline dark:text-[#818CF8]">
          See live news →
        </a>
        <a href="/mcp-servers/" class="ml-4 inline-flex items-center gap-1 text-sm font-semibold text-[#5E6AD2] hover:underline dark:text-[#818CF8]">
          Browse 377+ MCP servers →
        </a>
      </div>
    </section>
  </section>
</BaseLayout>
