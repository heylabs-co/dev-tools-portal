---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-4 py-8 text-center text-sm text-gray-500 dark:text-gray-400 sm:flex-row sm:justify-between sm:text-left">
    <div>
      <p class="font-medium text-gray-700 dark:text-gray-200">DevTools.wiki &mdash; Compare 630+ Developer Tools</p>
      <p class="mt-1 text-xs">Data updated every 6 hours</p>
    </div>

    <div class="flex items-center gap-4">
      <a href="/about/" class="hover:text-gray-900 dark:hover:text-white">About</a>
      <a href="https://github.com/nicholasgriffintn/dev-tools-portal" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 dark:hover:text-white">GitHub</a>
      <a href="https://github.com/fusssyfusssy/Dev-Tools-Portal/issues/new?template=add-tool.yml" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 dark:hover:text-white">Add Your Tool</a>
      <span>&copy; {year}</span>
    </div>
  </div>
</footer>
