---
interface Review {
  verdict?: string;
  pros?: string[];
  cons?: string[];
  best_for?: string;
  not_for?: string;
}

interface Props {
  review: Review;
}

const { review } = Astro.props;
---

<section class="mt-10 relative rounded-xl border border-[#5E6AD2]/20 dark:border-[#818CF8]/20 bg-white dark:bg-[#13131A] overflow-hidden shadow-sm">
  <!-- Left accent bar -->
  <div class="absolute inset-y-0 left-0 w-1 bg-[#5E6AD2] dark:bg-[#818CF8] rounded-l-xl"></div>

  <div class="pl-6 pr-6 py-6">
    <!-- Header -->
    <div class="flex items-center gap-2.5 mb-4">
      <!-- Badge/star icon -->
      <svg class="h-5 w-5 text-[#5E6AD2] dark:text-[#818CF8] shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
      </svg>
      <h2 class="text-base font-semibold text-[#0F172A] dark:text-[#EDEDEF] tracking-tight">Our Verdict</h2>
    </div>

    <!-- Verdict text -->
    {review.verdict && (
      <p class="text-[15px] font-medium text-[#1E293B] dark:text-[#D1D5DB] leading-relaxed mb-6">
        {review.verdict}
      </p>
    )}

    <!-- Pros / Cons two columns -->
    {((review.pros && review.pros.length > 0) || (review.cons && review.cons.length > 0)) && (
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <!-- Pros -->
        {review.pros && review.pros.length > 0 && (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-emerald-700 dark:text-emerald-400 mb-2.5">Pros</h3>
            <ul class="space-y-2">
              {review.pros.map((pro: string) => (
                <li class="flex items-start gap-2 text-sm text-[#334155] dark:text-[#A1A8B8]">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{pro}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Cons -->
        {review.cons && review.cons.length > 0 && (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-red-600 dark:text-red-400 mb-2.5">Cons</h3>
            <ul class="space-y-2">
              {review.cons.map((con: string) => (
                <li class="flex items-start gap-2 text-sm text-[#334155] dark:text-[#A1A8B8]">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-red-500 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                  <span>{con}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )}

    <!-- Best for / Not for pills -->
    {(review.best_for || review.not_for) && (
      <div class="flex flex-wrap gap-2 pt-4 border-t border-gray-100 dark:border-gray-800">
        {review.best_for && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-200 dark:border-emerald-800/40 px-3 py-1 text-xs font-medium text-emerald-700 dark:text-emerald-400">
            <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Best for: {review.best_for}
          </span>
        )}
        {review.not_for && (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-800/40 px-3 py-1 text-xs font-medium text-red-600 dark:text-red-400">
            <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Not for: {review.not_for}
          </span>
        )}
      </div>
    )}
  </div>
</section>
