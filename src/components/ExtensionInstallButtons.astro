---
/**
 * Deep-link install buttons for VS Code extensions.
 * Opens the extension directly in VS Code, VS Code Insiders, Cursor,
 * or Windsurf (all share the VS Code Marketplace).
 */
interface Props {
  vscodeId: string;
  extensionName: string;
}

const { vscodeId, extensionName } = Astro.props;

const vscodeUrl = `vscode:extension/${vscodeId}`;
const vscodeInsidersUrl = `vscode-insiders:extension/${vscodeId}`;
const cursorUrl = `cursor:extension/${vscodeId}`;
const windsurfUrl = `windsurf:extension/${vscodeId}`;
const cliCmd = `code --install-extension ${vscodeId}`;
---

<div class="ext-install-buttons">
  <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#64748B] dark:text-[#8A8F98]">
    One-click install
  </h3>
  <div class="flex flex-wrap gap-2">
    <a href={vscodeUrl} class="install-btn install-btn-accent">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M23.15 2.587L18.21.21a1.494 1.494 0 0 0-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 0 0-1.276.057L.327 7.261A1 1 0 0 0 .326 8.74L3.899 12 .326 15.26a1 1 0 0 0 .001 1.479L1.65 17.94a.999.999 0 0 0 1.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 0 0 1.704.29l4.942-2.377A1.5 1.5 0 0 0 24 20.06V3.939a1.5 1.5 0 0 0-.85-1.352zm-5.146 14.861L10.826 12l7.178-5.448v10.896z" />
      </svg>
      Install in VS Code
    </a>

    <a href={cursorUrl} class="install-btn">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M11.925 24l10.425-6v-12L11.925 0 1.5 6v12l10.425 6z" />
      </svg>
      Install in Cursor
    </a>

    <a href={windsurfUrl} class="install-btn">
      Install in Windsurf
    </a>

    <button type="button" class="install-btn copy-ext-cmd" data-cmd={cliCmd}>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="4 17 10 11 4 5" stroke-linecap="round" stroke-linejoin="round" />
        <line x1="12" y1="19" x2="20" y2="19" stroke-linecap="round" />
      </svg>
      Copy CLI command
    </button>
  </div>

  <details class="mt-3 text-sm">
    <summary class="cursor-pointer text-[#64748B] dark:text-[#8A8F98] hover:text-[#0F172A] dark:hover:text-[#EDEDEF] select-none">
      More clients (VS Code Insiders, Antigravity…)
    </summary>
    <div class="mt-3 flex flex-wrap gap-2">
      <a href={vscodeInsidersUrl} class="install-btn install-btn-sm">VS Code Insiders</a>
    </div>
    <p class="mt-3 text-xs text-[#64748B] dark:text-[#8A8F98] leading-relaxed">
      <strong>Antigravity</strong> (Google) and other VS Code forks support the same Marketplace — search for <code class="px-1 py-0.5 rounded bg-gray-100 dark:bg-gray-800 font-mono text-[11px]">{extensionName}</code> inside the IDE.
    </p>
  </details>
</div>

<style>
  .install-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
    transition: all 0.15s;
    cursor: pointer;
    text-decoration: none;
  }
  .install-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .install-btn-accent {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .install-btn-accent:hover {
    opacity: 0.9;
    color: #fff;
  }
  .install-btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.copy-ext-cmd').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.cmd ?? '';
      if (!text) return;
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.innerHTML;
        btn.innerHTML = '<span>Copied!</span>';
        setTimeout(() => { btn.innerHTML = original; }, 1500);
      });
    });
  });
</script>
