---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import sectionsData from '../../../data/meta/sections.json';

type Section = {
  slug: string;
  name: string;
  icon: string;
  description: string;
  order: number;
  categories: string[];
};

const sections: Section[] = (sectionsData as Section[]).slice().sort((a, b) => a.order - b.order);

const allCategories = await getCollection('categories');
const categoryCount = allCategories.length;
const totalTools = allCategories.reduce((sum, c) => sum + (c.data.company_count ?? 0), 0);

const catBySlug = new Map(allCategories.map((c) => [c.data.slug, c.data]));

type CatView = {
  slug: string;
  name: string;
  company_count: number;
  ai_native: boolean;
};
type SectionView = Section & { cats: CatView[]; total: number };

const sectionsView: SectionView[] = sections.map((s) => {
  const cats: CatView[] = s.categories
    .map((slug) => catBySlug.get(slug))
    .filter((c): c is NonNullable<typeof c> => c !== undefined)
    .map((c) => ({
      slug: c.slug,
      name: c.name,
      company_count: c.company_count ?? 0,
      ai_native: !!c.ai_native,
    }))
    .sort((a, b) => b.company_count - a.company_count);
  const total = cats.reduce((sum, c) => sum + c.company_count, 0);
  return { ...s, cats, total };
});
---

<BaseLayout
  title={`All ${categoryCount} Developer Tool Categories`}
  description={`Browse ${categoryCount} developer tool categories across ${sections.length} sections — payments, AI, mobile, infrastructure, observability, DevOps, security, APIs, and more. ${totalTools.toLocaleString()}+ tools total.`}
>
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Categories' },
      ]}
    />

    <div class="mt-6 mb-10">
      <h1 class="text-4xl font-extrabold tracking-tight" style="color: var(--color-text);">
        Developer Tool Categories
      </h1>
      <p class="mt-3 text-lg max-w-3xl" style="color: var(--color-muted);">
        {categoryCount} categories across {sections.length} sections —
        {totalTools.toLocaleString()}+ tools organized by what they do.
      </p>
    </div>

    {sectionsView.map((sec) => (
      <section class="mb-14">
        <a
          href={`/sections/${sec.slug}/`}
          class="group mb-4 flex flex-wrap items-baseline gap-3 border-b pb-3"
          style="border-color: var(--color-border);"
        >
          <span class="text-3xl leading-none">{sec.icon}</span>
          <h2 class="text-2xl font-bold transition-colors duration-150 group-hover:text-[#5E6AD2] dark:group-hover:text-[#818CF8]" style="color: var(--color-text);">
            {sec.name}
          </h2>
          <span class="text-sm" style="color: var(--color-muted);">
            {sec.cats.length} categories · {sec.total.toLocaleString()} tools
          </span>
          <span class="ml-auto text-sm opacity-60 transition-opacity duration-150 group-hover:opacity-100" style="color: var(--color-accent);">
            View section →
          </span>
        </a>
        <p class="mb-4 text-sm" style="color: var(--color-muted);">{sec.description}</p>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {sec.cats.map((cat) => (
            <a
              href={`/categories/${cat.slug}/`}
              class="group flex items-center justify-between rounded-xl border p-4 transition-all duration-150 hover:-translate-y-0.5 hover:shadow-md"
              style="border-color: var(--color-border); background-color: var(--color-surface);"
            >
              <div class="min-w-0 flex-1">
                <h3 class="truncate text-sm font-semibold transition-colors duration-150 group-hover:text-[#5E6AD2] dark:group-hover:text-[#818CF8]" style="color: var(--color-text);">
                  {cat.name}
                </h3>
                <p class="mt-0.5 text-xs" style="color: var(--color-muted);">
                  {cat.company_count} {cat.company_count === 1 ? 'tool' : 'tools'}
                </p>
              </div>
              {cat.ai_native && (
                <span class="ml-2 inline-flex shrink-0 items-center rounded-full bg-gradient-to-r from-purple-500 to-indigo-500 px-2 py-0.5 text-[10px] font-semibold text-white shadow-sm">
                  AI
                </span>
              )}
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
