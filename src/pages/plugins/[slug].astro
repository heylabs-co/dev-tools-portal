---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const plugins = await getCollection('jetbrainsPlugins');
  return plugins.map((entry) => ({
    params: { slug: entry.id },
    props: { plugin: entry },
  }));
}

const { plugin } = Astro.props;
const d = plugin.data;

const pageTitle = d.seo?.title ?? `${d.name} — JetBrains Plugin`;
const pageDescription = d.seo?.meta_description ?? d.description ?? `Install and learn about ${d.name} JetBrains plugin.`;

const marketplaceUrl = `https://plugins.jetbrains.com/search?search=${encodeURIComponent(d.name)}`;

const categoryLabels: Record<string, string> = {
  ai: 'AI',
  database: 'Database',
  design: 'Design',
  devops: 'DevOps',
  docker: 'Docker',
  framework: 'Framework',
  git: 'Git',
  language: 'Language',
  linting: 'Linting',
  other: 'Other',
  productivity: 'Productivity',
  testing: 'Testing',
};

const ideLabels: Record<string, string> = {
  all: 'All IDEs',
  intellij: 'IntelliJ IDEA',
  pycharm: 'PyCharm',
  webstorm: 'WebStorm',
  phpstorm: 'PhpStorm',
  rider: 'Rider',
  clion: 'CLion',
};

const cat = d.category ?? 'other';
const catLabel = categoryLabels[cat] ?? cat;
const ide = d.ide ?? 'all';
const ideLabel = ideLabels[ide] ?? ide;

// Schema.org
const schemaOrg = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: d.name,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Cross-platform',
  ...(d.description ? { description: d.description } : {}),
  url: marketplaceUrl,
  ...(d.publisher ? { author: { '@type': 'Organization', name: d.publisher } } : {}),
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article class="mx-auto max-w-4xl px-6 py-12">
    <!-- Breadcrumbs -->
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Plugins', href: '/plugins/' },
        { label: d.name },
      ]}
    />

    <!-- Hero card -->
    <div class="mt-10 rounded-2xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-8 shadow-sm">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-3">
            <h1 class="text-3xl font-bold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">
              {d.name}
            </h1>
            <span class="inline-flex items-center rounded-full bg-[#5E6AD2]/10 dark:bg-[#818CF8]/10 border border-[#5E6AD2]/20 dark:border-[#818CF8]/20 px-3 py-1 text-xs font-semibold text-[#5E6AD2] dark:text-[#818CF8]">
              {catLabel}
            </span>
            <span class="inline-flex items-center rounded-full bg-orange-500/10 border border-orange-500/20 px-3 py-1 text-xs font-semibold text-orange-600 dark:text-orange-400">
              {ideLabel}
            </span>
          </div>

          {d.description && (
            <p class="mt-3 text-base text-[#64748B] dark:text-[#8A8F98] leading-relaxed max-w-2xl">
              {d.description}
            </p>
          )}

          {d.publisher && (
            <p class="mt-2 text-sm text-[#64748B] dark:text-[#8A8F98]">
              by <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">{d.publisher}</span>
            </p>
          )}
        </div>
      </div>

      <!-- Links -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <a
          href={marketplaceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-[#13131A] px-4 py-2 text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF] hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 transition-colors shadow-sm"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M21.78 4.23l-8.56 18.7c-.37.8-1.5.83-1.9.04L8.16 16.7a1 1 0 0 0-.56-.56L.84 12.68c-.79-.4-.76-1.53.04-1.9L19.58 2.22c.76-.35 1.6.08 1.91.83.1.24.14.5.1.76l-.01.02.2-.6z"/>
          </svg>
          JetBrains Marketplace
          <svg class="h-3 w-3 text-[#64748B] dark:text-[#8A8F98]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
      </div>
    </div>

    <!-- Install from IDE -->
    <section class="mt-10">
      <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
        <span class="block w-1 h-6 rounded-full bg-[#5E6AD2] dark:bg-[#818CF8]"></span>
        Install from Your IDE
      </h2>
      <div class="mt-4 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-6">
        <ol class="list-decimal list-inside space-y-3 text-sm leading-relaxed text-[#64748B] dark:text-[#8A8F98]">
          <li>Open your JetBrains IDE and go to <code class="rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs font-mono">Settings / Preferences</code> &rarr; <code class="rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs font-mono">Plugins</code>.</li>
          <li>Click <strong class="text-[#0F172A] dark:text-[#EDEDEF]">Marketplace</strong> and search for <code class="rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs font-mono">{d.name}</code>.</li>
          <li>Click <strong class="text-[#0F172A] dark:text-[#EDEDEF]">Install</strong> and restart the IDE if prompted.</li>
        </ol>
      </div>
    </section>

    <!-- Details -->
    <section class="mt-10">
      <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
        <span class="block w-1 h-6 rounded-full" style="background-color: var(--color-accent);"></span>
        Details
      </h2>
      <div class="mt-5 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-6 space-y-4">
        {d.publisher && (
          <div class="text-sm">
            <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Publisher:</span>
            <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{d.publisher}</span>
          </div>
        )}
        <div class="text-sm">
          <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Category:</span>
          <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{catLabel}</span>
        </div>
        <div class="text-sm">
          <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">IDE:</span>
          <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{ideLabel}</span>
        </div>
      </div>
    </section>
  </article>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
</BaseLayout>
