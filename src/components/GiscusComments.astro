---
interface Props {
  term: string; // The discussion title / page identifier
}
const { term } = Astro.props;
---

<section class="mt-12 border-t border-gray-200 dark:border-gray-800 pt-8">
  <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Community Discussion</h2>
  <div class="giscus-container">
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo="heylabs-co/dev-tools-portal"
      data-repo-id=""
      data-category="General"
      data-category-id=""
      data-mapping="specific"
      data-term={term}
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="preferred_color_scheme"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </div>
  <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">
    Comments powered by <a href="https://giscus.app" class="text-indigo-600 hover:underline" target="_blank" rel="noopener">Giscus</a> (GitHub Discussions).
    You need a GitHub account to comment.
  </p>
</section>
