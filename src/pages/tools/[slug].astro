---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import LockInBadge from '../../components/LockInBadge.astro';
import MetricBar from '../../components/MetricBar.astro';
import PricingTable from '../../components/PricingTable.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import HealthScore from '../../components/HealthScore.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import VoteButtons from '../../components/VoteButtons.astro';
import TcoCalculator from '../../components/TcoCalculator.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import RecommendCTA from '../../components/RecommendCTA.astro';
import { getCollection } from 'astro:content';
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, resolve } from 'node:path';

export async function getStaticPaths() {
  const companies = await getCollection('companies');
  return companies.map((entry) => ({
    params: { slug: entry.id },
    props: { company: entry },
  }));
}

const { company } = Astro.props;
const d = company.data;

// Load reverse index: tool slug → [use cases that reference it].
// File is generated by scripts/build-use-case-reverse-index.ts before astro build.
let usedInStacks: Array<{ slug: string; title: string; meta_category: string }> = [];
try {
  const reverseIndexPath = resolve(
    dirname(fileURLToPath(import.meta.url)),
    '../../../data/meta/use-cases-by-tool.json',
  );
  if (existsSync(reverseIndexPath)) {
    const idx = JSON.parse(readFileSync(reverseIndexPath, 'utf-8')) as Record<
      string,
      Array<{ slug: string; title: string; meta_category: string }>
    >;
    // Use hasOwnProperty so slugs like "constructor" (which collide with
    // Object.prototype members) don't return the prototype method.
    const found = Object.prototype.hasOwnProperty.call(idx, d.slug) ? idx[d.slug] : undefined;
    usedInStacks = Array.isArray(found) ? found : [];
  }
} catch { /* reverse index not built yet — fall back to empty */ }

const pageTitle = d.seo?.title || `${d.name} — Developer Tool Review`;
const pageDescription = d.seo?.meta_description || d.description || `Learn about ${d.name}: pricing, lock-in score, and alternatives.`;
const initial = d.name.charAt(0).toUpperCase();

const lockIn = d.scores?.lock_in;

const scaleItems = [
  { label: 'Customers', value: d.scale?.customers },
  { label: 'Revenue', value: d.scale?.revenue },
  { label: 'Employees', value: d.scale?.employees },
  { label: 'Valuation', value: d.scale?.valuation },
].filter((item) => item.value);

// Family detection — group tools by website root domain so siblings
// (e.g. Stripe + Stripe API + Stripe Atlas + Stripe Connect) link to
// each other. We strip "www.", well-known subdomains, and skip generic
// hosts that aren't brand-specific (github.com, gitlab.com, etc).
function rootDomain(url: string | undefined | null): string | null {
  if (!url) return null;
  try {
    const u = new URL(url);
    let host = u.hostname.toLowerCase().replace(/^www\./, '');
    // Skip generic hosts so we don't group every OSS tool that uses a github URL.
    const generic = new Set([
      'github.com', 'github.io', 'gitlab.com', 'bitbucket.org',
      'docs.google.com', 'sites.google.com', 'medium.com',
      'gitbook.io', 'notion.site', 'notion.so', 'pages.dev',
      'vercel.app', 'netlify.app', 'fly.dev', 'workers.dev',
      'readme.io', 'gitiles.com', 'sourceforge.net',
    ]);
    if (generic.has(host)) return null;
    return host;
  } catch { return null; }
}
const myFamilyDomain = rootDomain(d.website);
let familyMembers: Array<{ slug: string; name: string; category: string }> = [];
if (myFamilyDomain) {
  const all = await getCollection('companies');
  familyMembers = all
    .filter((c) => c.data.slug !== d.slug)
    .filter((c) => rootDomain(c.data.website) === myFamilyDomain)
    .filter((c) => c.data.status !== 'inactive')
    .map((c) => ({
      slug: c.data.slug,
      name: c.data.name,
      category: c.data.categories?.primary?.name ?? '—',
    }))
    .sort((a, b) => a.name.localeCompare(b.name))
    .slice(0, 12);
}
// Family display name: shortest sibling name is usually the parent brand
// (e.g. "Stripe" comes before "Stripe API"). Fall back to current tool name.
const familyName = familyMembers.length > 0
  ? [d.name, ...familyMembers.map((m) => m.name)].sort((a, b) => a.length - b.length)[0]
  : d.name;

// High-water-mark pricing flag. If this tool is flagged, compute 3-5
// alternatives from the same primary category that do NOT have the flag.
const hwm = d.pricing?.high_water_mark === true;
const hwmReason: string | undefined = (d.pricing as any)?.high_water_mark_reason;
let hwmAlternatives: Array<{ slug: string; name: string; lockInLevel?: string }> = [];
if (hwm) {
  const primarySlug = d.categories?.primary?.slug;
  if (primarySlug) {
    const all = await getCollection('companies');
    hwmAlternatives = all
      .filter((c) => c.data.slug !== d.slug)
      .filter((c) => c.data.categories?.primary?.slug === primarySlug)
      .filter((c) => (c.data.pricing as any)?.high_water_mark !== true)
      .filter((c) => c.data.status !== 'inactive')
      .map((c) => ({
        slug: c.data.slug,
        name: c.data.name,
        lockInLevel: c.data.scores?.lock_in?.level,
      }))
      .sort((a, b) => {
        // low lock-in first
        const rank = (l?: string) => (l === 'low' ? 0 : l === 'medium' ? 1 : l === 'high' ? 2 : 3);
        const r = rank(a.lockInLevel) - rank(b.lockInLevel);
        return r !== 0 ? r : a.name.localeCompare(b.name);
      })
      .slice(0, 5);
  }
}
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article
    class="mx-auto max-w-4xl px-6 py-12"
    data-pagefind-body
    data-pagefind-filter={`type:Tool`}
    data-pagefind-meta={`type:Tool`}
  >
    <!-- Pagefind facets: filters + metadata. data-pagefind-ignore keeps body out of indexed text. -->
    <div data-pagefind-ignore="all" hidden>
      <span data-pagefind-filter={`category:${d.categories.primary.name}`}></span>
      {d.pricing?.model && <span data-pagefind-filter={`pricing:${d.pricing.model}`}></span>}
      {d.pricing?.has_free_tier !== undefined && <span data-pagefind-filter={`free_tier:${d.pricing.has_free_tier ? 'Yes' : 'No'}`}></span>}
      {lockIn && <span data-pagefind-filter={`lock_in:${lockIn.level.charAt(0).toUpperCase() + lockIn.level.slice(1)}`}></span>}
      {d.health?.health_score && <span data-pagefind-filter={`health:${d.health.health_score}`}></span>}
      <span data-pagefind-meta={`category:${d.categories.primary.name}`}></span>
      {d.logo && <span data-pagefind-meta={`logo:${d.logo}`}></span>}
      {d.hq_country && <span data-pagefind-meta={`country:${d.hq_country}`}></span>}
      {d.founded && <span data-pagefind-meta={`founded:${d.founded}`}></span>}
      {d.pricing?.model && <span data-pagefind-meta={`pricing:${d.pricing.model}`}></span>}
      {lockIn && <span data-pagefind-meta={`lock_in:${lockIn.level}`}></span>}
    </div>
    <!-- Breadcrumbs -->
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Tools', href: '/tools/' },
        { label: d.name },
      ]}
    />

    <!-- Hero -->
    <header class="mt-10 flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex items-start gap-5 min-w-0 flex-1">
        <!-- Logo with subtle glow -->
        <div class="relative shrink-0">
          <div class="absolute -inset-2 rounded-3xl bg-[#5E6AD2]/10 dark:bg-[#818CF8]/10 blur-xl"></div>
          <div class="relative h-24 w-24 overflow-hidden rounded-2xl border border-gray-200/60 dark:border-gray-700/60 bg-white dark:bg-[#13131A] shadow-sm">
            <img
              src={d.logo ?? ''}
              alt={`${d.name} logo`}
              width="96"
              height="96"
              class="h-full w-full object-contain p-2"
              onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
            />
            <span
              class="absolute inset-0 hidden items-center justify-center text-3xl font-bold text-[#64748B] dark:text-[#8A8F98] bg-gradient-to-br from-[#5E6AD2]/5 to-[#818CF8]/10 dark:from-[#5E6AD2]/10 dark:to-[#818CF8]/20"
              aria-hidden="true"
            >
              {initial}
            </span>
          </div>
        </div>

        <div class="min-w-0 flex-1 pt-1">
          <h1 class="text-3xl font-bold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">
            {d.name}
          </h1>
          {d.description && (
            <p class="mt-2 text-base text-[#64748B] dark:text-[#8A8F98] leading-relaxed">{d.description}</p>
          )}
          <div class="mt-4 flex flex-wrap items-center gap-3">
            <a
              href={d.website}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-[#13131A] px-4 py-2 text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF] hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 transition-colors shadow-sm"
            >
              Visit website
              <svg class="h-3.5 w-3.5 text-[#64748B] dark:text-[#8A8F98]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
            <a
              href={`/compare/?a=${d.slug}`}
              class="inline-flex items-center gap-2 rounded-lg border border-[#5E6AD2]/30 dark:border-[#818CF8]/30 px-4 py-2 text-sm font-medium text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/5 dark:hover:bg-[#818CF8]/5 transition-colors"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
              Compare with...
            </a>
          </div>
        </div>
      </div>

      <!-- Vote buttons inline right -->
      <div class="shrink-0 sm:pt-1">
        <VoteButtons slug={d.slug} name={d.name} />
      </div>
    </header>

    <!-- Info badges row -->
    <div class="mt-8 flex flex-wrap items-center gap-2">
      {d.hq_country && (
        <span class="inline-flex items-center rounded-full bg-[#FAFBFC] dark:bg-[#13131A] border border-gray-200 dark:border-gray-700/60 px-3 py-1 text-xs font-medium text-[#64748B] dark:text-[#8A8F98]">
          {d.hq_country}
        </span>
      )}
      {d.founded && (
        <span class="inline-flex items-center rounded-full bg-[#FAFBFC] dark:bg-[#13131A] border border-gray-200 dark:border-gray-700/60 px-3 py-1 text-xs font-medium text-[#64748B] dark:text-[#8A8F98]">
          Est. {d.founded}
        </span>
      )}
      <span
        class:list={[
          'inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border',
          d.status === 'active'
            ? 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-700 dark:text-emerald-400 border-emerald-200 dark:border-emerald-800/60'
            : 'bg-gray-50 dark:bg-gray-800/50 text-[#64748B] dark:text-[#8A8F98] border-gray-200 dark:border-gray-700/60',
        ]}
      >
        {d.status === 'active' ? 'Active' : 'Inactive'}
      </span>
      <!-- Category badge: accent color, larger -->
      <a
        href={`/categories/${d.categories.primary.slug}/`}
        class="inline-flex items-center rounded-full bg-[#5E6AD2]/10 dark:bg-[#818CF8]/10 border border-[#5E6AD2]/20 dark:border-[#818CF8]/20 px-4 py-1 text-xs font-semibold text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/15 dark:hover:bg-[#818CF8]/15 transition-colors"
      >
        {d.categories.primary.name}
      </a>
      {hwm && (
        <a
          href="#pricing-warning"
          title={hwmReason}
          class="inline-flex items-center gap-1.5 rounded-full border border-red-500/30 bg-red-500/10 px-3 py-1 text-xs font-semibold text-red-700 dark:text-red-300 hover:bg-red-500/15 transition-colors"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
          High water mark pricing
        </a>
      )}
    </div>

    <!-- Review Card -->
    {d.review && <ReviewCard review={d.review} />}

    <!-- When to Use -->
    {d.content?.when_to_use && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
          <span class="block w-1 h-6 rounded-full bg-[#5E6AD2] dark:bg-[#818CF8]"></span>
          When to Use {d.name}
        </h2>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-emerald-200/80 dark:border-emerald-800/40 bg-emerald-50/60 dark:bg-emerald-950/20 p-5">
            <h3 class="text-sm font-semibold text-emerald-800 dark:text-emerald-300 mb-3">Good fit if you need</h3>
            <ul class="space-y-2.5">
              {d.content.when_to_use.map((item: string) => (
                <li class="flex items-start gap-2.5 text-sm text-emerald-700 dark:text-emerald-400">
                  <svg class="mt-0.5 h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          {d.content.when_not_to_use && (
            <div class="rounded-xl border border-red-200/80 dark:border-red-800/40 bg-red-50/60 dark:bg-red-950/20 p-5">
              <h3 class="text-sm font-semibold text-red-800 dark:text-red-300 mb-3">Not the best choice if</h3>
              <ul class="space-y-2.5">
                {d.content.when_not_to_use.map((item: string) => (
                  <li class="flex items-start gap-2.5 text-sm text-red-700 dark:text-red-400">
                    <svg class="mt-0.5 h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
        {d.content.consider_instead && d.content.consider_instead.length > 0 && (
          <p class="mt-4 text-sm text-[#64748B] dark:text-[#8A8F98]">
            Consider instead:{' '}
            {d.content.consider_instead.map((alt: string, i: number) => (
              <>{i > 0 && ', '}<a href={`/tools/${alt}/`} class="text-[#5E6AD2] dark:text-[#818CF8] hover:underline">{alt}</a></>
            ))}
          </p>
        )}
      </section>
    )}

    <!-- Migration Cheatsheet -->
    {d.content?.migration_cheatsheet && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
          <span class="block w-1 h-6 rounded-full bg-amber-500 dark:bg-amber-400"></span>
          Migration Guide
        </h2>
        <div class="mt-5 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-6 space-y-4">
          <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF]">Difficulty:</span>
            <span class="inline-flex items-center rounded-full bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800/40 px-3 py-0.5 text-xs font-medium text-amber-700 dark:text-amber-400 capitalize">{d.content.migration_cheatsheet.difficulty}</span>
          </div>
          <div class="text-sm">
            <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Data you can export:</span>
            <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{d.content.migration_cheatsheet.data_you_keep}</span>
          </div>
          <div class="text-sm">
            <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">API standard:</span>
            <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{d.content.migration_cheatsheet.api_standard}</span>
          </div>
          {d.content.migration_cheatsheet.tip && (
            <p class="text-sm text-[#64748B] dark:text-[#8A8F98] italic border-t border-gray-100 dark:border-gray-800 pt-4">
              💡 {d.content.migration_cheatsheet.tip}
            </p>
          )}
        </div>
      </section>
    )}

    <!-- Works Well With -->
    {d.content?.works_well_with && d.content.works_well_with.length > 0 && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
          <span class="block w-1 h-6 rounded-full bg-[#5E6AD2] dark:bg-[#818CF8]"></span>
          Works Well With
        </h2>
        <div class="mt-5 flex flex-wrap gap-3">
          {d.content.works_well_with.map((slug: string) => (
            <a
              href={`/tools/${slug}/`}
              class="inline-flex items-center gap-2 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] px-4 py-2.5 text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF] hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 transition-colors shadow-sm"
            >
              <span class="flex h-6 w-6 items-center justify-center rounded-md bg-gray-100 dark:bg-gray-800 text-xs font-bold text-[#64748B] dark:text-[#8A8F98]">{slug.charAt(0).toUpperCase()}</span>
              {slug}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Lock-in Section -->
    <div data-pagefind-ignore>
    {lockIn && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
          <span class="block w-1 h-6 rounded-full bg-orange-500 dark:bg-orange-400"></span>
          Lock-in Assessment
        </h2>
        <div class="mt-5 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-6 space-y-5">
          <div class="flex items-center gap-3">
            <LockInBadge level={lockIn.level} score={lockIn.score} />
          </div>
          <MetricBar label="Lock-in Score" value={lockIn.score} maxValue={5} inverted={true} />
          {lockIn.explanation && (
            <p class="text-sm text-[#64748B] dark:text-[#8A8F98] leading-relaxed">{lockIn.explanation}</p>
          )}
          {lockIn.data_portability && (
            <div class="text-sm">
              <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Data Portability:</span>
              <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{lockIn.data_portability}</span>
            </div>
          )}
          {lockIn.api_compatibility && (
            <div class="text-sm">
              <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">API Compatibility:</span>
              <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{lockIn.api_compatibility}</span>
            </div>
          )}
        </div>
      </section>
    )}

    </div>
    <!-- Pricing Section -->
    <div data-pagefind-ignore>
    {d.pricing && (
      <section class="mt-14">
        <div class="flex items-center justify-between mb-5">
          <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
            <span class="block w-1 h-6 rounded-full bg-emerald-500 dark:bg-emerald-400"></span>
            Pricing
          </h2>
          <a
            href={`https://github.com/heylabs-co/dev-tools-portal/issues/new?title=${encodeURIComponent(`[Pricing] ${d.name} — incorrect or outdated pricing`)}&body=${encodeURIComponent(`**Tool:** ${d.name}\n**Current pricing on our site:**\n- Model: ${d.pricing?.model || 'unknown'}\n- Entry price: ${d.pricing?.entry_price || 'unknown'}\n- Free tier: ${d.pricing?.has_free_tier ? 'Yes' : 'No'}\n\n**What's wrong:**\n\n**Correct pricing (with source link):**\n`)}&labels=pricing-fix`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 rounded-lg border border-amber-200 dark:border-amber-800/40 bg-amber-50/60 dark:bg-amber-950/20 px-3 py-1.5 text-xs font-medium text-amber-700 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 transition-colors"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Price wrong?
          </a>
        </div>
        <PricingTable company={{ name: d.name, pricing: d.pricing }} />

        {hwm && (
          <aside
            id="pricing-warning"
            class="mt-6 rounded-xl border border-red-300 dark:border-red-800/60 bg-red-50/70 dark:bg-red-950/30 p-5"
          >
            <h3 class="flex items-center gap-2 text-sm font-bold text-red-800 dark:text-red-300">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-xs text-white">!</span>
              Heads up: high water mark pricing
            </h3>
            <p class="mt-2 text-sm text-red-700 dark:text-red-200">
              {hwmReason ?? 'Bill stays at peak usage or reserved capacity — does not scale down within the billing cycle.'}
            </p>
            {hwmAlternatives.length > 0 && (
              <>
                <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-red-800 dark:text-red-300">
                  Alternatives without this pricing pattern
                </p>
                <ul class="mt-2 space-y-1.5">
                  {hwmAlternatives.map((alt) => (
                    <li class="flex items-center gap-2 text-sm">
                      <a
                        href={`/tools/${alt.slug}/`}
                        class="font-medium text-red-900 dark:text-red-100 hover:underline"
                      >
                        {alt.name}
                      </a>
                      {alt.lockInLevel && (
                        <span class="text-xs text-red-700 dark:text-red-300">· {alt.lockInLevel} lock-in</span>
                      )}
                    </li>
                  ))}
                </ul>
              </>
            )}
          </aside>
        )}
      </section>
    )}

    <!-- No pricing — help us -->
    {!d.pricing && (
      <section class="mt-14">
        <div class="rounded-xl border border-dashed border-gray-300 dark:border-gray-700 bg-[#FAFBFC] dark:bg-[#13131A] p-8 text-center">
          <p class="text-sm text-[#64748B] dark:text-[#8A8F98]">No pricing data yet for {d.name}</p>
          <a
            href={`https://github.com/heylabs-co/dev-tools-portal/issues/new?title=${encodeURIComponent(`[Pricing] Add pricing for ${d.name}`)}&body=${encodeURIComponent(`**Tool:** ${d.name}\n**Website:** ${d.website}\n\n**Pricing info:**\n- Model (usage/subscription/freemium/seat):\n- Free tier (yes/no):\n- Entry price:\n- Pricing page URL:\n`)}&labels=pricing-data`}
            target="_blank"
            rel="noopener"
            class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-[#5E6AD2] dark:bg-[#818CF8] px-4 py-2 text-sm font-medium text-white hover:opacity-90 transition-opacity"
          >
            Help us add pricing data
          </a>
        </div>
      </section>
    )}

    <!-- TCO Calculator -->
    {d.pricing && (
      <TcoCalculator slug={d.slug} name={d.name} pricing={d.pricing} />
    )}

    </div>
    <!-- Scale Section -->
    <div data-pagefind-ignore>
    {scaleItems.length > 0 && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF] mb-5">
          <span class="block w-1 h-6 rounded-full bg-sky-500 dark:bg-sky-400"></span>
          Scale
        </h2>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
          {scaleItems.map((item) => (
            <div class="rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-5 text-center">
              <dt class="text-xs font-medium text-[#64748B] dark:text-[#8A8F98] uppercase tracking-wider">{item.label}</dt>
              <dd class="mt-2 text-xl font-bold text-[#0F172A] dark:text-[#EDEDEF]" style="font-family: 'JetBrains Mono', monospace;">{item.value}</dd>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Health Score -->
    {d.health && <HealthScore health={d.health} />}

    <!-- Alternatives Section -->
    {d.alternatives && d.alternatives.length > 0 && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF] mb-5">
          <span class="block w-1 h-6 rounded-full bg-violet-500 dark:bg-violet-400"></span>
          Alternatives
        </h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
          {d.alternatives.map((alt: string) => (
            <a
              href={`/tools/${alt}/`}
              class="flex items-center gap-3 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] px-4 py-3 text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF] hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 transition-colors shadow-sm"
            >
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-bold text-[#64748B] dark:text-[#8A8F98] shrink-0">{alt.charAt(0).toUpperCase()}</span>
              <span class="truncate">{alt}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    </div>
    <!-- Report incorrect data -->
    <div data-pagefind-ignore>
    <div class="mt-16 pt-8 border-t border-gray-100 dark:border-gray-800/60 text-center">
      <a
        href={`https://github.com/heylabs-co/dev-tools-portal/issues/new?title=${encodeURIComponent(`[Data] Incorrect info for ${d.name}`)}&body=${encodeURIComponent(`**Tool:** ${d.name}\n**Page:** /tools/${d.slug}/\n\n**What's incorrect:**\n\n**Correct information:**\n`)}`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 text-sm text-[#64748B] dark:text-[#8A8F98] hover:text-[#0F172A] dark:hover:text-[#EDEDEF] transition-colors"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Report incorrect data
      </a>
    </div>

    <!-- Family / sibling products from same brand -->
    {familyMembers.length > 0 && (
      <section class="mt-12" data-pagefind-ignore>
        <h2 class="flex items-center gap-3 text-lg font-semibold" style="color: var(--color-text);">
          <span class="block w-1 h-6 rounded-full bg-gradient-to-b from-[#5E6AD2] to-[#818CF8]"></span>
          More from {familyName}
        </h2>
        <p class="mt-2 text-sm" style="color: var(--color-muted);">
          Other {familyName} products in the catalog — same brand, different category.
        </p>
        <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
          {familyMembers.map((m) => (
            <a
              href={`/tools/${m.slug}/`}
              class="group flex items-center justify-between rounded-xl border p-4 transition-all duration-150 hover:-translate-y-0.5 hover:shadow-md"
              style="border-color: var(--color-border); background-color: var(--color-surface);"
            >
              <div class="min-w-0">
                <div class="text-sm font-semibold transition-colors duration-150 group-hover:text-[#5E6AD2] dark:group-hover:text-[#818CF8]" style="color: var(--color-text);">
                  {m.name}
                </div>
                <div class="mt-0.5 truncate text-xs" style="color: var(--color-muted);">
                  {m.category}
                </div>
              </div>
              <svg class="h-4 w-4 shrink-0 opacity-40 transition-opacity duration-150 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-muted);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Migrate CTA — opens modal to draft an export-request email -->
    <section class="mt-12" data-pagefind-ignore>
      <div class="rounded-2xl border border-orange-200/60 dark:border-orange-900/40 bg-orange-50/40 dark:bg-orange-950/20 p-6">
        <h3 class="flex items-center gap-2 text-base font-bold" style="color: var(--color-text);">
          <span>🔄</span>
          Thinking about migrating off {d.name}?
        </h3>
        <p class="mt-2 text-sm" style="color: var(--color-muted);">
          Get an AI-drafted migration plan + a copy-paste email to {d.name} support
          requesting a data export. Pick where you're moving to and tell us your context.
        </p>
        <button
          id="migrate-open-btn"
          type="button"
          data-source-slug={d.slug}
          data-source-name={d.name}
          data-source-category={d.categories.primary.slug}
          class="mt-4 inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-orange-500 to-amber-500 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:opacity-90"
        >
          Help me migrate from {d.name}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
      </div>
    </section>

    <!-- Migrate Modal — hidden until button click -->
    <div
      id="migrate-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4 backdrop-blur-sm"
      role="dialog"
      aria-modal="true"
      aria-labelledby="migrate-modal-title"
    >
      <div class="relative w-full max-w-2xl rounded-2xl bg-white p-6 shadow-xl dark:bg-gray-900 max-h-[90vh] overflow-y-auto">
        <button
          id="migrate-close-btn"
          type="button"
          aria-label="Close"
          class="absolute top-3 right-3 rounded-full p-1.5 text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
        <h3 id="migrate-modal-title" class="text-lg font-bold text-gray-900 dark:text-white">
          Migrate from {d.name}
        </h3>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
          We'll draft an export-request email and a step-by-step plan.
        </p>

        <div id="migrate-form" class="mt-5 space-y-4">
          <div>
            <label for="migrate-target" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Migrate to
            </label>
            <select
              id="migrate-target"
              class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/30 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
            >
              <option value="">Loading alternatives…</option>
            </select>
          </div>

          <div>
            <label for="migrate-context" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Your context <span class="text-xs text-gray-500">(stack, data volume, what matters)</span>
            </label>
            <textarea
              id="migrate-context"
              rows="3"
              placeholder="e.g. Next.js + Postgres app, ~5k MAU, need to keep webhook subscriptions and historical events"
              class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/30 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
            ></textarea>
          </div>

          <button
            id="migrate-submit-btn"
            type="button"
            class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-orange-500 to-amber-500 px-4 py-2.5 text-sm font-semibold text-white transition hover:opacity-90"
          >
            Draft my migration plan
          </button>
          <p class="text-[11px] text-gray-500 dark:text-gray-400">
            ⚠ AI-generated — verify every step against the official docs before executing.
          </p>
        </div>

        <div id="migrate-loading" class="mt-6 hidden text-center">
          <div class="inline-block h-6 w-6 animate-spin rounded-full border-2 border-orange-500 border-t-transparent"></div>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Drafting your migration plan…</p>
        </div>
        <div id="migrate-error" class="mt-6 hidden rounded-lg bg-red-50 dark:bg-red-950/30 p-4 text-sm text-red-700 dark:text-red-300"></div>
        <div id="migrate-results" class="mt-6 hidden space-y-5"></div>
      </div>
    </div>

    <script is:inline define:vars={{ sourceSlug: d.slug, sourceName: d.name, primaryCategorySlug: d.categories.primary.slug }}>
      (function () {
        const openBtn = document.getElementById('migrate-open-btn');
        const closeBtn = document.getElementById('migrate-close-btn');
        const modal = document.getElementById('migrate-modal');
        const form = document.getElementById('migrate-form');
        const targetSel = document.getElementById('migrate-target');
        const ctxTa = document.getElementById('migrate-context');
        const submitBtn = document.getElementById('migrate-submit-btn');
        const loadingEl = document.getElementById('migrate-loading');
        const errorEl = document.getElementById('migrate-error');
        const resultsEl = document.getElementById('migrate-results');
        if (!openBtn || !modal) return;

        function open() {
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          if (!targetSel.dataset.loaded) loadAlternatives();
        }
        function close() {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }
        openBtn.addEventListener('click', open);
        closeBtn.addEventListener('click', close);
        modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
        });

        function esc(s) { return String(s ?? '').replace(/[&<>"']/g, function (c) {
          return ({'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'})[c];
        }); }

        // Pull same-category tools from a static endpoint we already publish.
        async function loadAlternatives() {
          try {
            const r = await fetch('/api/tools-by-category.json', { cache: 'force-cache' });
            const data = await r.json();
            const alts = (data[primaryCategorySlug] || []).filter(function (t) {
              return t.slug !== sourceSlug;
            }).slice(0, 50);
            if (alts.length === 0) {
              targetSel.innerHTML = '<option value="">(no alternatives in this category)</option>';
              return;
            }
            targetSel.innerHTML =
              '<option value="">— choose a target —</option>' +
              alts.map(function (t) {
                return '<option value="' + esc(t.slug) + '">' + esc(t.name) + '</option>';
              }).join('');
            targetSel.dataset.loaded = '1';
          } catch (e) {
            targetSel.innerHTML = '<option value="">Couldn\'t load alternatives</option>';
            console.warn('migrate alts load failed', e);
          }
        }

        submitBtn.addEventListener('click', async function () {
          const target = targetSel.value;
          if (!target) {
            errorEl.textContent = 'Please pick a target tool first.';
            errorEl.classList.remove('hidden');
            return;
          }
          errorEl.classList.add('hidden');
          form.classList.add('hidden');
          loadingEl.classList.remove('hidden');
          resultsEl.classList.add('hidden');
          resultsEl.innerHTML = '';

          try {
            const res = await fetch('https://devtools-recommend-api.sssands.workers.dev/migrate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                source_slug: sourceSlug,
                target_slug: target,
                context: ctxTa.value.trim().slice(0, 1500),
              }),
            });
            if (!res.ok) {
              const txt = await res.text().catch(function () { return ''; });
              throw new Error('HTTP ' + res.status + ' — ' + txt.slice(0, 120));
            }
            const data = await res.json();
            renderResults(data);
          } catch (e) {
            errorEl.textContent = 'Couldn\'t generate the plan: ' + (e && e.message ? e.message : e);
            errorEl.classList.remove('hidden');
            form.classList.remove('hidden');
          } finally {
            loadingEl.classList.add('hidden');
          }
        });

        function renderResults(data) {
          const subject = (data.email && data.email.subject) || 'Data export request';
          const body = (data.email && data.email.body) || '';
          const steps = Array.isArray(data.steps) ? data.steps : [];
          const effort = data.effort || '';
          const gotchas = Array.isArray(data.gotchas) ? data.gotchas : [];

          resultsEl.innerHTML =
            '<div class="rounded-lg border border-orange-200/80 dark:border-orange-900/40 bg-orange-50/40 dark:bg-orange-950/20 p-4">' +
            '<div class="flex items-center justify-between mb-2">' +
            '<h4 class="text-sm font-bold text-gray-900 dark:text-white">📧 Draft email to ' + esc(sourceName) + ' support</h4>' +
            '<button type="button" id="migrate-copy-email" class="rounded-md border border-gray-300 dark:border-gray-700 px-2 py-1 text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800">Copy</button>' +
            '</div>' +
            '<div class="text-xs text-gray-500 dark:text-gray-400 mb-1">Subject: <span class="font-mono">' + esc(subject) + '</span></div>' +
            '<pre class="whitespace-pre-wrap text-xs text-gray-800 dark:text-gray-200 font-mono leading-relaxed">' + esc(body) + '</pre>' +
            '</div>' +

            (steps.length ? (
              '<div>' +
              '<h4 class="text-sm font-bold text-gray-900 dark:text-white mb-2">🛠 Migration steps</h4>' +
              '<ol class="list-decimal space-y-2 pl-5 text-sm text-gray-700 dark:text-gray-300">' +
              steps.map(function (s) { return '<li>' + esc(s) + '</li>'; }).join('') +
              '</ol>' +
              (effort ? '<p class="mt-2 text-xs text-gray-500 dark:text-gray-400">Estimated effort: <strong>' + esc(effort) + '</strong></p>' : '') +
              '</div>'
            ) : '') +

            (gotchas.length ? (
              '<div class="rounded-lg border border-yellow-200 dark:border-yellow-900/50 bg-yellow-50/60 dark:bg-yellow-950/30 p-4">' +
              '<h4 class="text-sm font-bold text-yellow-800 dark:text-yellow-300 mb-2">⚠ Watch out for</h4>' +
              '<ul class="list-disc space-y-1 pl-5 text-sm text-yellow-700 dark:text-yellow-200">' +
              gotchas.map(function (g) { return '<li>' + esc(g) + '</li>'; }).join('') +
              '</ul>' +
              '</div>'
            ) : '') +

            '<div class="text-center pt-2">' +
            '<button type="button" id="migrate-restart-btn" class="text-xs text-gray-500 dark:text-gray-400 hover:underline">← Try a different target</button>' +
            '</div>';

          resultsEl.classList.remove('hidden');

          const copyBtn = document.getElementById('migrate-copy-email');
          if (copyBtn) {
            copyBtn.addEventListener('click', function () {
              const txt = 'Subject: ' + subject + '\n\n' + body;
              navigator.clipboard.writeText(txt).then(function () {
                copyBtn.textContent = 'Copied ✓';
                setTimeout(function () { copyBtn.textContent = 'Copy'; }, 1500);
              });
            });
          }
          const restartBtn = document.getElementById('migrate-restart-btn');
          if (restartBtn) {
            restartBtn.addEventListener('click', function () {
              resultsEl.classList.add('hidden');
              form.classList.remove('hidden');
            });
          }
        }
      })();
    </script>

    <!-- Used in stacks (use cases referencing this tool) -->
    {usedInStacks.length > 0 && (
      <section class="mt-12" data-pagefind-ignore>
        <h2 class="flex items-center gap-3 text-lg font-semibold" style="color: var(--color-text);">
          <span class="block w-1 h-6 rounded-full bg-gradient-to-b from-[#5E6AD2] to-[#818CF8]"></span>
          Used in these stacks
        </h2>
        <p class="mt-2 text-sm" style="color: var(--color-muted);">
          Curated setups that include {d.name}.
        </p>
        <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
          {usedInStacks.slice(0, 6).map((u) => (
            <a
              href={`/use-cases/${u.slug}/`}
              class="group flex items-center justify-between rounded-xl border p-4 transition-all duration-150 hover:-translate-y-0.5 hover:shadow-md"
              style="border-color: var(--color-border); background-color: var(--color-surface);"
            >
              <span class="text-sm font-semibold transition-colors duration-150 group-hover:text-[#5E6AD2] dark:group-hover:text-[#818CF8]" style="color: var(--color-text);">
                {u.title}
              </span>
              <svg class="h-4 w-4 shrink-0 opacity-40 transition-opacity duration-150 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color: var(--color-muted);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <RecommendCTA
      seed={d.slug}
      headline={`Looking for alternatives to ${d.name}?`}
      subline="Answer 4 quick questions — get an AI-ranked shortlist of tools that match your stack and requirements."
    />

    <!-- Comments -->
    <GiscusComments term={d.name} />

    <!-- Schema.org -->
    <SchemaOrg
      type="company"
      data={{
        name: d.name,
        slug: d.slug,
        website: d.website,
        description: d.description,
        logo: d.logo,
        pricing: d.pricing,
        categories: d.categories,
      }}
    />
  </article>
</BaseLayout>
