---
import { getCollection } from 'astro:content';
const year = new Date().getFullYear();
const companies = await getCollection('companies');
const toolCount = companies.length;
---

<footer style="border-top: 1px solid var(--color-border);">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-4 pb-6 pt-12 lg:px-6 sm:flex-row sm:items-start sm:justify-between">
    <!-- Left: logo + tagline -->
    <div class="flex flex-col gap-3">
      <a href="/" class="flex items-center gap-2.5">
        <span
          class="inline-flex h-7 w-7 items-center justify-center rounded-md text-xs font-black text-white"
          style="background-color: var(--color-accent);"
        >TN</span>
        <span class="text-[15px] font-semibold tracking-tight" style="color: var(--color-text);">tool.news</span>
      </a>
      <p class="max-w-xs text-sm leading-relaxed" style="color: var(--color-muted);">
        Discover and compare {toolCount}+ developer tools. Find the right tool for your stack.
      </p>
      <p class="mt-2 text-xs" style="color: color-mix(in srgb, var(--color-muted) 60%, transparent);">
        Made by <a href="https://heylabs.co" target="_blank" rel="noopener noreferrer" style="color: var(--color-text-secondary); text-decoration: underline; text-underline-offset: 2px;">HeyLabs</a> &middot; Built with Astro &middot; &copy; {year}
      </p>
    </div>

    <!-- Right: links -->
    <nav class="flex gap-12">
      <div class="flex flex-col gap-2.5">
        <h4 class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-muted);">Resources</h4>
        <a href="/about/" class="text-sm transition-colors duration-150" style="color: var(--color-text-secondary);" onmouseenter="this.style.color='var(--color-text)'" onmouseleave="this.style.color='var(--color-text-secondary)'">About</a>
        <a href="/tools/" class="text-sm transition-colors duration-150" style="color: var(--color-text-secondary);" onmouseenter="this.style.color='var(--color-text)'" onmouseleave="this.style.color='var(--color-text-secondary)'">All Tools</a>
        <a href="/categories/" class="text-sm transition-colors duration-150" style="color: var(--color-text-secondary);" onmouseenter="this.style.color='var(--color-text)'" onmouseleave="this.style.color='var(--color-text-secondary)'">Categories</a>
        <a href="/use-cases/" class="text-sm transition-colors duration-150" style="color: var(--color-text-secondary);" onmouseenter="this.style.color='var(--color-text)'" onmouseleave="this.style.color='var(--color-text-secondary)'">Use Cases</a>
      </div>
      <div class="flex flex-col gap-2.5">
        <h4 class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-muted);">Community</h4>
        <a href="https://github.com/heylabs-co/dev-tools-portal" target="_blank" rel="noopener noreferrer" class="text-sm transition-colors duration-150" style="color: var(--color-text-secondary);" onmouseenter="this.style.color='var(--color-text)'" onmouseleave="this.style.color='var(--color-text-secondary)'">GitHub</a>
        <a href="https://x.com/toolnewsHQ" target="_blank" rel="noopener noreferrer" class="text-sm transition-colors duration-150" style="color: var(--color-text-secondary);" onmouseenter="this.style.color='var(--color-text)'" onmouseleave="this.style.color='var(--color-text-secondary)'">X / Twitter</a>
        <a href="https://github.com/heylabs-co/dev-tools-portal/issues/new?template=add-tool.yml" target="_blank" rel="noopener noreferrer" class="text-sm transition-colors duration-150" style="color: var(--color-text-secondary);" onmouseenter="this.style.color='var(--color-text)'" onmouseleave="this.style.color='var(--color-text-secondary)'">Add Your Tool</a>
      </div>
    </nav>
  </div>

  <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-4 gap-y-2 px-4 pb-8 text-xs lg:px-6" style="color: var(--color-muted);">
    <button
      type="button"
      onclick="window.__cookieConsent && window.__cookieConsent.show()"
      class="cursor-pointer underline-offset-2 hover:underline"
      style="background: none; border: none; padding: 0; color: inherit; font: inherit;"
    >Your Privacy Choices</button>
  </div>
</footer>
