---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allPlugins = await getCollection('jetbrainsPlugins');
const sorted = allPlugins.sort((a, b) =>
  a.data.name.localeCompare(b.data.name, 'en', { sensitivity: 'base' })
);

const categories = [...new Set(sorted.map((s) => s.data.category ?? 'other'))].sort();
const ides = [...new Set(sorted.map((s) => s.data.ide ?? 'all'))].sort();
const totalCount = sorted.length;

const categoryLabels: Record<string, string> = {
  ai: 'AI',
  database: 'Database',
  design: 'Design',
  devops: 'DevOps',
  docker: 'Docker',
  framework: 'Framework',
  git: 'Git',
  language: 'Language',
  linting: 'Linting',
  other: 'Other',
  productivity: 'Productivity',
  testing: 'Testing',
};

const ideLabels: Record<string, string> = {
  all: 'All IDEs',
  intellij: 'IntelliJ IDEA',
  pycharm: 'PyCharm',
  webstorm: 'WebStorm',
  phpstorm: 'PhpStorm',
  rider: 'Rider',
  clion: 'CLion',
};
---

<BaseLayout
  title={`JetBrains Plugins — ${totalCount} Plugins for IntelliJ, PyCharm, WebStorm & More`}
  description={`Browse ${totalCount} curated JetBrains IDE plugins. Filter by category and IDE — find the best plugins for AI, testing, Git, DevOps, and more.`}
>
  <section class="mx-auto max-w-7xl px-4 py-10">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Plugins' }]} />

    <!-- Hero -->
    <div class="mt-6">
      <h1 class="text-4xl font-extrabold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">
        JetBrains Plugins
      </h1>
      <p class="mt-2 text-lg text-[#64748B] dark:text-[#8A8F98]">
        {totalCount} plugins for IntelliJ, PyCharm, WebStorm &amp; more
      </p>
    </div>

    <!-- Category filter pills -->
    <div class="mt-8 flex flex-wrap gap-2" id="category-filter">
      <button
        data-category="all"
        class="category-pill active rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
      >
        All
      </button>
      {categories.map((cat) => (
        <button
          data-category={cat}
          class="category-pill rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
        >
          {categoryLabels[cat] ?? cat}
        </button>
      ))}
    </div>

    <!-- IDE filter pills -->
    <div class="mt-3 flex flex-wrap gap-2" id="ide-filter">
      <button
        data-ide="all"
        class="ide-pill active rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
      >
        All IDEs
      </button>
      {ides.filter((i) => i !== 'all').map((ide) => (
        <button
          data-ide={ide}
          class="ide-pill rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
        >
          {ideLabels[ide] ?? ide}
        </button>
      ))}
    </div>

    <!-- Plugins grid -->
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" id="plugins-grid">
      {sorted.map((entry) => {
        const d = entry.data;
        const cat = d.category ?? 'other';
        const ide = d.ide ?? 'all';
        return (
          <a
            href={`/plugins/${d.slug}/`}
            class="plugin-card group rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-5 transition-colors hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 shadow-sm"
            data-category={cat}
            data-ide={ide}
          >
            <div class="flex items-start justify-between gap-3">
              <h2 class="text-base font-semibold text-[#0F172A] dark:text-[#EDEDEF] group-hover:text-[#5E6AD2] dark:group-hover:text-[#818CF8] transition-colors">
                {d.name}
              </h2>
              <span class="inline-flex shrink-0 items-center rounded-full bg-[#5E6AD2]/10 dark:bg-[#818CF8]/10 border border-[#5E6AD2]/20 dark:border-[#818CF8]/20 px-2 py-0.5 text-[10px] font-semibold text-[#5E6AD2] dark:text-[#818CF8] capitalize">
                {categoryLabels[cat] ?? cat}
              </span>
            </div>

            {d.publisher && (
              <p class="mt-1 text-xs text-[#64748B] dark:text-[#8A8F98]">
                by <span class="font-medium">{d.publisher}</span>
              </p>
            )}

            {d.description && (
              <p class="mt-2 text-sm text-[#64748B] dark:text-[#8A8F98] line-clamp-2 leading-relaxed">
                {d.description}
              </p>
            )}

            <div class="mt-3 flex items-center gap-1.5 text-xs font-medium text-[#64748B] dark:text-[#8A8F98]">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {ideLabels[ide] ?? ide}
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <style>
    .category-pill,
    .ide-pill {
      border-color: var(--color-border);
      color: var(--color-muted);
      background: transparent;
      cursor: pointer;
    }
    .category-pill:hover,
    .category-pill.active {
      border-color: var(--color-accent, #5E6AD2);
      color: var(--color-accent, #5E6AD2);
      background-color: color-mix(in srgb, var(--color-accent, #5E6AD2) 8%, transparent);
    }
    .ide-pill:hover,
    .ide-pill.active {
      border-color: #F97316;
      color: #F97316;
      background-color: color-mix(in srgb, #F97316 8%, transparent);
    }
  </style>

  <script>
    const catPills = document.querySelectorAll<HTMLButtonElement>('.category-pill');
    const idePills = document.querySelectorAll<HTMLButtonElement>('.ide-pill');
    const cards = document.querySelectorAll<HTMLElement>('.plugin-card');

    let activeCat = 'all';
    let activeIde = 'all';

    function filterCards() {
      cards.forEach((card) => {
        const matchCat = activeCat === 'all' || card.dataset.category === activeCat;
        const matchIde = activeIde === 'all' || card.dataset.ide === activeIde || card.dataset.ide === 'all';
        card.style.display = matchCat && matchIde ? '' : 'none';
      });
    }

    catPills.forEach((pill) => {
      pill.addEventListener('click', () => {
        catPills.forEach((p) => p.classList.remove('active'));
        pill.classList.add('active');
        activeCat = pill.dataset.category ?? 'all';
        filterCards();
      });
    });

    idePills.forEach((pill) => {
      pill.addEventListener('click', () => {
        idePills.forEach((p) => p.classList.remove('active'));
        pill.classList.add('active');
        activeIde = pill.dataset.ide ?? 'all';
        filterCards();
      });
    });
  </script>
</BaseLayout>
