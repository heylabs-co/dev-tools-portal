---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  jsonLd?: Record<string, unknown>;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, canonical, jsonLd, ogImage, noindex } = Astro.props;
const ogImageUrl = ogImage || 'https://tool.news/og-default.svg';
const siteUrl = 'https://tool.news';
const pageUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Preload Inter (via Tailwind) + JetBrains Mono -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      as="style"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <!-- Theme color -->
    <meta name="theme-color" content="#0A0A0F" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#FAFBFC" media="(prefers-color-scheme: light)" />

    <title>{title} — tool.news</title>
    <meta name="description" content={description} />
    {noindex ? (
      <meta name="robots" content="noindex, follow" />
    ) : (
      <link rel="canonical" href={pageUrl} />
    )}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="tool.news" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:site" content="@toolnewsHQ" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Dark mode: apply class before paint to avoid flash -->
    <script is:inline>
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.classList.add('dark');
      }
    </script>

    <!-- Cookie consent + Microsoft Clarity (gated) -->
    <script is:inline>
      (function () {
        var KEY = 'cookie-consent';
        var CLARITY_ID = 'wovo3ql7tt';
        var clarityLoaded = false;

        function loadClarity() {
          if (clarityLoaded) return;
          clarityLoaded = true;
          (function (c, l, a, r, i, t, y) {
            c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
            t = l.createElement(r); t.async = 1; t.src = 'https://www.clarity.ms/tag/' + i;
            y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
          })(window, document, 'clarity', 'script', CLARITY_ID);
        }

        window.__cookieConsent = {
          accept: function () {
            try { localStorage.setItem(KEY, 'accepted'); } catch (e) {}
            var b = document.getElementById('cookie-banner');
            if (b) b.hidden = true;
            loadClarity();
            if (window.clarity) window.clarity('consent');
          },
          decline: function () {
            try { localStorage.setItem(KEY, 'declined'); } catch (e) {}
            var b = document.getElementById('cookie-banner');
            if (b) b.hidden = true;
            if (window.clarity) window.clarity('consent', false);
          },
          show: function () {
            var b = document.getElementById('cookie-banner');
            if (b) b.hidden = false;
          },
        };

        try {
          if (localStorage.getItem(KEY) === 'accepted') loadClarity();
        } catch (e) {}
      })();
    </script>
  </head>
  <body
    class="min-h-screen flex flex-col animate-fade-in"
    style="background-color: var(--color-bg); color: var(--color-text); font-family: 'Inter', system-ui, sans-serif;"
  >
    <Header />
    <main class="flex-1" data-pagefind-body>
      <slot />
    </main>
    <Footer />

    <!-- Cookie consent banner (shown on first visit, re-openable from footer) -->
    <div
      id="cookie-banner"
      hidden
      role="dialog"
      aria-modal="true"
      aria-label="Cookie consent"
      class="fixed bottom-0 left-0 right-0 z-50"
      style="background-color: var(--color-bg); border-top: 1px solid var(--color-border); box-shadow: 0 -4px 20px rgba(0,0,0,0.08);"
    >
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-4 sm:flex-row sm:items-center sm:justify-between lg:px-6">
        <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          We use analytics cookies (Microsoft Clarity) to see anonymous session replays and click heatmaps so we can improve the catalog. No ads, no selling data.
        </p>
        <div class="flex shrink-0 gap-2">
          <button
            type="button"
            onclick="window.__cookieConsent.decline()"
            class="rounded-md px-4 py-2 text-sm font-medium transition-colors"
            style="background-color: transparent; border: 1px solid var(--color-border); color: var(--color-text-secondary);"
          >Decline</button>
          <button
            type="button"
            autofocus
            onclick="window.__cookieConsent.accept()"
            class="rounded-md px-4 py-2 text-sm font-medium text-white transition-colors"
            style="background-color: var(--color-accent);"
          >Accept</button>
        </div>
      </div>
    </div>

    <script is:inline>
      try {
        if (localStorage.getItem('cookie-consent') === null) {
          var b = document.getElementById('cookie-banner');
          if (b) b.hidden = false;
        }
      } catch (e) {}
    </script>
  </body>
</html>
