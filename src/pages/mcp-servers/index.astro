---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allServers = await getCollection('mcpServers');
const sorted = allServers.sort((a, b) => {
  // Official first, then alphabetical
  if (a.data.official !== b.data.official) return a.data.official ? -1 : 1;
  return a.data.name.localeCompare(b.data.name, 'en', { sensitivity: 'base' });
});

const categories = [...new Set(sorted.map((s) => s.data.category ?? 'other'))].sort();
const totalCount = sorted.length;

const categoryLabels: Record<string, string> = {
  ai: 'AI',
  cloud: 'Cloud',
  code: 'Code',
  communication: 'Communication',
  database: 'Database',
  design: 'Design',
  devops: 'DevOps',
  finance: 'Finance',
  other: 'Other',
  productivity: 'Productivity',
  search: 'Search',
  web: 'Web',
};
---

<BaseLayout
  title={`MCP Servers — ${totalCount} Model Context Protocol Servers`}
  description={`Browse ${totalCount} MCP servers for Claude Code and other AI assistants. Filter by category, find install commands, and connect AI to any service.`}
>
  <section class="mx-auto max-w-7xl px-4 py-10">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'MCP Servers' }]} />

    <!-- Hero -->
    <div class="mt-6">
      <h1 class="text-4xl font-extrabold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">
        MCP Server Directory
      </h1>
      <p class="mt-2 text-lg text-[#64748B] dark:text-[#8A8F98]">
        Connect AI assistants to any service &mdash; {totalCount} servers and counting
      </p>
    </div>

    <!-- Category filter pills -->
    <div class="mt-8 flex flex-wrap gap-2" id="category-filter">
      <button
        data-category="all"
        class="category-pill active rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
      >
        All
      </button>
      {categories.map((cat) => (
        <button
          data-category={cat}
          class="category-pill rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
        >
          {categoryLabels[cat] ?? cat}
        </button>
      ))}
    </div>

    <!-- Server grid -->
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" id="server-grid">
      {sorted.map((entry) => {
        const d = entry.data;
        const cat = d.category ?? 'other';
        const ghUrl = d.github_repo ? `https://github.com/${d.github_repo}` : null;
        return (
          <a
            href={`/mcp-servers/${d.slug}/`}
            class="server-card group rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-5 transition-colors hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 shadow-sm"
            data-category={cat}
          >
            <div class="flex items-start justify-between gap-3">
              <h2 class="text-base font-semibold text-[#0F172A] dark:text-[#EDEDEF] group-hover:text-[#5E6AD2] dark:group-hover:text-[#818CF8] transition-colors">
                {d.name}
              </h2>
              <div class="flex shrink-0 items-center gap-1.5">
                {d.official && (
                  <span class="inline-flex items-center rounded-full bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-200 dark:border-emerald-800/60 px-2 py-0.5 text-[10px] font-semibold text-emerald-700 dark:text-emerald-400 uppercase tracking-wider">
                    Official
                  </span>
                )}
                <span class="inline-flex items-center rounded-full bg-[#5E6AD2]/10 dark:bg-[#818CF8]/10 border border-[#5E6AD2]/20 dark:border-[#818CF8]/20 px-2 py-0.5 text-[10px] font-semibold text-[#5E6AD2] dark:text-[#818CF8] capitalize">
                  {categoryLabels[cat] ?? cat}
                </span>
              </div>
            </div>

            {d.description && (
              <p class="mt-2 text-sm text-[#64748B] dark:text-[#8A8F98] line-clamp-2 leading-relaxed">
                {d.description}
              </p>
            )}

            {d.install_command && (
              <div class="mt-3 rounded-lg bg-[#FAFBFC] dark:bg-[#0A0A0F] border border-gray-100 dark:border-gray-800 px-3 py-2">
                <code class="text-xs text-[#64748B] dark:text-[#8A8F98] font-mono truncate block">
                  {d.install_command}
                </code>
              </div>
            )}
          </a>
        );
      })}
    </div>
  </section>

  <style>
    .category-pill {
      border-color: var(--color-border);
      color: var(--color-muted);
      background: transparent;
      cursor: pointer;
    }
    .category-pill:hover,
    .category-pill.active {
      border-color: var(--color-accent, #5E6AD2);
      color: var(--color-accent, #5E6AD2);
      background-color: color-mix(in srgb, var(--color-accent, #5E6AD2) 8%, transparent);
    }
  </style>

  <script>
    const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill');
    const cards = document.querySelectorAll<HTMLElement>('.server-card');

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        pills.forEach((p) => p.classList.remove('active'));
        pill.classList.add('active');
        const cat = pill.dataset.category;

        cards.forEach((card) => {
          if (cat === 'all' || card.dataset.category === cat) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
