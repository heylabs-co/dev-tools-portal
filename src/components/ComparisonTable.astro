---
interface Company {
  name: string;
  slug: string;
  logo?: string;
  description?: string;
  pricing?: {
    model?: string;
    has_free_tier?: boolean;
    entry_price?: string;
    enterprise_available?: boolean;
    billing_complexity?: 'low' | 'medium' | 'high';
  };
  scores?: {
    lock_in?: {
      level?: 'low' | 'medium' | 'high';
      score?: number;
      migration_complexity?: 'low' | 'medium' | 'high';
      data_portability?: string;
    };
    transparency?: { level?: string; score?: number };
    developer_experience?: { level?: string; score?: number };
  };
  health?: {
    stars?: number;
    last_commit_days_ago?: number;
    release_frequency_days?: number;
    license?: string;
  };
  categories: {
    primary: { id: string; slug: string; name: string };
  };
}

interface Props {
  companyA: Company;
  companyB: Company;
}

const { companyA, companyB } = Astro.props;

type Row = {
  label: string;
  a: string;
  b: string;
  highlight?: 'lower-better' | 'higher-better' | 'bool-good' | 'level-lower-better';
};

function levelValue(level?: string): number {
  if (level === 'low') return 1;
  if (level === 'medium') return 2;
  if (level === 'high') return 3;
  return 0;
}

function fmtNum(n?: number): string {
  if (n == null) return '—';
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}

const rows: Row[] = [
  {
    label: 'Category',
    a: companyA.categories.primary.name,
    b: companyB.categories.primary.name,
  },
  {
    label: 'Pricing Model',
    a: companyA.pricing?.model && companyA.pricing.model !== 'unknown' ? companyA.pricing.model : '—',
    b: companyB.pricing?.model && companyB.pricing.model !== 'unknown' ? companyB.pricing.model : '—',
  },
  {
    label: 'Entry Price',
    a: companyA.pricing?.entry_price ?? '—',
    b: companyB.pricing?.entry_price ?? '—',
  },
  {
    label: 'Free Tier',
    a: companyA.pricing?.has_free_tier ? 'Yes' : 'No',
    b: companyB.pricing?.has_free_tier ? 'Yes' : 'No',
    highlight: 'bool-good',
  },
  {
    label: 'Billing Complexity',
    a: companyA.pricing?.billing_complexity ?? '—',
    b: companyB.pricing?.billing_complexity ?? '—',
    highlight: 'level-lower-better',
  },
  {
    label: 'Developer Experience',
    a: companyA.scores?.developer_experience?.score != null ? `${companyA.scores.developer_experience.score}/5` : '—',
    b: companyB.scores?.developer_experience?.score != null ? `${companyB.scores.developer_experience.score}/5` : '—',
    highlight: 'higher-better',
  },
  {
    label: 'Pricing Transparency',
    a: companyA.scores?.transparency?.score != null ? `${companyA.scores.transparency.score}/5` : '—',
    b: companyB.scores?.transparency?.score != null ? `${companyB.scores.transparency.score}/5` : '—',
    highlight: 'higher-better',
  },
  {
    label: 'Lock-in Level',
    a: companyA.scores?.lock_in?.level ?? '—',
    b: companyB.scores?.lock_in?.level ?? '—',
    highlight: 'level-lower-better',
  },
  {
    label: 'Migration Complexity',
    a: companyA.scores?.lock_in?.migration_complexity ?? '—',
    b: companyB.scores?.lock_in?.migration_complexity ?? '—',
    highlight: 'level-lower-better',
  },
  {
    label: 'Data Portability',
    a: companyA.scores?.lock_in?.data_portability ?? '—',
    b: companyB.scores?.lock_in?.data_portability ?? '—',
  },
  {
    label: 'Enterprise',
    a: companyA.pricing?.enterprise_available ? 'Available' : '—',
    b: companyB.pricing?.enterprise_available ? 'Available' : '—',
  },
  {
    label: 'GitHub Stars',
    a: fmtNum(companyA.health?.stars),
    b: fmtNum(companyB.health?.stars),
    highlight: 'higher-better',
  },
  {
    label: 'License',
    a: companyA.health?.license ?? '—',
    b: companyB.health?.license ?? '—',
  },
];

function cellClasses(row: Row, side: 'a' | 'b'): string {
  const val = side === 'a' ? row.a : row.b;
  const other = side === 'a' ? row.b : row.a;
  if (!row.highlight || val === '—' || other === '—') return '';

  if (row.highlight === 'bool-good') {
    if (val === 'Yes' && other === 'No') return 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300';
    if (val === 'No' && other === 'Yes') return 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-300';
  }

  if (row.highlight === 'level-lower-better') {
    const v = levelValue(val);
    const o = levelValue(other);
    if (v && o && v < o) return 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300';
    if (v && o && v > o) return 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-300';
  }

  if (row.highlight === 'lower-better') {
    const numA = parseFloat(val);
    const numB = parseFloat(other);
    if (!isNaN(numA) && !isNaN(numB)) {
      if (numA < numB) return 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300';
      if (numA > numB) return 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-300';
    }
  }

  if (row.highlight === 'higher-better') {
    const parseScore = (v: string) => {
      const m = v.match(/^([\d.]+)k?$/);
      if (!m) return NaN;
      const n = parseFloat(m[1]);
      return v.endsWith('k') ? n * 1000 : n;
    };
    const numA = parseScore(val);
    const numB = parseScore(other);
    if (!isNaN(numA) && !isNaN(numB)) {
      if (numA > numB) return 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300';
      if (numA < numB) return 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-300';
    }
  }

  return '';
}
---

<div class="overflow-x-auto rounded-xl border" style="border-color: var(--color-border);">
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr style="background-color: var(--color-elevated);">
        <th class="py-3 px-4 text-left font-medium w-1/3" style="color: var(--color-muted);"></th>
        <th class="py-3 px-4 text-center w-1/3">
          <a href={`/tools/${companyA.slug}/`} class="inline-flex flex-col items-center gap-2 hover:opacity-80 transition-opacity">
            {companyA.logo && <img src={companyA.logo} alt={companyA.name} class="h-8 w-8 object-contain rounded" loading="lazy" />}
            <span class="font-semibold" style="color: var(--color-text);">{companyA.name}</span>
          </a>
        </th>
        <th class="py-3 px-4 text-center w-1/3">
          <a href={`/tools/${companyB.slug}/`} class="inline-flex flex-col items-center gap-2 hover:opacity-80 transition-opacity">
            {companyB.logo && <img src={companyB.logo} alt={companyB.name} class="h-8 w-8 object-contain rounded" loading="lazy" />}
            <span class="font-semibold" style="color: var(--color-text);">{companyB.name}</span>
          </a>
        </th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr style="border-top: 1px solid var(--color-border);">
          <td class="py-3 px-4 font-medium" style="color: var(--color-text-secondary);">{row.label}</td>
          <td class={`py-3 px-4 text-center capitalize ${cellClasses(row, 'a')}`} style={!cellClasses(row, 'a') ? 'color: var(--color-text);' : undefined}>{row.a}</td>
          <td class={`py-3 px-4 text-center capitalize ${cellClasses(row, 'b')}`} style={!cellClasses(row, 'b') ? 'color: var(--color-text);' : undefined}>{row.b}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
