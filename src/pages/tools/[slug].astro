---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import LockInBadge from '../../components/LockInBadge.astro';
import MetricBar from '../../components/MetricBar.astro';
import PricingTable from '../../components/PricingTable.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import HealthScore from '../../components/HealthScore.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import VoteButtons from '../../components/VoteButtons.astro';
import TcoCalculator from '../../components/TcoCalculator.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const companies = await getCollection('companies');
  return companies.map((entry) => ({
    params: { slug: entry.id },
    props: { company: entry },
  }));
}

const { company } = Astro.props;
const d = company.data;

const pageTitle = d.seo?.title || `${d.name} — Developer Tool Review`;
const pageDescription = d.seo?.meta_description || d.description || `Learn about ${d.name}: pricing, lock-in score, and alternatives.`;
const initial = d.name.charAt(0).toUpperCase();

const lockIn = d.scores?.lock_in;

const scaleItems = [
  { label: 'Customers', value: d.scale?.customers },
  { label: 'Revenue', value: d.scale?.revenue },
  { label: 'Employees', value: d.scale?.employees },
  { label: 'Valuation', value: d.scale?.valuation },
].filter((item) => item.value);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article class="mx-auto max-w-4xl px-6 py-12" data-pagefind-body>
    <!-- Breadcrumbs -->
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Tools', href: '/tools/' },
        { label: d.name },
      ]}
    />

    <!-- Hero -->
    <header class="mt-10 flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex items-start gap-5 min-w-0 flex-1">
        <!-- Logo with subtle glow -->
        <div class="relative shrink-0">
          <div class="absolute -inset-2 rounded-3xl bg-[#5E6AD2]/10 dark:bg-[#818CF8]/10 blur-xl"></div>
          <div class="relative h-24 w-24 overflow-hidden rounded-2xl border border-gray-200/60 dark:border-gray-700/60 bg-white dark:bg-[#13131A] shadow-sm">
            <img
              src={d.logo ?? ''}
              alt={`${d.name} logo`}
              width="96"
              height="96"
              class="h-full w-full object-contain p-2"
              onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
            />
            <span
              class="absolute inset-0 hidden items-center justify-center text-3xl font-bold text-[#64748B] dark:text-[#8A8F98] bg-gradient-to-br from-[#5E6AD2]/5 to-[#818CF8]/10 dark:from-[#5E6AD2]/10 dark:to-[#818CF8]/20"
              aria-hidden="true"
            >
              {initial}
            </span>
          </div>
        </div>

        <div class="min-w-0 flex-1 pt-1">
          <h1 class="text-3xl font-bold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">
            {d.name}
          </h1>
          {d.description && (
            <p class="mt-2 text-base text-[#64748B] dark:text-[#8A8F98] leading-relaxed">{d.description}</p>
          )}
          <div class="mt-4 flex flex-wrap items-center gap-3">
            <a
              href={d.website}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-[#13131A] px-4 py-2 text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF] hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 transition-colors shadow-sm"
            >
              Visit website
              <svg class="h-3.5 w-3.5 text-[#64748B] dark:text-[#8A8F98]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
            <a
              href={`/compare/?a=${d.slug}`}
              class="inline-flex items-center gap-2 rounded-lg border border-[#5E6AD2]/30 dark:border-[#818CF8]/30 px-4 py-2 text-sm font-medium text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/5 dark:hover:bg-[#818CF8]/5 transition-colors"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
              Compare with...
            </a>
          </div>
        </div>
      </div>

      <!-- Vote buttons inline right -->
      <div class="shrink-0 sm:pt-1">
        <VoteButtons slug={d.slug} name={d.name} />
      </div>
    </header>

    <!-- Info badges row -->
    <div class="mt-8 flex flex-wrap items-center gap-2">
      {d.hq_country && (
        <span class="inline-flex items-center rounded-full bg-[#FAFBFC] dark:bg-[#13131A] border border-gray-200 dark:border-gray-700/60 px-3 py-1 text-xs font-medium text-[#64748B] dark:text-[#8A8F98]">
          {d.hq_country}
        </span>
      )}
      {d.founded && (
        <span class="inline-flex items-center rounded-full bg-[#FAFBFC] dark:bg-[#13131A] border border-gray-200 dark:border-gray-700/60 px-3 py-1 text-xs font-medium text-[#64748B] dark:text-[#8A8F98]">
          Est. {d.founded}
        </span>
      )}
      <span
        class:list={[
          'inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border',
          d.status === 'active'
            ? 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-700 dark:text-emerald-400 border-emerald-200 dark:border-emerald-800/60'
            : 'bg-gray-50 dark:bg-gray-800/50 text-[#64748B] dark:text-[#8A8F98] border-gray-200 dark:border-gray-700/60',
        ]}
      >
        {d.status === 'active' ? 'Active' : 'Inactive'}
      </span>
      <!-- Category badge: accent color, larger -->
      <a
        href={`/categories/${d.categories.primary.slug}/`}
        class="inline-flex items-center rounded-full bg-[#5E6AD2]/10 dark:bg-[#818CF8]/10 border border-[#5E6AD2]/20 dark:border-[#818CF8]/20 px-4 py-1 text-xs font-semibold text-[#5E6AD2] dark:text-[#818CF8] hover:bg-[#5E6AD2]/15 dark:hover:bg-[#818CF8]/15 transition-colors"
      >
        {d.categories.primary.name}
      </a>
    </div>

    <!-- Review Card -->
    {d.review && <ReviewCard review={d.review} />}

    <!-- When to Use -->
    {d.content?.when_to_use && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
          <span class="block w-1 h-6 rounded-full bg-[#5E6AD2] dark:bg-[#818CF8]"></span>
          When to Use {d.name}
        </h2>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-emerald-200/80 dark:border-emerald-800/40 bg-emerald-50/60 dark:bg-emerald-950/20 p-5">
            <h3 class="text-sm font-semibold text-emerald-800 dark:text-emerald-300 mb-3">Good fit if you need</h3>
            <ul class="space-y-2.5">
              {d.content.when_to_use.map((item: string) => (
                <li class="flex items-start gap-2.5 text-sm text-emerald-700 dark:text-emerald-400">
                  <svg class="mt-0.5 h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          {d.content.when_not_to_use && (
            <div class="rounded-xl border border-red-200/80 dark:border-red-800/40 bg-red-50/60 dark:bg-red-950/20 p-5">
              <h3 class="text-sm font-semibold text-red-800 dark:text-red-300 mb-3">Not the best choice if</h3>
              <ul class="space-y-2.5">
                {d.content.when_not_to_use.map((item: string) => (
                  <li class="flex items-start gap-2.5 text-sm text-red-700 dark:text-red-400">
                    <svg class="mt-0.5 h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
        {d.content.consider_instead && d.content.consider_instead.length > 0 && (
          <p class="mt-4 text-sm text-[#64748B] dark:text-[#8A8F98]">
            Consider instead:{' '}
            {d.content.consider_instead.map((alt: string, i: number) => (
              <>{i > 0 && ', '}<a href={`/tools/${alt}/`} class="text-[#5E6AD2] dark:text-[#818CF8] hover:underline">{alt}</a></>
            ))}
          </p>
        )}
      </section>
    )}

    <!-- Migration Cheatsheet -->
    {d.content?.migration_cheatsheet && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
          <span class="block w-1 h-6 rounded-full bg-amber-500 dark:bg-amber-400"></span>
          Migration Guide
        </h2>
        <div class="mt-5 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-6 space-y-4">
          <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF]">Difficulty:</span>
            <span class="inline-flex items-center rounded-full bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800/40 px-3 py-0.5 text-xs font-medium text-amber-700 dark:text-amber-400 capitalize">{d.content.migration_cheatsheet.difficulty}</span>
          </div>
          <div class="text-sm">
            <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Data you can export:</span>
            <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{d.content.migration_cheatsheet.data_you_keep}</span>
          </div>
          <div class="text-sm">
            <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">API standard:</span>
            <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{d.content.migration_cheatsheet.api_standard}</span>
          </div>
          {d.content.migration_cheatsheet.tip && (
            <p class="text-sm text-[#64748B] dark:text-[#8A8F98] italic border-t border-gray-100 dark:border-gray-800 pt-4">
              💡 {d.content.migration_cheatsheet.tip}
            </p>
          )}
        </div>
      </section>
    )}

    <!-- Works Well With -->
    {d.content?.works_well_with && d.content.works_well_with.length > 0 && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
          <span class="block w-1 h-6 rounded-full bg-[#5E6AD2] dark:bg-[#818CF8]"></span>
          Works Well With
        </h2>
        <div class="mt-5 flex flex-wrap gap-3">
          {d.content.works_well_with.map((slug: string) => (
            <a
              href={`/tools/${slug}/`}
              class="inline-flex items-center gap-2 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] px-4 py-2.5 text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF] hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 transition-colors shadow-sm"
            >
              <span class="flex h-6 w-6 items-center justify-center rounded-md bg-gray-100 dark:bg-gray-800 text-xs font-bold text-[#64748B] dark:text-[#8A8F98]">{slug.charAt(0).toUpperCase()}</span>
              {slug}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Lock-in Section -->
    <div data-pagefind-ignore>
    {lockIn && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
          <span class="block w-1 h-6 rounded-full bg-orange-500 dark:bg-orange-400"></span>
          Lock-in Assessment
        </h2>
        <div class="mt-5 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-6 space-y-5">
          <div class="flex items-center gap-3">
            <LockInBadge level={lockIn.level} score={lockIn.score} />
          </div>
          <MetricBar label="Lock-in Score" value={lockIn.score} maxValue={5} inverted={true} />
          {lockIn.explanation && (
            <p class="text-sm text-[#64748B] dark:text-[#8A8F98] leading-relaxed">{lockIn.explanation}</p>
          )}
          {lockIn.data_portability && (
            <div class="text-sm">
              <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Data Portability:</span>
              <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{lockIn.data_portability}</span>
            </div>
          )}
          {lockIn.api_compatibility && (
            <div class="text-sm">
              <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">API Compatibility:</span>
              <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{lockIn.api_compatibility}</span>
            </div>
          )}
        </div>
      </section>
    )}

    </div>
    <!-- Pricing Section -->
    <div data-pagefind-ignore>
    {d.pricing && (
      <section class="mt-14">
        <div class="flex items-center justify-between mb-5">
          <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
            <span class="block w-1 h-6 rounded-full bg-emerald-500 dark:bg-emerald-400"></span>
            Pricing
          </h2>
          <a
            href={`https://github.com/heylabs-co/dev-tools-portal/issues/new?title=${encodeURIComponent(`[Pricing] ${d.name} — incorrect or outdated pricing`)}&body=${encodeURIComponent(`**Tool:** ${d.name}\n**Current pricing on our site:**\n- Model: ${d.pricing?.model || 'unknown'}\n- Entry price: ${d.pricing?.entry_price || 'unknown'}\n- Free tier: ${d.pricing?.has_free_tier ? 'Yes' : 'No'}\n\n**What's wrong:**\n\n**Correct pricing (with source link):**\n`)}&labels=pricing-fix`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 rounded-lg border border-amber-200 dark:border-amber-800/40 bg-amber-50/60 dark:bg-amber-950/20 px-3 py-1.5 text-xs font-medium text-amber-700 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 transition-colors"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Price wrong?
          </a>
        </div>
        <PricingTable company={{ name: d.name, pricing: d.pricing }} />
      </section>
    )}

    <!-- No pricing — help us -->
    {!d.pricing && (
      <section class="mt-14">
        <div class="rounded-xl border border-dashed border-gray-300 dark:border-gray-700 bg-[#FAFBFC] dark:bg-[#13131A] p-8 text-center">
          <p class="text-sm text-[#64748B] dark:text-[#8A8F98]">No pricing data yet for {d.name}</p>
          <a
            href={`https://github.com/heylabs-co/dev-tools-portal/issues/new?title=${encodeURIComponent(`[Pricing] Add pricing for ${d.name}`)}&body=${encodeURIComponent(`**Tool:** ${d.name}\n**Website:** ${d.website}\n\n**Pricing info:**\n- Model (usage/subscription/freemium/seat):\n- Free tier (yes/no):\n- Entry price:\n- Pricing page URL:\n`)}&labels=pricing-data`}
            target="_blank"
            rel="noopener"
            class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-[#5E6AD2] dark:bg-[#818CF8] px-4 py-2 text-sm font-medium text-white hover:opacity-90 transition-opacity"
          >
            Help us add pricing data
          </a>
        </div>
      </section>
    )}

    <!-- TCO Calculator -->
    {d.pricing && (
      <TcoCalculator slug={d.slug} name={d.name} pricing={d.pricing} />
    )}

    </div>
    <!-- Scale Section -->
    <div data-pagefind-ignore>
    {scaleItems.length > 0 && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF] mb-5">
          <span class="block w-1 h-6 rounded-full bg-sky-500 dark:bg-sky-400"></span>
          Scale
        </h2>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
          {scaleItems.map((item) => (
            <div class="rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-5 text-center">
              <dt class="text-xs font-medium text-[#64748B] dark:text-[#8A8F98] uppercase tracking-wider">{item.label}</dt>
              <dd class="mt-2 text-xl font-bold text-[#0F172A] dark:text-[#EDEDEF]" style="font-family: 'JetBrains Mono', monospace;">{item.value}</dd>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Health Score -->
    {d.health && <HealthScore health={d.health} />}

    <!-- Alternatives Section -->
    {d.alternatives && d.alternatives.length > 0 && (
      <section class="mt-14">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF] mb-5">
          <span class="block w-1 h-6 rounded-full bg-violet-500 dark:bg-violet-400"></span>
          Alternatives
        </h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
          {d.alternatives.map((alt: string) => (
            <a
              href={`/tools/${alt}/`}
              class="flex items-center gap-3 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] px-4 py-3 text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF] hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 transition-colors shadow-sm"
            >
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gray-100 dark:bg-gray-800 text-xs font-bold text-[#64748B] dark:text-[#8A8F98] shrink-0">{alt.charAt(0).toUpperCase()}</span>
              <span class="truncate">{alt}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    </div>
    <!-- Report incorrect data -->
    <div data-pagefind-ignore>
    <div class="mt-16 pt-8 border-t border-gray-100 dark:border-gray-800/60 text-center">
      <a
        href={`https://github.com/heylabs-co/dev-tools-portal/issues/new?title=${encodeURIComponent(`[Data] Incorrect info for ${d.name}`)}&body=${encodeURIComponent(`**Tool:** ${d.name}\n**Page:** /tools/${d.slug}/\n\n**What's incorrect:**\n\n**Correct information:**\n`)}`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 text-sm text-[#64748B] dark:text-[#8A8F98] hover:text-[#0F172A] dark:hover:text-[#EDEDEF] transition-colors"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Report incorrect data
      </a>
    </div>

    <!-- Comments -->
    <GiscusComments term={d.name} />

    <!-- Schema.org -->
    <SchemaOrg
      type="company"
      data={{
        name: d.name,
        slug: d.slug,
        website: d.website,
        description: d.description,
        logo: d.logo,
        pricing: d.pricing,
        categories: d.categories,
      }}
    />
  </article>
</BaseLayout>
