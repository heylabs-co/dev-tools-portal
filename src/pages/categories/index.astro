---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CategoryGrid from '../../components/CategoryGrid.astro';

const allCategories = await getCollection('categories');

const sorted = allCategories
  .map((entry) => ({
    slug: entry.data.slug,
    name: entry.data.name,
    company_count: entry.data.company_count,
    ai_native: entry.data.ai_native,
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout
  title="All 42 Developer Tool Categories"
  description="Browse all 42 developer tool categories. Find the best tools for CI/CD, monitoring, databases, authentication, and more."
>
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Categories' },
      ]}
    />

    <h1 class="mt-6 text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
      Developer Tool Categories
    </h1>

    <div class="mt-8">
      <CategoryGrid categories={sorted} />
    </div>
  </div>
</BaseLayout>
