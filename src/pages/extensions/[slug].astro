---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const extensions = await getCollection('extensions');
  return extensions.map((entry) => ({
    params: { slug: entry.id },
    props: { extension: entry },
  }));
}

const { extension } = Astro.props;
const d = extension.data;

const pageTitle = d.seo?.title ?? `${d.name} — VS Code Extension`;
const pageDescription = d.seo?.meta_description ?? d.description ?? `Install and learn about ${d.name} VS Code extension.`;

const marketplaceUrl = d.vscode_id
  ? `https://marketplace.visualstudio.com/items?itemName=${d.vscode_id}`
  : null;

const installCommand = d.vscode_id ? `code --install-extension ${d.vscode_id}` : null;

const categoryLabels: Record<string, string> = {
  ai: 'AI',
  api: 'API',
  database: 'Database',
  debug: 'Debug',
  devops: 'DevOps',
  docker: 'Docker',
  docs: 'Documentation',
  framework: 'Framework',
  git: 'Git',
  language: 'Language',
  linting: 'Linting',
  other: 'Other',
  remote: 'Remote',
  snippets: 'Snippets',
  testing: 'Testing',
  'C# / .NET': 'C# / .NET',
  'Docker / Kubernetes': 'Docker / Kubernetes',
  'Flutter / Dart': 'Flutter / Dart',
  Go: 'Go',
  Java: 'Java',
  'JavaScript / TypeScript': 'JavaScript / TypeScript',
  PHP: 'PHP',
  Python: 'Python',
  React: 'React',
  Ruby: 'Ruby',
  Rust: 'Rust',
  Swift: 'Swift',
  'Tailwind CSS': 'Tailwind CSS',
  Terraform: 'Terraform',
  Vue: 'Vue',
};

const cat = d.category ?? 'other';
const catLabel = categoryLabels[cat] ?? cat;

// Schema.org
const schemaOrg = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: d.name,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Cross-platform',
  ...(d.description ? { description: d.description } : {}),
  ...(marketplaceUrl ? { url: marketplaceUrl } : {}),
  ...(d.publisher ? { author: { '@type': 'Organization', name: d.publisher } } : {}),
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article class="mx-auto max-w-4xl px-6 py-12">
    <!-- Breadcrumbs -->
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Extensions', href: '/extensions/' },
        { label: d.name },
      ]}
    />

    <!-- Hero card -->
    <div class="mt-10 rounded-2xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-8 shadow-sm">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-3">
            <h1 class="text-3xl font-bold tracking-tight text-[#0F172A] dark:text-[#EDEDEF]">
              {d.name}
            </h1>
            <span class="inline-flex items-center rounded-full bg-[#5E6AD2]/10 dark:bg-[#818CF8]/10 border border-[#5E6AD2]/20 dark:border-[#818CF8]/20 px-3 py-1 text-xs font-semibold text-[#5E6AD2] dark:text-[#818CF8]">
              {catLabel}
            </span>
          </div>

          {d.description && (
            <p class="mt-3 text-base text-[#64748B] dark:text-[#8A8F98] leading-relaxed max-w-2xl">
              {d.description}
            </p>
          )}

          {d.publisher && (
            <p class="mt-2 text-sm text-[#64748B] dark:text-[#8A8F98]">
              by <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">{d.publisher}</span>
            </p>
          )}
        </div>

        {d.installs && (
          <div class="shrink-0 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-[#FAFBFC] dark:bg-[#0A0A0F] px-5 py-4 text-center">
            <div class="text-2xl font-bold text-[#0F172A] dark:text-[#EDEDEF]" style="font-family: 'JetBrains Mono', monospace;">
              {d.installs}
            </div>
            <div class="text-xs text-[#64748B] dark:text-[#8A8F98] font-medium uppercase tracking-wider mt-1">Installs</div>
          </div>
        )}
      </div>

      <!-- Links -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        {marketplaceUrl && (
          <a
            href={marketplaceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-[#13131A] px-4 py-2 text-sm font-medium text-[#0F172A] dark:text-[#EDEDEF] hover:border-[#5E6AD2]/40 dark:hover:border-[#818CF8]/40 transition-colors shadow-sm"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.15 2.587L18.21.21a1.494 1.494 0 0 0-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 0 0-1.276.057L.327 7.261A1 1 0 0 0 .326 8.74L3.899 12 .326 15.26a1 1 0 0 0 .001 1.479L1.65 17.94a.999.999 0 0 0 1.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 0 0 1.704.29l4.942-2.377A1.5 1.5 0 0 0 24 20.06V3.939a1.5 1.5 0 0 0-.85-1.352zm-5.146 14.861L10.826 12l7.178-5.448v10.896z"/>
            </svg>
            Marketplace
            <svg class="h-3 w-3 text-[#64748B] dark:text-[#8A8F98]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
        )}
      </div>
    </div>

    <!-- Install command -->
    {installCommand && (
      <section class="mt-10">
        <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
          <span class="block w-1 h-6 rounded-full bg-emerald-500 dark:bg-emerald-400"></span>
          Quick Install
        </h2>
        <p class="mt-3 text-sm text-[#64748B] dark:text-[#8A8F98] leading-relaxed">
          Run this command in your terminal to install the extension:
        </p>
        <div class="mt-4 relative group">
          <pre class="rounded-xl border border-gray-200 dark:border-gray-700/60 bg-[#FAFBFC] dark:bg-[#0A0A0F] px-5 py-4 overflow-x-auto"><code class="text-sm font-mono text-[#0F172A] dark:text-[#EDEDEF]" id="install-cmd">{installCommand}</code></pre>
          <button
            class="copy-btn absolute top-3 right-3 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-[#13131A] px-2.5 py-1.5 text-xs font-medium text-[#64748B] dark:text-[#8A8F98] opacity-0 group-hover:opacity-100 transition-opacity hover:text-[#0F172A] dark:hover:text-[#EDEDEF]"
            data-target="install-cmd"
          >
            Copy
          </button>
        </div>
      </section>
    )}

    <!-- Install from VS Code -->
    <section class="mt-10">
      <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
        <span class="block w-1 h-6 rounded-full bg-[#5E6AD2] dark:bg-[#818CF8]"></span>
        Install from VS Code
      </h2>
      <div class="mt-4 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-6">
        <ol class="list-decimal list-inside space-y-3 text-sm leading-relaxed text-[#64748B] dark:text-[#8A8F98]">
          <li>Open VS Code and press <code class="rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs font-mono">Ctrl+Shift+X</code> (or <code class="rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs font-mono">Cmd+Shift+X</code> on macOS) to open the Extensions panel.</li>
          <li>Search for <code class="rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs font-mono">{d.vscode_id || d.name}</code>.</li>
          <li>Click <strong class="text-[#0F172A] dark:text-[#EDEDEF]">Install</strong> and reload if prompted.</li>
        </ol>
      </div>
    </section>

    <!-- Details -->
    <section class="mt-10">
      <h2 class="flex items-center gap-3 text-lg font-semibold text-[#0F172A] dark:text-[#EDEDEF]">
        <span class="block w-1 h-6 rounded-full" style="background-color: var(--color-accent);"></span>
        Details
      </h2>
      <div class="mt-5 rounded-xl border border-gray-200 dark:border-gray-700/60 bg-white dark:bg-[#13131A] p-6 space-y-4">
        {d.publisher && (
          <div class="text-sm">
            <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Publisher:</span>
            <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{d.publisher}</span>
          </div>
        )}
        <div class="text-sm">
          <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Category:</span>
          <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{catLabel}</span>
        </div>
        {d.installs && (
          <div class="text-sm">
            <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Installs:</span>
            <span class="ml-2 text-[#64748B] dark:text-[#8A8F98]">{d.installs}</span>
          </div>
        )}
        {d.vscode_id && (
          <div class="text-sm">
            <span class="font-medium text-[#0F172A] dark:text-[#EDEDEF]">Extension ID:</span>
            <code class="ml-2 rounded bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 text-xs font-mono text-[#64748B] dark:text-[#8A8F98]">{d.vscode_id}</code>
          </div>
        )}
      </div>
    </section>
  </article>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

  <script>
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = btn.dataset.target;
        if (!targetId) return;
        const el = document.getElementById(targetId);
        if (!el) return;
        navigator.clipboard.writeText(el.textContent ?? '').then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        });
      });
    });
  </script>
</BaseLayout>
