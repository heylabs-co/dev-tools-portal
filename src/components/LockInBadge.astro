---
interface Props {
  level: 'low' | 'medium' | 'high';
  score?: number;
}

const { level, score } = Astro.props;

const config = {
  low:    { bg: 'bg-green-100 text-green-800',  label: 'Low Lock-in' },
  medium: { bg: 'bg-yellow-100 text-yellow-800', label: 'Medium Lock-in' },
  high:   { bg: 'bg-red-100 text-red-800',       label: 'High Lock-in' },
};

const { bg, label } = config[level];
---

<span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium ${bg}`}>
  {label}
  {score !== undefined && (
    <span class="font-semibold">{score}/5</span>
  )}
</span>
