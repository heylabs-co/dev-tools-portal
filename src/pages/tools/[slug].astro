---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import LockInBadge from '../../components/LockInBadge.astro';
import MetricBar from '../../components/MetricBar.astro';
import PricingTable from '../../components/PricingTable.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const companies = await getCollection('companies');
  return companies.map((entry) => ({
    params: { slug: entry.id },
    props: { company: entry },
  }));
}

const { company } = Astro.props;
const d = company.data;

const pageTitle = d.seo?.title || `${d.name} — Developer Tool Review`;
const pageDescription = d.seo?.meta_description || d.description || `Learn about ${d.name}: pricing, lock-in score, and alternatives.`;
const initial = d.name.charAt(0).toUpperCase();

const lockIn = d.scores?.lock_in;

const scaleItems = [
  { label: 'Customers', value: d.scale?.customers },
  { label: 'Revenue', value: d.scale?.revenue },
  { label: 'Employees', value: d.scale?.employees },
  { label: 'Valuation', value: d.scale?.valuation },
].filter((item) => item.value);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <article class="mx-auto max-w-4xl px-4 py-10">
    <!-- Breadcrumbs -->
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Tools', href: '/tools/' },
        { label: d.name },
      ]}
    />

    <!-- Hero -->
    <header class="mt-8 flex flex-col items-start gap-6 sm:flex-row sm:items-center">
      <div class="relative h-20 w-20 shrink-0 overflow-hidden rounded-2xl bg-gray-100 dark:bg-gray-800">
        <img
          src={d.logo ?? ''}
          alt={`${d.name} logo`}
          width="80"
          height="80"
          class="h-full w-full object-contain"
          onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
        />
        <span
          class="absolute inset-0 hidden items-center justify-center text-3xl font-bold text-gray-400 bg-gradient-to-br from-indigo-100 to-purple-100 dark:from-indigo-900 dark:to-purple-900"
          aria-hidden="true"
        >
          {initial}
        </span>
      </div>

      <div class="min-w-0 flex-1">
        <h1 class="text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          {d.name}
        </h1>
        {d.description && (
          <p class="mt-2 text-lg text-gray-600 dark:text-gray-400">{d.description}</p>
        )}
        <a
          href={d.website}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300"
        >
          Visit website
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </header>

    <!-- Info Section -->
    <section class="mt-10 flex flex-wrap items-center gap-3">
      {d.hq_country && (
        <span class="inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300">
          HQ: {d.hq_country}
        </span>
      )}
      {d.founded && (
        <span class="inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300">
          Founded: {d.founded}
        </span>
      )}
      <span
        class:list={[
          'inline-flex items-center rounded-full px-3 py-1 text-sm font-medium',
          d.status === 'active'
            ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300'
            : 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400',
        ]}
      >
        {d.status === 'active' ? 'Active' : 'Inactive'}
      </span>
    </section>

    <!-- Category -->
    <section class="mt-6">
      <a
        href={`/categories/${d.categories.primary.slug}/`}
        class="inline-flex items-center rounded-full bg-indigo-50 dark:bg-indigo-900/30 px-3 py-1 text-sm font-medium text-indigo-700 dark:text-indigo-300 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 transition-colors"
      >
        {d.categories.primary.name}
      </a>
    </section>

    <!-- When to Use -->
    {d.content?.when_to_use && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">When to Use {d.name}</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-emerald-200 dark:border-emerald-800 bg-emerald-50 dark:bg-emerald-950/30 p-5">
            <h3 class="text-sm font-semibold text-emerald-800 dark:text-emerald-300 mb-3">Good fit if you need</h3>
            <ul class="space-y-2">
              {d.content.when_to_use.map((item: string) => (
                <li class="flex items-start gap-2 text-sm text-emerald-700 dark:text-emerald-400">
                  <span class="mt-0.5 shrink-0">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          {d.content.when_not_to_use && (
            <div class="rounded-xl border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-950/30 p-5">
              <h3 class="text-sm font-semibold text-red-800 dark:text-red-300 mb-3">Not the best choice if</h3>
              <ul class="space-y-2">
                {d.content.when_not_to_use.map((item: string) => (
                  <li class="flex items-start gap-2 text-sm text-red-700 dark:text-red-400">
                    <span class="mt-0.5 shrink-0">✗</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
        {d.content.consider_instead && d.content.consider_instead.length > 0 && (
          <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">
            Consider instead:{' '}
            {d.content.consider_instead.map((alt: string, i: number) => (
              <>{i > 0 && ', '}<a href={`/tools/${alt}/`} class="text-indigo-600 dark:text-indigo-400 hover:underline">{alt}</a></>
            ))}
          </p>
        )}
      </section>
    )}

    <!-- Migration Cheatsheet -->
    {d.content?.migration_cheatsheet && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Migration Guide</h2>
        <div class="mt-4 rounded-xl border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-950/30 p-5 space-y-3">
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-amber-800 dark:text-amber-300">Difficulty:</span>
            <span class="text-sm text-amber-700 dark:text-amber-400 capitalize">{d.content.migration_cheatsheet.difficulty}</span>
          </div>
          <div>
            <span class="text-sm font-medium text-amber-800 dark:text-amber-300">Data you can export:</span>
            <span class="ml-1 text-sm text-amber-700 dark:text-amber-400">{d.content.migration_cheatsheet.data_you_keep}</span>
          </div>
          <div>
            <span class="text-sm font-medium text-amber-800 dark:text-amber-300">API standard:</span>
            <span class="ml-1 text-sm text-amber-700 dark:text-amber-400">{d.content.migration_cheatsheet.api_standard}</span>
          </div>
          {d.content.migration_cheatsheet.tip && (
            <p class="text-sm text-amber-600 dark:text-amber-500 italic border-t border-amber-200 dark:border-amber-800 pt-3">
              💡 {d.content.migration_cheatsheet.tip}
            </p>
          )}
        </div>
      </section>
    )}

    <!-- Works Well With -->
    {d.content?.works_well_with && d.content.works_well_with.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Works Well With</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {d.content.works_well_with.map((slug: string) => (
            <a
              href={`/tools/${slug}/`}
              class="inline-flex items-center rounded-full border border-indigo-200 dark:border-indigo-800 bg-indigo-50 dark:bg-indigo-950/30 px-3 py-1.5 text-sm font-medium text-indigo-700 dark:text-indigo-300 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 transition-colors"
            >
              {slug}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Lock-in Section -->
    {lockIn && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Lock-in Assessment</h2>
        <div class="mt-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 p-6 shadow-sm space-y-4">
          <div class="flex items-center gap-3">
            <LockInBadge level={lockIn.level} score={lockIn.score} />
          </div>
          <MetricBar label="Lock-in Score" value={lockIn.score} maxValue={5} />
          {lockIn.explanation && (
            <p class="text-sm text-gray-600 dark:text-gray-400">{lockIn.explanation}</p>
          )}
          {lockIn.data_portability && (
            <div>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Data Portability:</span>
              <span class="ml-1 text-sm text-gray-600 dark:text-gray-400">{lockIn.data_portability}</span>
            </div>
          )}
          {lockIn.api_compatibility && (
            <div>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300">API Compatibility:</span>
              <span class="ml-1 text-sm text-gray-600 dark:text-gray-400">{lockIn.api_compatibility}</span>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Pricing Section -->
    {d.pricing && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Pricing</h2>
        <PricingTable company={{ name: d.name, pricing: d.pricing }} />
      </section>
    )}

    <!-- Scale Section -->
    {scaleItems.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Scale</h2>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
          {scaleItems.map((item) => (
            <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 p-4 shadow-sm text-center">
              <dt class="text-sm text-gray-500 dark:text-gray-400">{item.label}</dt>
              <dd class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">{item.value}</dd>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Alternatives Section -->
    {d.alternatives && d.alternatives.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Alternatives</h2>
        <div class="flex flex-wrap gap-2">
          {d.alternatives.map((alt: string) => (
            <a
              href={`/tools/${alt}/`}
              class="inline-flex items-center rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:border-indigo-300 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"
            >
              {alt}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Report incorrect data -->
    <div class="mt-10 text-center">
      <a
        href={`https://github.com/fusssyfusssy/Dev-Tools-Portal/issues/new?title=${encodeURIComponent(`[Data] Incorrect info for ${d.name}`)}&body=${encodeURIComponent(`**Tool:** ${d.name}\n**Page:** /tools/${d.slug}/\n\n**What's incorrect:**\n\n**Correct information:**\n`)}`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Report incorrect data
      </a>
    </div>

    <!-- Comments -->
    <GiscusComments term={d.name} />

    <!-- Schema.org -->
    <SchemaOrg
      type="company"
      data={{
        name: d.name,
        slug: d.slug,
        website: d.website,
        description: d.description,
        logo: d.logo,
        pricing: d.pricing,
        categories: d.categories,
      }}
    />
  </article>
</BaseLayout>
