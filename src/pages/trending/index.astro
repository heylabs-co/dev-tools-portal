---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import fs from 'node:fs';
import path from 'node:path';

interface Repo {
  full_name: string;
  name?: string;
  description: string;
  url: string;
  stars: number;
  language: string | null;
  company_slug?: string | null;
  stars_today?: number;
  stars_week?: number;
}

interface TrendingData {
  updated_at: string;
  hot?: Repo[];
  weekly_trend?: Repo[];
  popular?: Repo[];
  weekly?: Repo[];
}

const dataPath = path.resolve('data/repos/trending.json');
let data: TrendingData = { updated_at: '' };
if (fs.existsSync(dataPath)) {
  data = JSON.parse(fs.readFileSync(dataPath, 'utf-8')) as TrendingData;
}

const TEASER_COUNT = 9;
const hot = (data.hot ?? []).slice(0, TEASER_COUNT);
const weekly = (data.weekly_trend ?? []).slice(0, TEASER_COUNT);
const popular = (data.popular ?? data.weekly ?? []).slice(0, TEASER_COUNT);
const totals = {
  hot: data.hot?.length ?? 0,
  weekly: data.weekly_trend?.length ?? 0,
  popular: (data.popular ?? data.weekly ?? []).length,
};
const updated_at = data.updated_at;

const langColors: Record<string, string> = {
  TypeScript: '#3178c6',
  JavaScript: '#f1e05a',
  Python: '#3572A5',
  Go: '#00ADD8',
  Rust: '#dea584',
  Java: '#b07219',
  Ruby: '#701516',
  'C#': '#178600',
  'C++': '#f34b7d',
  C: '#555555',
  Swift: '#F05138',
  Kotlin: '#A97BFF',
  PHP: '#4F5D95',
  Shell: '#89e051',
  Dart: '#00B4AB',
  Elixir: '#6e4a7e',
  Scala: '#c22d40',
  Zig: '#ec915c',
  Lua: '#000080',
  Vue: '#41b883',
  Cuda: '#3A4E3A',
  HTML: '#e34c26',
  Markdown: '#083fa1',
};

function formatStars(n: number | null | undefined): string {
  if (!n || n <= 0) return '0';
  if (n >= 1000) return `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k`;
  return String(n);
}

function formatDelta(n: number | null | undefined): string {
  if (!n || n <= 0) return '';
  if (n >= 1000) return `+${(n / 1000).toFixed(1).replace(/\.0$/, '')}k`;
  return `+${n.toLocaleString()}`;
}

const sections = [
  {
    key: 'hot' as const,
    repos: hot,
    total: totals.hot,
    title: 'Hot today',
    icon: '🔥',
    subtitle: 'Repos spiking right now — most stars gained in the last 24 hours',
    deltaField: 'stars_today' as const,
    deltaSuffix: 'today',
    badgeClass: 'bg-orange-500/15 text-orange-600 dark:text-orange-300',
    href: '/trending/hot/',
  },
  {
    key: 'weekly' as const,
    repos: weekly,
    total: totals.weekly,
    title: 'This week',
    icon: '📈',
    subtitle: 'Biggest 7-day star growth',
    deltaField: 'stars_week' as const,
    deltaSuffix: 'week',
    badgeClass: 'bg-green-500/15 text-green-700 dark:text-green-300',
    href: '/trending/weekly/',
  },
  {
    key: 'popular' as const,
    repos: popular,
    total: totals.popular,
    title: 'All-time popular',
    icon: '🏆',
    subtitle: 'Most-starred dev-tool repos overall',
    deltaField: null,
    deltaSuffix: '',
    badgeClass: '',
    href: '/trending/popular/',
  },
];
---

<BaseLayout
  title="GitHub Trending — Dev-Tool Repos"
  description="GitHub repos trending today, this week, and all-time — filtered for developer tools. Updated daily."
>
  <section class="mx-auto max-w-6xl px-4 py-10">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'GitHub Trending' },
    ]} />

    <div class="mt-6">
      <h1 class="text-4xl font-extrabold tracking-tight" style="color: var(--color-text);">
        GitHub Trending
      </h1>
      <p class="mt-2 text-lg" style="color: var(--color-muted);">
        Dev-tool repos by stars today, this week, and all-time
        {updated_at && <span class="text-sm ml-2">· Updated {updated_at}</span>}
      </p>
    </div>

    {sections.map((sec) => (
      <div class="mt-14">
        <div class="flex items-end justify-between gap-3 flex-wrap">
          <div>
            <h2 class="flex items-center gap-2 text-2xl font-bold tracking-tight" style="color: var(--color-text);">
              <span>{sec.icon}</span>
              {sec.title}
            </h2>
            <p class="mt-1 text-sm" style="color: var(--color-muted);">
              {sec.subtitle}
            </p>
          </div>
          {sec.total > sec.repos.length && (
            <a
              href={sec.href}
              class="text-sm font-medium"
              style="color: var(--color-accent);"
            >See all {sec.total} →</a>
          )}
        </div>

        {sec.repos.length === 0 ? (
          <p class="mt-6 text-sm" style="color: var(--color-muted);">
            No data yet. Daily GitHub Action fetches this at 06:00 UTC.
          </p>
        ) : (
          <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {sec.repos.map((repo) => {
              const delta = sec.deltaField ? repo[sec.deltaField] : undefined;
              return (
                <article
                  class="group rounded-xl border p-5 transition-all duration-200 hover:shadow-md"
                  style="background-color: var(--color-surface); border-color: var(--color-border);"
                >
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="text-base font-semibold leading-tight" style="color: var(--color-text);">
                      <a href={repo.url} target="_blank" rel="noopener noreferrer" class="hover:underline">
                        {repo.full_name}
                      </a>
                    </h3>
                    {delta && delta > 0 ? (
                      <span
                        class={`inline-flex shrink-0 items-center gap-1 rounded-full px-2 py-0.5 text-xs font-bold ${sec.badgeClass}`}
                        title={`${delta.toLocaleString()} stars ${sec.deltaSuffix}`}
                      >
                        {formatDelta(delta)} ⭐ {sec.deltaSuffix}
                      </span>
                    ) : (
                      <span
                        class="inline-flex shrink-0 items-center gap-1 text-sm font-medium"
                        style="color: var(--color-muted);"
                        title={`${repo.stars.toLocaleString()} stars`}
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                        {formatStars(repo.stars)}
                      </span>
                    )}
                  </div>

                  <p class="mt-2 line-clamp-2 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                    {repo.description || 'No description'}
                  </p>

                  <div class="mt-3 flex flex-wrap items-center gap-3 text-xs" style="color: var(--color-muted);">
                    {repo.language && (
                      <span class="inline-flex items-center gap-1.5">
                        <span class="inline-block h-2.5 w-2.5 rounded-full" style={`background-color: ${langColors[repo.language] || '#888'};`} />
                        {repo.language}
                      </span>
                    )}
                    {sec.deltaField && (
                      <span class="inline-flex items-center gap-1" title={`${repo.stars.toLocaleString()} total stars`}>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                        {formatStars(repo.stars)}
                      </span>
                    )}
                    {repo.company_slug && (
                      <a href={`/tools/${repo.company_slug}/`} class="font-medium hover:underline" style="color: var(--color-accent);">
                        on tool.news →
                      </a>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>
    ))}
  </section>
</BaseLayout>
