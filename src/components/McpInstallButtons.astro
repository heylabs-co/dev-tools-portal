---
/**
 * Deep-link install buttons for MCP servers.
 * Generates clickable links that open Cursor / VS Code / VS Code Insiders
 * with the MCP config pre-filled. Plus copy buttons for Claude Code CLI
 * and raw JSON (for Antigravity, Windsurf, Zed, and other clients).
 */
interface Props {
  serverName: string;
  npmPackage?: string;
  installCommand?: string;
}

const { serverName, npmPackage, installCommand } = Astro.props;

// Build the server config object: { command, args, env? }
let command = '';
let args: string[] = [];
if (installCommand) {
  const parts = installCommand.trim().split(/\s+/);
  command = parts[0];
  args = parts.slice(1);
} else if (npmPackage) {
  command = 'npx';
  args = ['-y', npmPackage];
}

const hasConfig = command.length > 0;
const serverConfig = { command, args };

// Cursor deep link: cursor://anysphere.cursor-deeplink/mcp/install?name=X&config=base64(JSON)
const cursorConfigB64 = hasConfig ? Buffer.from(JSON.stringify(serverConfig)).toString('base64') : '';
const cursorUrl = hasConfig
  ? `cursor://anysphere.cursor-deeplink/mcp/install?name=${encodeURIComponent(serverName)}&config=${cursorConfigB64}`
  : '';

// VS Code MCP install: vscode:mcp/install?<url-encoded-JSON>
const vscodePayload = hasConfig
  ? JSON.stringify({ name: serverName, gallery: true, ...serverConfig })
  : '';
const vscodeUrl = hasConfig ? `vscode:mcp/install?${encodeURIComponent(vscodePayload)}` : '';
const vscodeInsidersUrl = hasConfig ? `vscode-insiders:mcp/install?${encodeURIComponent(vscodePayload)}` : '';

// Claude Code CLI command
const claudeCliCmd = hasConfig
  ? `claude mcp add-json ${serverName} '${JSON.stringify(serverConfig)}'`
  : '';

// Full JSON for copy (universal fallback for any client)
const fullJson = hasConfig
  ? JSON.stringify({ mcpServers: { [serverName]: serverConfig } }, null, 2)
  : '';
---

{hasConfig && (
  <div class="mcp-install-buttons">
    <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#64748B] dark:text-[#8A8F98]">
      One-click install
    </h3>
    <div class="flex flex-wrap gap-2">
      <a
        href={cursorUrl}
        class="install-btn install-btn-accent"
        data-client="cursor"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M11.925 24l10.425-6v-12L11.925 0 1.5 6v12l10.425 6z" />
        </svg>
        Install in Cursor
      </a>

      <a href={vscodeUrl} class="install-btn" data-client="vscode">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.15 2.587L18.21.21a1.494 1.494 0 0 0-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 0 0-1.276.057L.327 7.261A1 1 0 0 0 .326 8.74L3.899 12 .326 15.26a1 1 0 0 0 .001 1.479L1.65 17.94a.999.999 0 0 0 1.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 0 0 1.704.29l4.942-2.377A1.5 1.5 0 0 0 24 20.06V3.939a1.5 1.5 0 0 0-.85-1.352zm-5.146 14.861L10.826 12l7.178-5.448v10.896z" />
        </svg>
        Install in VS Code
      </a>

      <button type="button" class="install-btn copy-mcp-cmd" data-cmd={claudeCliCmd}>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="4 17 10 11 4 5" stroke-linecap="round" stroke-linejoin="round" />
          <line x1="12" y1="19" x2="20" y2="19" stroke-linecap="round" />
        </svg>
        Copy for Claude Code
      </button>
    </div>

    <details class="mt-3 text-sm">
      <summary class="cursor-pointer text-[#64748B] dark:text-[#8A8F98] hover:text-[#0F172A] dark:hover:text-[#EDEDEF] select-none">
        More clients (VS Code Insiders, Antigravity, Windsurf, Zed, Trae…)
      </summary>
      <div class="mt-3 flex flex-wrap gap-2">
        <a href={vscodeInsidersUrl} class="install-btn install-btn-sm" data-client="vscode-insiders">
          VS Code Insiders
        </a>
        <button type="button" class="install-btn install-btn-sm copy-mcp-json" data-json={fullJson}>
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" stroke-linejoin="round" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke-linejoin="round" />
          </svg>
          Copy JSON (any client)
        </button>
      </div>
      <p class="mt-3 text-xs text-[#64748B] dark:text-[#8A8F98] leading-relaxed">
        JSON works with: <strong>Antigravity</strong> (Google), <strong>Windsurf</strong> (Codeium), <strong>Trae</strong> (ByteDance), <strong>Zed</strong>, <strong>Continue.dev</strong>, <strong>Cline</strong>, <strong>Roo Code</strong>, and any other MCP-compatible client.
        Paste into their MCP config file or settings.
      </p>
    </details>
  </div>
)}

<style>
  .install-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
    transition: all 0.15s;
    cursor: pointer;
  }
  .install-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .install-btn-accent {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .install-btn-accent:hover {
    opacity: 0.9;
    color: #fff;
  }
  .install-btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.copy-mcp-cmd, .copy-mcp-json').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.cmd ?? btn.dataset.json ?? '';
      if (!text) return;
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.innerHTML;
        btn.innerHTML = '<span>Copied!</span>';
        setTimeout(() => { btn.innerHTML = original; }, 1500);
      });
    });
  });
</script>
