---
const mobileLinks = [
  { label: 'Dev News 🟢', href: '/news/' },
  { label: 'Tools', href: '/tools/' },
  { label: 'MCP Servers', href: '/mcp-servers/' },
  { label: 'AI Skills', href: '/skills/' },
  { label: 'GitHub Trending', href: '/trending/' },
  { label: 'Use Cases', href: '/use-cases/' },
  { label: 'Compare', href: '/compare/' },
  { label: 'VS Code Extensions', href: '/extensions/' },
  { label: 'JetBrains Plugins', href: '/plugins/' },
];

const aiEcosystemLinks = [
  { label: 'MCP Servers', href: '/mcp-servers/' },
  { label: 'AI Skills', href: '/skills/' },
];

const moreLinks = [
  { label: 'GitHub Trending', href: '/trending/' },
  { label: 'Use Cases', href: '/use-cases/' },
  { label: 'Compare Tools', href: '/compare/' },
  { label: 'VS Code Extensions', href: '/extensions/' },
  { label: 'JetBrains Plugins', href: '/plugins/' },
];

const ADD_TOOL_HREF = 'https://github.com/heylabs-co/dev-tools-portal/issues/new?template=add-tool.yml';
---

<header
  id="site-header"
  class="sticky top-0 z-50 transition-all duration-200"
  style="background-color: transparent;"
>
  <div
    class="backdrop-blur-xl"
    style="background-color: color-mix(in srgb, var(--color-surface) 80%, transparent); border-bottom: 1px solid var(--color-border);"
  >
    <nav class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 lg:px-6">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group shrink-0">
        <span
          class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-sm font-black text-white transition-transform duration-200 group-hover:scale-105"
          style="background-color: var(--color-accent);"
        >TN</span>
        <span
          class="hidden text-[15px] font-semibold tracking-tight lg:inline"
          style="color: var(--color-text);"
        >tool.news</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden items-center gap-1 md:flex">
        <li>
          <a href="/news/" class="nav-link relative flex items-center gap-1.5 px-3 py-2 text-sm font-medium transition-colors duration-150" style="color: var(--color-muted);">
            <span class="relative inline-flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-75"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-green-500"></span>
            </span>
            Dev News
            <span class="nav-underline absolute bottom-0.5 left-3 right-3 h-px origin-left scale-x-0 transition-transform duration-200 ease-out" style="background-color: var(--color-accent);"></span>
          </a>
        </li>
        <li>
          <a href="/tools/" class="nav-link relative px-3 py-2 text-sm font-medium transition-colors duration-150" style="color: var(--color-muted);">
            Tools
            <span class="nav-underline absolute bottom-0.5 left-3 right-3 h-px origin-left scale-x-0 transition-transform duration-200 ease-out" style="background-color: var(--color-accent);"></span>
          </a>
        </li>

        <!-- AI Ecosystem dropdown -->
        <li class="dropdown-parent relative">
          <button
            class="nav-link dropdown-trigger relative flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors duration-150 cursor-default select-none"
            style="color: var(--color-muted);"
            tabindex="0"
            aria-haspopup="true"
          >
            AI Ecosystem
            <svg class="chevron h-3.5 w-3.5 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
            <span class="nav-underline absolute bottom-0.5 left-3 right-3 h-px origin-left scale-x-0 transition-transform duration-200 ease-out" style="background-color: var(--color-accent);"></span>
          </button>
          <div class="dropdown-menu absolute left-0 top-full pt-1 hidden">
            <ul class="min-w-[180px] rounded-xl shadow-lg py-1.5" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
              {aiEcosystemLinks.map((link) => (
                <li>
                  <a href={link.href} class="dropdown-item flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors duration-150" style="color: var(--color-text-secondary);">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>

        <!-- More dropdown -->
        <li class="dropdown-parent relative">
          <button
            class="nav-link dropdown-trigger relative flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors duration-150 cursor-default select-none"
            style="color: var(--color-muted);"
            tabindex="0"
            aria-haspopup="true"
          >
            More
            <svg class="chevron h-3.5 w-3.5 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
            <span class="nav-underline absolute bottom-0.5 left-3 right-3 h-px origin-left scale-x-0 transition-transform duration-200 ease-out" style="background-color: var(--color-accent);"></span>
          </button>
          <div class="dropdown-menu absolute left-0 top-full pt-1 hidden">
            <ul class="min-w-[220px] rounded-xl shadow-lg py-1.5" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
              {moreLinks.map((link) => (
                <li>
                  <a href={link.href} class="dropdown-item flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors duration-150" style="color: var(--color-text-secondary);">
                    {link.label}
                  </a>
                </li>
              ))}
              <li class="my-1 border-t" style="border-color: var(--color-border);"></li>
              <li>
                <a
                  href={ADD_TOOL_HREF}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="dropdown-item flex items-center gap-2 px-4 py-2.5 text-sm font-semibold transition-colors duration-150"
                  style="color: var(--color-accent);"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                  Add a tool
                </a>
              </li>
            </ul>
          </div>
        </li>
      </ul>

      <!-- Search + mobile toggle -->
      <div class="flex items-center gap-2 flex-1 justify-end min-w-0">
        <!-- Inline header search with live autocomplete -->
        <form
          action="/search/"
          method="get"
          role="search"
          class="header-search relative flex items-center flex-1 sm:flex-none max-w-[280px] md:max-w-none"
          autocomplete="off"
        >
          <svg
            class="absolute left-2.5 h-4 w-4 pointer-events-none"
            style="color: var(--color-muted);"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
          </svg>
          <input
            id="header-search-input"
            type="search"
            name="q"
            autocomplete="off"
            placeholder="Search tools…"
            aria-label="Search tools"
            aria-autocomplete="list"
            aria-controls="header-search-results"
            class="w-full md:w-60 lg:w-72 rounded-lg border py-1.5 pl-8 pr-8 text-sm transition-colors duration-150 focus:outline-none"
            style="background-color: var(--color-elevated); border-color: var(--color-border); color: var(--color-text);"
          />
          <kbd
            class="absolute right-2 pointer-events-none rounded border px-1 text-[10px] font-mono hidden md:inline-block"
            style="border-color: var(--color-border); color: var(--color-muted); background-color: var(--color-surface);"
            aria-hidden="true"
          >/</kbd>

          <!-- Live autocomplete dropdown -->
          <div
            id="header-search-results"
            role="listbox"
            class="absolute left-0 right-0 top-full mt-1 hidden rounded-xl shadow-lg overflow-hidden z-50"
            style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
          ></div>
        </form>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="inline-flex h-8 w-8 items-center justify-center rounded-lg transition-colors duration-150 md:hidden shrink-0"
          style="color: var(--color-muted);"
          aria-label="Toggle menu"
        >
          <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile slide-in menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-[57px] z-40 translate-x-full transition-transform duration-300 ease-out md:hidden"
  >
    <div class="absolute inset-0 backdrop-blur-sm" style="background-color: rgba(0,0,0,0.3);" id="mobile-backdrop"></div>
    <div
      class="absolute right-0 top-0 bottom-0 w-72 overflow-y-auto p-5"
      style="background-color: color-mix(in srgb, var(--color-surface) 95%, transparent); backdrop-filter: blur(20px); border-left: 1px solid var(--color-border);"
    >
      <ul class="flex flex-col gap-1">
        {mobileLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block rounded-lg px-3 py-2.5 text-sm font-medium transition-colors duration-150"
              style={`color: var(--color-text-secondary);`}
              onmouseenter="this.style.backgroundColor='var(--color-elevated)';this.style.color='var(--color-text)'"
              onmouseleave="this.style.backgroundColor='transparent';this.style.color='var(--color-text-secondary)'"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="mt-3 pt-3" style="border-top: 1px solid var(--color-border);">
          <a
            href="https://github.com/heylabs-co/dev-tools-portal/issues/new?template=add-tool.yml"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors duration-150"
            style={`color: var(--color-accent);`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add Tool
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<style>
  .header-search input:focus {
    border-color: var(--color-accent) !important;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  .nav-link:hover {
    color: var(--color-text) !important;
  }
  .nav-link:hover .nav-underline {
    transform: scaleX(1);
  }

  .dropdown-parent:hover .dropdown-trigger {
    color: var(--color-text) !important;
  }
  .dropdown-parent:hover .dropdown-trigger .nav-underline {
    transform: scaleX(1);
  }
  .dropdown-parent:hover .chevron {
    transform: rotate(180deg);
  }
  .dropdown-parent:hover .dropdown-menu,
  .dropdown-parent:focus-within .dropdown-menu {
    display: block !important;
  }

  .dropdown-item:hover {
    background-color: var(--color-elevated) !important;
    color: var(--color-text) !important;
  }

  .add-tool-btn:hover {
    background-color: var(--color-accent) !important;
    color: #fff !important;
  }

  /* Live search container — static Astro-rendered element */
  #header-search-results {
    max-height: 28rem;
    overflow-y: auto;
  }
</style>

<!-- Global because the dropdown contents are injected via innerHTML at runtime;
     they don't carry Astro's scoped data-attribute so scoped selectors miss. -->
<style is:global>
  .hs-result {
    display: block;
    padding: 0.625rem 0.875rem;
    text-decoration: none;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.12s;
  }
  .hs-result:last-child { border-bottom: none; }
  .hs-result:hover,
  .hs-result.hs-active {
    background-color: var(--color-elevated);
  }
  .hs-result-title {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hs-result-title mark {
    background: color-mix(in srgb, var(--color-accent) 22%, transparent);
    color: inherit;
    padding: 0 0.125rem;
    border-radius: 2px;
  }
  .hs-result-meta {
    margin-top: 0.15rem;
    font-size: 0.72rem;
    color: var(--color-muted);
    display: flex;
    gap: 0.5rem;
    align-items: center;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .hs-result-excerpt {
    margin-top: 0.2rem;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hs-result-excerpt mark {
    background: color-mix(in srgb, var(--color-accent) 22%, transparent);
    color: inherit;
    padding: 0 0.125rem;
    border-radius: 2px;
  }
  .hs-footer {
    padding: 0.55rem 0.875rem;
    font-size: 0.75rem;
    color: var(--color-muted);
    border-top: 1px solid var(--color-border);
    background-color: var(--color-elevated);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .hs-footer a {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }
  .hs-footer a:hover { text-decoration: underline; }
  .hs-empty {
    padding: 0.875rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-align: center;
  }
</style>

<script is:inline type="module">
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-backdrop');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  function toggleMenu() {
    const isOpen = !menu?.classList.contains('translate-x-full');
    menu?.classList.toggle('translate-x-full', isOpen);
    menu?.classList.toggle('translate-x-0', !isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  }

  btn?.addEventListener('click', toggleMenu);
  backdrop?.addEventListener('click', toggleMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !e.ctrlKey && !e.metaKey) {
      const t = e.target;
      if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
      const inp = document.getElementById('header-search-input');
      if (inp) { e.preventDefault(); inp.focus(); }
    }
  });

  // ─── Live autocomplete (Pagefind JS API) ───────────────────────────────
  const input = document.getElementById('header-search-input');
  const results = document.getElementById('header-search-results');
  const form = input && input.closest('form');

  if (input && results && form) {
    let pagefind = null;
    let pfLoading = null;
    let activeIdx = -1;
    let currentQuery = '';

    async function loadPagefind() {
      if (pagefind) return pagefind;
      if (pfLoading) return pfLoading;
      pfLoading = (async () => {
        try {
          const pf = await import('/pagefind/pagefind.js');
          if (pf && pf.options) await pf.options({ excerptLength: 20 });
          pagefind = pf;
          return pf;
        } catch (_e) {
          return null;
        }
      })();
      return pfLoading;
    }

    function hide() {
      results.classList.add('hidden');
      results.innerHTML = '';
      activeIdx = -1;
    }

    function show() { results.classList.remove('hidden'); }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      }[c] || c));
    }

    function render(items, query) {
      if (!items.length) {
        results.innerHTML = `<div class="hs-empty">No matches for "${escapeHtml(query)}"</div>
          <div class="hs-footer"><span></span><a href="/search/?q=${encodeURIComponent(query)}">Open full search →</a></div>`;
        show();
        return;
      }
      const html = items.map((d, i) => {
        const title = escapeHtml((d.meta && d.meta.title) || d.url);
        const type = (d.meta && d.meta.type) || '';
        const excerpt = d.excerpt || '';
        return `<a class="hs-result" role="option" href="${d.url}" data-idx="${i}">
          <div class="hs-result-title">${title}</div>
          ${type ? `<div class="hs-result-meta"><span>${escapeHtml(type)}</span></div>` : ''}
          ${excerpt ? `<div class="hs-result-excerpt">${excerpt}</div>` : ''}
        </a>`;
      }).join('');
      results.innerHTML = html +
        `<div class="hs-footer"><span>${items.length} shown</span><a href="/search/?q=${encodeURIComponent(query)}">Open full search →</a></div>`;
      show();
    }

    function setActive(idx) {
      const cards = results.querySelectorAll('.hs-result');
      if (!cards.length) return;
      activeIdx = (idx + cards.length) % cards.length;
      cards.forEach((c, i) => c.classList.toggle('hs-active', i === activeIdx));
      cards[activeIdx] && cards[activeIdx].scrollIntoView({ block: 'nearest' });
    }

    let debounce = null;
    async function onInput() {
      const q = input.value.trim();
      currentQuery = q;
      if (debounce) clearTimeout(debounce);
      if (q.length < 2) { hide(); return; }
      debounce = setTimeout(async () => {
        const pf = await loadPagefind();
        if (!pf || currentQuery !== q) return;
        try {
          const s = await pf.search(q);
          if (currentQuery !== q) return;
          const top = await Promise.all(s.results.slice(0, 5).map((r) => r.data()));
          render(top, q);
        } catch (_e) { hide(); }
      }, 140);
    }

    input.addEventListener('input', onInput);
    input.addEventListener('focus', () => {
      if (input.value.trim().length >= 2 && results.innerHTML) show();
    });
    input.addEventListener('keydown', (e) => {
      const cards = results.querySelectorAll('.hs-result');
      if (e.key === 'ArrowDown' && cards.length) { e.preventDefault(); setActive(activeIdx + 1); }
      else if (e.key === 'ArrowUp' && cards.length) { e.preventDefault(); setActive(activeIdx - 1); }
      else if (e.key === 'Enter') {
        if (activeIdx >= 0 && cards[activeIdx]) { e.preventDefault(); window.location.href = cards[activeIdx].href; }
      } else if (e.key === 'Escape') { hide(); input.blur(); }
    });

    document.addEventListener('click', (e) => {
      if (!form.contains(e.target)) hide();
    });

    input.addEventListener('focus', () => { loadPagefind(); }, { once: true });
  }
</script>
